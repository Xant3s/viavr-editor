{
  "name": "viavr-editor",
  "version": "0.1.0",
  "description": "VIA-VR Editor",
  "main": "dist/App/app.js",
  "scripts": {
    "postinstall": "cd plugins/Spoke && yarn install",
    "start": "tsc && electron-forge start",
    "package": "tsc && electron-forge package",
    "make": "tsc && electron-forge make",
    "copy-dependencies:win": "cpy plugins out/viavr-editor-win32-x64 --parents --dot",
    "make:win": "tsc && electron-forge make && copy-dependencies"
  },
  "repository": {
    "type": "git",
    "url": "git@gitlab2.informatik.uni-wuerzburg.de:GE/Teaching/grl/2021-truman-viavr-editor.git"
  },
  "keywords": [],
  "author": "Samuel Truman",
  "license": "none",
  "devDependencies": {
    "@electron-forge/cli": "^6.0.0-beta.54",
    "@electron-forge/maker-deb": "^6.0.0-beta.54",
    "@electron-forge/maker-rpm": "^6.0.0-beta.54",
    "@electron-forge/maker-squirrel": "^6.0.0-beta.54",
    "@electron-forge/maker-zip": "^6.0.0-beta.54",
    "@types/jquery": "^3.5.13",
    "cpy-cli": "^3.1.1",
    "electron": "^11.3.0",
    "electron-reloader": "^1.2.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^4.2.2"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.0",
    "extract-zip": "^2.0.1",
    "jquery": "^3.6.0",
    "node-fetch": "^2.6.7"
  },
  "config": {
    "forge": {
      "packagerConfig": {},
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "unity_interop"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-deb",
          "config": {}
        },
        {
          "name": "@electron-forge/maker-rpm",
          "config": {}
        }
      ]
    }
  }
}
