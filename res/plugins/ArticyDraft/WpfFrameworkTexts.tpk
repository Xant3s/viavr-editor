			<Text Lang="pt-BR">articy:draft</Text>
			<Text Lang="zh">articy:draft</Text>
			<Text Lang="ko">articy:draft</Text>
			<Text Lang="de">articy:draft</Text>
		</TextDefinition>

		<TextDefinition Key="Default.InfoText">
