		<TextDefinition Key="Error.EmptyKey">
			<Context>Dialogbox 'Enter license key': Error label when no key is entered</Context>
			<Text Lang="en">A valid license key is required.</Text>
			<Text Lang="uk">Необхідний дісний ліцензійний ключ.</Text>
