<?xml version='1.0' encoding='utf-8' standalone='yes' ?>
<TextPackage BaseNamespace="Articy.Editor" GenerateIds="True" xml:space="preserve" xmlns="http://nevigo.com/TextPackage.xsd">

	<!--
	  Application
	-->
	<Category Name="Ui" Namespace=".App">

		<TextDefinition Key="CantReadImage.Description">
			<Context>Messagebox text: The image that was selected as template icon could not be read.</Context>
			<Text Lang="en">Image can't be read.</Text>
			<Text Lang="uk">Зображення неможливо прочитати.</Text>
			<Text Lang="fr">Impossible de lire l’image.</Text>
			<Text Lang="pt-BR">Imagem não pode ser lida.</Text>
			<Text Lang="zh">图像无法读取。</Text>
			<Text Lang="ko">이미지를 읽을 수 없습니다.</Text>
			<Text Lang="pl">Obraz nie może zostać odczytany.</Text>
			<Text Lang="es">La imagen no se puede leer.</Text>
			<Text Lang="it">L'immagine non può essere aperta.</Text>
			<Text Lang="ru">Образ не может быть прочитан.</Text>
			<Text Lang="ja">イメージが開けられません。</Text>
			<Text Lang="de">Bilddatei kann nicht geladen werden.</Text>
		</TextDefinition>

		<TextDefinition Key="Title.NoProject">
			<Context>The name of the application, shown in the window title bar when no project is opened. Also the window title name for secondary windows.</Context>
			<Text Lang="en">{4}</Text>
			<Text Lang="uk">{4}</Text>
			<Text Lang="fr">{4}</Text>
			<Text Lang="pt-BR">{4}</Text>
			<Text Lang="zh">{4}</Text>
			<Text Lang="ko">{4}</Text>
			<Text Lang="pl">{4}</Text>
			<Text Lang="es">{4}</Text>
			<Text Lang="it">{4}</Text>
			<Text Lang="ru">{4}</Text>
			<Text Lang="ja">{4}</Text>
			<Text Lang="de">{4}</Text>
		</TextDefinition>

		<TextDefinition Key="Title.WithLocalProject">
			<Context>The name of the application, shown in the window title bar when a single-user project is opened. 0=project name, 1=project folder, 4=productname.</Context>
			<Text Lang="en">{4} - {0} ({1})</Text>
			<Text Lang="uk">{4} - {0} ({1})</Text>
			<Text Lang="fr">{4} - {0} ({1})</Text>
			<Text Lang="pt-BR">{4} - {0}({1})</Text>
			<Text Lang="zh">{4} - {0} ({1})</Text>
			<Text Lang="ko">{4} - {0} ({1})</Text>
			<Text Lang="pl">{4} - {0} ({1})</Text>
			<Text Lang="es">{4} - {0} ({1})</Text>
			<Text Lang="it">{4} - {0} ({1})</Text>
			<Text Lang="ru">{4} - {0} ({1})</Text>
			<Text Lang="ja">{4} - {0} ({1})</Text>
			<Text Lang="de">{4} - {0} ({1})</Text>
		</TextDefinition>

		<TextDefinition Key="Title.WithOfflineProject" Unused="1">
			<Context>The name of the application, shown in the window title bar when a server project is opened in offline mode. 0=project name, 1=project folder, 2=user name, 4=productname.</Context>
			<Text Lang="en">{4} - {0} ({1}) - {2}</Text>
			<Text Lang="uk">{4} - {0} ({1}) - {2}</Text>
			<Text Lang="fr">{4} - {0} ({1}) - {2}</Text>
			<Text Lang="pt-BR">{4} - {0}({1}) - {2}</Text>
			<Text Lang="zh">{4} - {0} ({1}) - {2}</Text>
			<Text Lang="ko">{4} - {0} ({1}) - {2}</Text>
			<Text Lang="pl">{4} - {0} ({1}) - {2} @ {3}</Text>
			<Text Lang="ja">{4} - {0} ({1}) - {2}</Text>
			<Text Lang="de">{4} - {0} ({1}) - {2}</Text>
		</TextDefinition>

		<TextDefinition Key="Title.WithOnlineProject">
			<Context>The name of the application, shown in the window title bar when a multi-user project is opened. 0=project name, 1=project folder, 2=user name, 3=server name, 4=productname.</Context>
			<Text Lang="en">{4} - {0} ({1}) - {2} @ {3}</Text>
			<Text Lang="uk">{4} - {0} ({1}) - {2} @ {3}</Text>
			<Text Lang="fr">{4} - {0} ({1}) - {2} @ {3}</Text>
			<Text Lang="pt-BR">{4} - {0}({1}) - {2} @ 3</Text>
			<Text Lang="zh">{4} - {0} ({1}) - {2} @ {3}</Text>
			<Text Lang="ko">{4} - {0} ({1}) - {2} @ {3}</Text>
			<Text Lang="pl">{4} - {0} ({1}) - {2} @ {3}</Text>
			<Text Lang="es">{4} - {0} ({1}) - {2} @ {3}</Text>
			<Text Lang="it">{4} - {0} ({1})- {2} @ {3}</Text>
			<Text Lang="ru">{4} - {0} ({1}) - {2} @ {3}</Text>
			<Text Lang="ja">{4} - {0} ({1}) - {2} @ {3}</Text>
			<Text Lang="de">{4} - {0} ({1}) - {2} @ {3}</Text>
		</TextDefinition>

		<TextDefinition Key="HelpButton.Text">
			<Context>Button text: Pressing opens the webpage with the online manual.</Context>
			<Text Lang="en">Articy Help Center</Text>
			<Text Lang="uk">Центр Підтримки Articy</Text>
			<Text Lang="fr">Centre d’aide d’Articy</Text>
			<Text Lang="pt-BR">Centro de ajuda Articy</Text>
			<Text Lang="zh">Articy帮助中心</Text>
			<Text Lang="ko">Articy 도움말 센터</Text>
			<Text Lang="pl">Centrum Pomocy Articy</Text>
			<Text Lang="es">Centro de ayuda de Articy</Text>
			<Text Lang="it">Centro d'Aiuto Articy</Text>
			<Text Lang="ru">Центр Помощи Articy</Text>
			<Text Lang="ja">Nevigoヘルプセンター</Text>
			<Text Lang="de">Articy Help Center</Text>
		</TextDefinition>

		<TextDefinition Key="CantOpenHelp.Text">
			<Context>Messagebox text that is shown when opening the online help fails</Context>
			<Text Lang="en">Unable to open the online help in your web browser.</Text>
			<Text Lang="uk">Не вдається відкрити онлайн-довідку у веб-переглядачі.</Text>
			<Text Lang="fr">Impossible d’ouvrir l’aide en ligne dans votre navigateur web.</Text>
			<Text Lang="pt-BR">Incapaz de abrir a ajuda onlina no seu navegador de web.</Text>
			<Text Lang="zh">无法在Web浏览器中打开在线帮助。</Text>
			<Text Lang="ko">웹 브라우저에서 온라인 도움말을 열 수 없습니다.</Text>
			<Text Lang="pl">Nie można było uruchomić przeglądarki internetowej.</Text>
			<Text Lang="es">No se puede iniciar tu navegador web.</Text>
			<Text Lang="it">Impossibile lanciare il tuo broswer web.</Text>
			<Text Lang="ru">Не удается запустить ваш веб-браузер.</Text>
			<Text Lang="ja">あなたのウェブブラウザーは開始できません。</Text>
			<Text Lang="de">Webbrowser mit Online-Hilfe konnte nicht gestartet werden.</Text>
		</TextDefinition>

		<TextDefinition Key="BubbleMenu.ToolTip.Default">
			<Context>ToolTip: The "Bubble" is the circle in the top left corner containing the Articy symbol. It contains the main menu.</Context>
			<Text Lang="en">Click here to open the bubble menu</Text>
			<Text Lang="uk">Натисніть тут для виклику кругового меню.</Text>
			<Text Lang="fr">Cliquez ici pour ouvrir le menu en bulle</Text>
			<Text Lang="pt-BR">Clique aqui para abir o menu bolha.</Text>
			<Text Lang="zh">单击此处打开气泡菜单</Text>
			<Text Lang="ko">버블 메뉴를 열려면 여기를 클릭하십시오.</Text>
			<Text Lang="pl">Kliknij dla menu bąbelkowego</Text>
			<Text Lang="es">Haz clic aquí para mostrar el menú</Text>
			<Text Lang="it">Clicca qui per il menu a bolla.</Text>
			<Text Lang="ru">Кликните здесь для вызова кругового меню.</Text>
			<Text Lang="de">Öffnet das Bubble-Menü</Text>
			<Text Lang="ja">バブルメニューを開けます</Text>
		</TextDefinition>

		<TextDefinition Key="EnterSingleUserKey.Description">
			<Context>Dialogbox 'Enter license key': Explanation what the user needs to do in this dialog.</Context>
			<Text Lang="de"><![CDATA[Bitte geben Sie den Single-User-Lizenzschlüssel ein, der Ihnen von Articy zugesandt wurde.
Dieser Schlüssel sieht in etwa aus wie 'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ' und beginnt stets mit einem 'A'.]]></Text>
			<Text Lang="uk"><![CDATA[Будь ласка, введіть articy:draft однокористувацький ліцензійний ключ, наданий Articy.
Цей ключ виглядає як 'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ і завжди починається з 'A '. ]]></Text>
			<Text Lang="fr"><![CDATA[Veuillez saisir la clé de licence d’utilisateur unique articy:draft fournie par Articy.
Cette clé ressemble à « AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ » et commence toujours par « A ».]]></Text>
			<Text Lang="pt-BR"><![CDATA[Por favor entre a licença de chave de uso único em articy:draft que foi provicenciada por Articy.
Essa chave parece com 'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ' e sempre começa com 'A'.]]></Text>
			<Text Lang="zh"><![CDATA[请输入Articy提供的articy:draft个人用户许可证密钥。
该密钥格式类似'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ'并总是以字母'A'开头。]]></Text>
			<Text Lang="ko">Nevigo에서 제공한 articy:draft 단일-사용자 라이선스 키를 입력하십시오. 이 키는 'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ' 처럼 나오며 항상 'A'로 시작합니다.</Text>
			<Text Lang="pl">Proszę wprowadzić licencję articity:draft dla jednego użytkownika udostępnioną przez Articy. Klucz powinien wyglądać jak 'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ' i zawsze zaczynać się na 'A'.</Text>
			<Text Lang="es"><![CDATA[Por favor introduce la clave de licencia de usuario único de articy:draft proporcionada por Articy.
Esta clave tiene la estructura 'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ' y siempre empieza por 'A'.]]></Text>
			<Text Lang="it"><![CDATA[Per favore inserisci la tua licenza di articy:draft di utente singolo che ti è stata fornita da Articy.
Questo è un esempio 'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ' e una licenza inizia sempre con una 'A'.]]></Text>
			<Text Lang="ru"><![CDATA[Пожалуйста, введите articy:draft однопользовательский лицензионный ключ, предоставленный Articy.
Этот ключ выглядит как 'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ и всегда начинается с ' A '. ]]></Text>
			<Text Lang="en"><![CDATA[Please enter the articy:draft single-user license key that was provided by Articy.
This key looks like 'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ' and always starts with an 'A'.]]></Text>
			<Text Lang="ja"><![CDATA[Nevigoから送信されたarticy:draftシングルユーザーライセンスキーナンバーを入力してください。
このキーナンバーは'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ'の様に、常に'A'で始まります。]]></Text>
		</TextDefinition>

		<TextDefinition Key="EnterSingleUserKeyFile.Description">
			<Context>Dialogbox 'Enter license key': Explanation what the user needs to do in this dialog.</Context>
			<Text Lang="de"><![CDATA[Bitte wählen Sie die Single-User-Lizenzschlüsseldatei aus, die Ihnen von Articy zugesandt wurde.
Der Dateiname sieht in etwa aus wie 'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ.nlic' und beginnt stets mit einem 'A'.]]></Text>
			<Text Lang="uk"><![CDATA[Будь ласка, введіть articy:draft однокористувацький ліцензійний ключ, наданий Articy.
Цей ключ виглядає як 'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ і завжди починається з 'A '. ]]></Text>
			<Text Lang="fr"><![CDATA[Veuillez sélectionner le fichier de licence d’utilisateur unique articy:draft fourni par Articy.
Ce fichier ressemble à « AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ.nlic » et commence toujours par « A ».]]></Text>
			<Text Lang="pt-BR"><![CDATA[Por favor selecione a licença de chave de uso único em articy:draft que foi provicenciada por Articy.
Essa chave parece com 'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ' e sempre começa com 'A'.]]></Text>
			<Text Lang="zh"><![CDATA[请选择由Articy提供的articy:draft 个人用户许可文件。
许可文件名称类似'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ.nlic'并总是以字母'A'开头。]]></Text>
			<Text Lang="ko"><![CDATA[Nevigo에서 제공한 articy:draft 단일 사용자 라이선스 파일을 선택하십시오.
이 키는 'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ' 처럼 나오며 항상 'A'로 시작합니다.]]></Text>
			<Text Lang="pl">Proszę wybrać licencję articity:draft dla jednego użytkownika udostępnioną przez Articy. Klucz powinien wyglądać jak 'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ.nlic' i zawsze zaczynać się na 'A'.</Text>
			<Text Lang="it"><![CDATA[Per favore inserisci la tua licenza di articy:draft di utente singolo che ti è stata fornita da Articy.
Il formato è del tipo 'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ' e inizia sempre con una 'A'.]]></Text>
			<Text Lang="en"><![CDATA[Please select the articy:draft single-user license file that was provided by Articy.
This file looks like 'AEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ.nlic' and always starts with an 'A'.]]></Text>
		</TextDefinition>

		<TextDefinition Key="EnterSingleUserKeyFile.Title">
			<Context>Dialogbox 'Enter license key': Explanation what the user needs to do in this dialog.</Context>
			<Text Lang="de">Bitte wählen sie die Single-User-Lizenzschlüsseldatei aus.</Text>
			<Text Lang="uk">Будь ласка, введіть articy: draft однокористувацький ліцензійний ключ,</Text>
			<Text Lang="fr">Veuillez sélectionner le fichier de clé de licence d’utilisateur unique articy:draft</Text>
			<Text Lang="pt-BR">Por favor selecione a licença de chave de uso único em articy:draft.</Text>
			<Text Lang="zh">请选择 articy:draft 个人用户许可证密钥文件。</Text>
			<Text Lang="ko">articy:draft 단일-사용자 라이선스 키 파일을 선택하십시오.</Text>
			<Text Lang="pl">Proszę wybrać plik klucza licencyjnego dla licencji dla pojedyńczego użytkownika articity:draft.</Text>
			<Text Lang="it">Per favore seleziona la tua licenza di articy:draft di utente singolo.</Text>
			<Text Lang="en">Please select the articy:draft single-user license key file.</Text>
		</TextDefinition>

		<TextDefinition Key="EnterSingleUserKeyFile.Filter">
			<Context>Dialogbox 'Enter license key': Explanation what the user needs to do in this dialog.</Context>
			<Text Lang="de">Articy Single-User Lizenz Datei|A*.nlic</Text>
			<Text Lang="uk">Articy Однокористувацький ліцензійний файл|A*.nlic</Text>
			<Text Lang="fr">Fichier de licence d’utilisateur unique Articy|A*.nlic</Text>
			<Text Lang="pt-BR">Arquivo de licença Articy de uso-único| A* .nlic</Text>
			<Text Lang="zh">Articy个人用户许可文件|A*.nlic</Text>
			<Text Lang="ko">Articy 단일-사용자 라이선스 파일|A*.nlic</Text>
			<Text Lang="pl">Licencja Articy dla pojedynczego użytkownika|A*.nlic</Text>
			<Text Lang="it">Articy licenza utente singolo file|A*.nlic</Text>
			<Text Lang="en">Articy Single-User license file|A*.nlic</Text>
		</TextDefinition>

		<TextDefinition Key="EnterSingleUserKeySteam.Description">
			<Context>Dialogbox 'Enter license key': Explanation what the user needs to do in this dialog for steam keys.</Context>
			<Text Lang="de"><![CDATA[Bitte geben Sie den CD-Key ein, der Ihnen von Steam beim Start von articy:draft angezeigt wurde.
Sie können diesen Key auch über die Windows-Zwischenablage einfügen (Strg+V).
Dieser Schlüssel sieht in etwa aus wie 'CEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ' und beginnt stets mit einem 'C'.]]></Text>
			<Text Lang="uk"><![CDATA[Будь ласка, введіть або скопіюйте CD ключ, показаний при завантаженні articy:draft в клієнті Steam.
Можливо ви захочете скопіювати цей ключ використовуючи буфер обміну Windows (Ctrl+V).
Цей ключ виглядає як 'CEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ і завжди починається з 'C '.]]></Text>
			<Text Lang="fr"><![CDATA[Veuillez saisir ou coller la clé CD affichée dans le client Steam lors du démarrage de articy:draft.
Vous pouvez insérer cette clé en utilisant le presse-papiers Windows (Ctrl+V).
Cette clé ressemble à « CEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ » et commence toujours par « C ».]]></Text>
			<Text Lang="pt-BR"><![CDATA[Por favor entre ou cole a chave CD que foi mostrada no cliente Steam quando iniciando articy:draft.
Você pode inserir essa chave usando o Windows Clipboard (Ctrl + V).
Essa chave parece com 'CEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ' e sempre começa com 'C'.]]></Text>
			<Text Lang="zh"><![CDATA[请输入或粘贴在Steam客户端中启动 articy:draft 时显示的CD key。
您可以使用Windows剪贴板 (Ctrl+V)输入此CD key。
此key格式类似'CEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ'且始终以 'C'开头。]]></Text>
			<Text Lang="ko"><![CDATA[스팀 클라이언트에서 articy:draft를 실행 할 때 표시되는 CD 키를 붙여넣거나 입력하여주십시오.
윈도우 클립보드 (Ctrl+V)를 이용하여 이 키 삽입할 수 있습니다.
이 키는  'CEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ' 처럼 나오며 항상 'C'로 시작합니다.]]></Text>
			<Text Lang="pl">Proszę wpisać lub wkleić CD-key pokazany w aplikacji Steam podczas startu programu articity:draft. Może użyć kombinacji kalwiszy Ctrl+C. Klucz powinien wyglądać jak 'CEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ' i zaczynać się literą 'C'.</Text>
			<Text Lang="es"><![CDATA[Escribe o pega la clave del CD que se muestra en el cliente de Steam al mirar articy:draft.
Es posible que quieras introducir esta clave usando el portapapeles (Ctrl + V).
Esta clave tiene la estructura 'CEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ' y siempre empieza por 'C'.]]></Text>
			<Text Lang="it"><![CDATA[Per favore inserisci o incolla la tua CD key che è visualizzata nel client di Steam quando avvii articy:draft.
Puoi inserire la licenza usando gli appunti di Windows (Ctrl+V).
Questa è un esempio 'CEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ' e una licenza inizia sempre con una 'C'.]]></Text>
			<Text Lang="ru"><![CDATA[Пожалуйста, введите или скопируйте  CD ключ, показанный при загрузке articy:draft в клиенте Steam.
Возможно вы захотите скопировать этот ключ используя буфер обмена Windows (Ctrl + V).
Этот ключ выглядит как 'CEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ и всегда начинается с 'C '. ]]></Text>
			<Text Lang="en"><![CDATA[Please enter or paste the CD key that was shown in the Steam client when starting articy:draft.
You can insert this key by using the Windows clipboard (Ctrl+V).
This key looks like 'CEDL9-F2D9M-WLUCF-Q8DWG-B2VKJ' and always starts with an 'C'.]]></Text>
		</TextDefinition>

	</Category>

	<!--
	  Welcome screen / General
	-->
	<Category Name="Ui" Namespace=".Aspects.Welcome">

		<TextDefinition Key="Logo.WelcomeTo.DisplayName">
			<Context>"Welcome to" part of the articy:draft logo</Context>
			<Text Lang="en">Welcome to</Text>
			<Text Lang="uk">Ласкаво просимо в</Text>
			<Text Lang="fr">Bienvenue sur</Text>
			<Text Lang="pt-BR">Bem vindo á</Text>
			<Text Lang="zh">欢迎使用</Text>
			<Text Lang="ko">Welcome to</Text>
			<Text Lang="pl">Witamy w</Text>
			<Text Lang="de">Willkommen zu</Text>
			<Text Lang="ru">Добро пожаловать в</Text>
			<Text Lang="it">Benvenuti a</Text>
			<Text Lang="ja">へようこそ</Text>
		</TextDefinition>

		<TextDefinition Key="Logo.By.DisplayName">
			<Context>"by" part of the articy:draft logo</Context>
			<Text Lang="en">by</Text>
			<Text Lang="uk">завдяки</Text>
			<Text Lang="fr">par</Text>
			<Text Lang="pt-BR">por</Text>
			<Text Lang="zh">by</Text>
			<Text Lang="ko">by</Text>
			<Text Lang="pl">przez</Text>
			<Text Lang="de">von</Text>
			<Text Lang="ru">по</Text>
			<Text Lang="it">da</Text>
			<Text Lang="ja">で</Text>
		</TextDefinition>

		<TextDefinition Key="Welcome.Name">
			<Context>name of the welcome aspect</Context>
			<Text Lang="en">Welcome</Text>
			<Text Lang="uk">Ласкаво просимо</Text>
			<Text Lang="fr">Bienvenue</Text>
			<Text Lang="pt-BR">Bem vindo</Text>
			<Text Lang="zh">欢迎！</Text>
			<Text Lang="ko">Welcome</Text>
			<Text Lang="pl">Witam</Text>
			<Text Lang="es">¡Te damos la bienvenida!</Text>
			<Text Lang="it">Benvenuto</Text>
			<Text Lang="ru">Добро пожаловать</Text>
			<Text Lang="de">Willkommen</Text>
			<Text Lang="ja">ようこそ</Text>
		</TextDefinition>

	</Category>

	<!--
	  Welcome screen / queries
	-->
	<Category Name="Ui" Namespace=".Aspects.Welcome.Queries">

		<TextDefinition Key="DeleteProject.Title">
			<Context>Dialogbox 'Deleting project': Dialogbox title. Only single-user projects can be deleted.</Context>
			<Text Lang="en">Delete project</Text>
			<Text Lang="uk">Видалення проекту</Text>
			<Text Lang="fr">Supprimer le projet</Text>
			<Text Lang="pt-BR">Deletar projeto</Text>
			<Text Lang="zh">删除项目</Text>
			<Text Lang="ko">프로젝트 삭제</Text>
			<Text Lang="pl">Usuwanie projektu</Text>
			<Text Lang="es">Eliminando proyecto</Text>
			<Text Lang="it">Cancellare progetto</Text>
			<Text Lang="ru">Удаление проекта</Text>
			<Text Lang="de">Projekt löschen</Text>
			<Text Lang="ja">プロジェクト削除</Text>
		</TextDefinition>

		<TextDefinition Key="DeleteProject.Description">
			<Context>Dialogbox 'Deleting project': User is asked for confirmation to delete.</Context>
			<Text Lang="en">Do you really want to completely delete the selected project?</Text>
			<Text Lang="uk">Ви дійсно бажаєете повністю видалити обраний проект?</Text>
			<Text Lang="fr">Voulez-vous vraiment supprimer totalement le projet sélectionné ?</Text>
			<Text Lang="pt-BR">Você realmente deseja deletar completamente o projeto selecionado?</Text>
			<Text Lang="zh">您真的想要完全删除所选项目吗？</Text>
			<Text Lang="ko">정말로 선택된 프로젝트를 완전히 삭제하시겠습니까?</Text>
			<Text Lang="pl">Jesteś pewien że chcesz kompletnie usunąć wybrany projekt?</Text>
			<Text Lang="es">¿Seguro que quieres eliminar por completo el proyecto seleccionado?</Text>
			<Text Lang="it">Sei sicuro di voler cancellare completamente la cartella di progetto selezionata?</Text>
			<Text Lang="ru">Вы действительно хотите полностью удалить выбранный проект?</Text>
			<Text Lang="de">Wollen Sie das Projekt wirklich vollständig löschen?</Text>
			<Text Lang="ja">このプロジェクトを本当に削除しますか？</Text>
		</TextDefinition>

		<TextDefinition Key="RemoveWorkingCopy.Title">
			<Context>Dialogbox 'Removing project folder': Dialogbox title. Only for multi-user projects a working copy can be removed.</Context>
			<Text Lang="en">Delete project folder</Text>
			<Text Lang="uk">Видалення папки проекту</Text>
			<Text Lang="fr">Supprimer le dossier du projet</Text>
			<Text Lang="pt-BR">Deletar pasta de projeto</Text>
			<Text Lang="zh">删除项目文件夹</Text>
			<Text Lang="ko">프로젝트 폴더 삭제</Text>
			<Text Lang="pl">Usuwanie folderu projektu</Text>
			<Text Lang="es">Eliminando carpeta del proyecto</Text>
			<Text Lang="it">Cancellare la cartella del progetto</Text>
			<Text Lang="ru">Удаление папки проекта</Text>
			<Text Lang="de">Projektordner löschen</Text>
			<Text Lang="ja">ローカルフォルダーを削除</Text>
		</TextDefinition>

		<TextDefinition Key="RemoveWorkingCopy.Description">
			<Context>Dialogbox 'Removing project folder': User is asked for confirmation to remove.</Context>
			<Text Lang="en"><![CDATA[You are about to delete the local project folder. Unpublished changes will be lost in the process!
			
Do you really want to remove the selected project's folder?]]></Text>
			<Text Lang="uk"><![CDATA[Ви збираєтеся видалити локальну папку проекту. В процесі втратяться неопубліковані зміни!

Ви дійсно хочете видалити папку  обраного проекту?]]></Text>
			<Text Lang="fr"><![CDATA[Vous allez supprimer le dossier local du projet. Les modifications non publiées seront perdues !
   
Voulez-vous vraiment supprimer le dossier du projet sélectionné ?]]></Text>
			<Text Lang="pt-BR"><![CDATA[Você está prestes a deletar a pasta de projetos local. Páginas não-publicadas serão perdidas no processo!

Você realmente deseja removar a pasta de projeto selecionada?

]]></Text>
			<Text Lang="zh"><![CDATA[您即将删除本地项目文件夹。未上传的更改将在此过程中丢失！
			
您真的想删除所选的项目文件夹吗？]]></Text>
			<Text Lang="ko"><![CDATA[로컬 프로젝트 폴더를 삭제합니다. 게시되지 않은 변경 사항은 손실됩니다!

정말로 선택한 프로젝트의 폴더를 제거하시겠습니까?]]></Text>
			<Text Lang="pl"><![CDATA[Usuwasz właśnie folder projektu. Nieopublikowane zmiany zostaną utracone w tym procesie!

Jesteś pewien że chcesz usunąć folder projektu?]]></Text>
			<Text Lang="es"><![CDATA[Estás a punto de eliminar la carpeta local del proyecto. ¡Los cambios no publicados se perderán en el proceso!
			
¿Seguro que quieres eliminar por completo la carpeta del proyecto seleccionado?]]></Text>
			<Text Lang="it"><![CDATA[Stai per cancellare la cartella locale del progetto. I cambiamenti non pubblicati andranno persi durante il processo. 

Sei sicuro di voler rimuovere la cartella del progetto selezionato?]]></Text>
			<Text Lang="ru"><![CDATA[Вы собираетесь удалить локальную папку проекта. В процессе будут потеряны неопубликованные изменения!

Вы действительно хотите удалить папку проекта выбранного проекта? ]]></Text>
			<Text Lang="de"><![CDATA[Sie sind dabei, den lokalen Projektordner zu löschen. Änderungen die noch nicht publiziert wurden gehen dabei verloren!
			
Wollen sie den Projektordner wirklich vollständig löschen?]]></Text>
			<Text Lang="ja">このプロジェクトのローカルフォルダーを本当に削除しますか？</Text>
		</TextDefinition>

	</Category>

	<!--
	  Welcome screen / server page
	-->
	<Category Name="Ui" Namespace=".Aspects.Welcome.Pages.Server">

		<TextDefinition Key="Page.Caption">
			<Context>name of the welcome page header for the server</Context>
			<Text Lang="en">Server</Text>
			<Text Lang="uk">Сервер</Text>
			<Text Lang="fr">Serveur</Text>
			<Text Lang="pt-BR">Servidor</Text>
			<Text Lang="zh">服务器</Text>
			<Text Lang="ko">서버</Text>
			<Text Lang="pl">Serwer</Text>
			<Text Lang="es">Servidor</Text>
			<Text Lang="it">Server</Text>
			<Text Lang="ru">Сервер</Text>
			<Text Lang="de">Server</Text>
			<Text Lang="ja">サーバー</Text>
		</TextDefinition>

		<TextDefinition Key="Host.Name">
			<Context>Label: Text for the label of the host address field</Context>
			<Text Lang="en">Host address:</Text>
			<Text Lang="uk">Адреса хоста:</Text>
			<Text Lang="fr">Adresse hôte :</Text>
			<Text Lang="pt-BR">Endereço do Host:</Text>
			<Text Lang="zh">主机地址：</Text>
			<Text Lang="ko">호스트 주소:</Text>
			<Text Lang="pl">Adres hosta:</Text>
			<Text Lang="es">Dirección del host:</Text>
			<Text Lang="it">Indirizzo dell'Host:</Text>
			<Text Lang="ru">Адрес сервера:</Text>
			<Text Lang="de">Host-Adresse:</Text>
			<Text Lang="ja">ホストアドレス：</Text>
		</TextDefinition>

		<TextDefinition Key="Host.Description">
			<Context>Tooltip for the label and textbox of the host address field</Context>
			<Text Lang="en">This is the URL of the articy:server (e.g. "192.168.100.250" or "articy.mycompany.com").</Text>
			<Text Lang="uk">Це URL-адреса articy:servcer (наприклад, «192.168.100.250» або «articy.mycompany.comі)».</Text>
			<Text Lang="fr">Ceci est l’URL du articy:server (par ex. « 192.168.100.250 » ou « articy.mycompany.com »).</Text>
			<Text Lang="pt-BR">Esse é o URL do articy:server (e.g. "192.168.100.250" ou "articy.mycompany.com").</Text>
			<Text Lang="zh">这是 articy:server 的URL（例如 "192.168.100.250" 或 "articy.mycompany.com"）。</Text>
			<Text Lang="ko">이는 articy:server의 URL입니다 (예: "192.168.100.250" or "articy.mycompany.com").</Text>
			<Text Lang="pl">To jest adres URL serwera asrticity:server w twojej firmie (np. '192.168.100.250' lub 'articity.mycompany.com').</Text>
			<Text Lang="es">Esta es la URL del servidor de articy:server para tu empresa (por ejemplo "192.168.100.250" o "articy.miempresa.com").</Text>
			<Text Lang="it">Questo è l' URL dell' articy:server della tua compagnia (ad esempio "192.168.100.250" o "articy.mycompany.com").</Text>
			<Text Lang="ru">Это адрес articy:server вашей компании (например, "192.168.100.250" или "articy.mycompany.com»).</Text>
			<Text Lang="de">Das ist die URL des articy:servers  (zum Beispiel "192.168.100.250" oder "articy.meinefirma.de").</Text>
			<Text Lang="ja">これはarticy:serverのURLです。（例えば、192.168.100.250 やarticy.watashinokaisha.co.jpなどです。）</Text>
		</TextDefinition>

		<TextDefinition Key="Port.Description">
			<Context>Tooltip for the textbox of the port field</Context>
			<Text Lang="en">This is the port through which the articy:server can be reached. Default port is '16707'.</Text>
			<Text Lang="uk">Це порт, через який можна отримати сервер articy:server. Порт за замовчуванням -  '16707'.</Text>
			<Text Lang="fr">Ceci est le port par lequel le articy:server peut être joint. Le port par défaut est « 16707 ».</Text>
			<Text Lang="pt-BR"><![CDATA[Esse é o porto pelo qual o articy:server pode ser alcançado.
Porto padrão é '16707'.]]></Text>
			<Text Lang="zh">这是可通过 articy:server 访问的端口。默认端口为 '16707'。</Text>
			<Text Lang="ko">이는 articy:server에 도달할 수 있는 포트 입니다.</Text>
			<Text Lang="pl">To jest port gdzie articity:server w twojej firmie może być znaleziony. Domyślny port to '16707'.</Text>
			<Text Lang="es">Este es el puerto en el que puedes encontrar el servidor articy:server de tu empresa. El puerto por defecto es '16707'.</Text>
			<Text Lang="it"><![CDATA[Questa è la porta alla quale si trova l'articy:server della tua compagnia. 
La porta di default è '16707'.]]></Text>
			<Text Lang="ru">Это порт, по которому можно найти articy:server вашей компании. Порт по умолчанию '16707 '.</Text>
			<Text Lang="de">Das ist der Port unter welchem articy:server erreichbar ist. Der Standardport ist '16707'.</Text>
			<Text Lang="ja">これはarticy:serverのポートです。標準ポートは16707です。</Text>
		</TextDefinition>

		<TextDefinition Key="Autologin.Name">
			<Context>text for the option to auto login into the server when starting the application</Context>
			<Text Lang="en">Login automatically</Text>
			<Text Lang="uk">Входити автоматично</Text>
			<Text Lang="fr">Connexion automatique</Text>
			<Text Lang="pt-BR">Logando automaticamente</Text>
			<Text Lang="zh">自动登录</Text>
			<Text Lang="ko">자동 로그인</Text>
			<Text Lang="pl">Zaloguj automatycznie</Text>
			<Text Lang="es">Iniciar sesión automáticamente</Text>
			<Text Lang="it">Login automatico</Text>
			<Text Lang="ru">Входить автоматически</Text>
			<Text Lang="de">Automatisch einloggen</Text>
			<Text Lang="ja">自動ログイン</Text>
		</TextDefinition>

		<TextDefinition Key="WorkLocally.Name">
			<Context>button text 'Single-user'</Context>
			<Text Lang="en">Single-user</Text>
			<Text Lang="uk">Однокористувацький</Text>
			<Text Lang="fr">Utilisateur unique</Text>
			<Text Lang="pt-BR">Usuário-Único</Text>
			<Text Lang="zh">个人用户</Text>
			<Text Lang="ko">단일-사용자</Text>
			<Text Lang="pl">Pojedynczy użytkownik</Text>
			<Text Lang="es">Usuario único</Text>
			<Text Lang="it">Utente Singolo</Text>
			<Text Lang="ru">Однопользовательский</Text>
			<Text Lang="de">Single-User</Text>
			<Text Lang="ja">シングルユーザー</Text>
		</TextDefinition>

		<TextDefinition Key="WorkLocally.ToolTip">
			<Context>tooltip for button "single-user"</Context>
			<Text Lang="en">Work with local single-user projects instead of connecting to an articy:server.</Text>
			<Text Lang="uk">Не підключатися до articy:server, а працювати з вашими однокористувацькими проектами.</Text>
			<Text Lang="fr">Travailler sur des projets d’utilisateur unique plutôt que se connecter à un articy:server.</Text>
			<Text Lang="pt-BR">Trabalhar com projetos de usuário-único em vez de conectar com o articy:Server.</Text>
			<Text Lang="zh">使用本地个人用户项目工作而不是连接至 articy:server。</Text>
			<Text Lang="ko">artics:server에 연결하는 대신 로컬 단일-사용자 프로젝트를 사용합니다.</Text>
			<Text Lang="pl">Nie łącz się z articy:sever, ale pracuj ze swoim projektem pojedynczego użytkownika.</Text>
			<Text Lang="es">No se conecta a un servidor de articy:server, sino que trabaja con tus proyectos de un solo usuario.</Text>
			<Text Lang="it">Non collegarti ad un articy:server e lavora con  i tuoi progetti da utente singolo.</Text>
			<Text Lang="ru">Не подключаться к articy:server, а  работать с вашими однопользовательскими проектами.</Text>
			<Text Lang="de">Nicht zu einem articy:server verbinden sondern mit lokalen Single-User-Projekten arbeiten.</Text>
			<Text Lang="ja">articy:serverへの接続をせずに、あなたのローカル作成プロジェクトを使ってください。</Text>
		</TextDefinition>

		<TextDefinition Key="Connect.Name">
			<Context>button text for 'connect' to an articy:server</Context>
			<Text Lang="en">Connect</Text>
			<Text Lang="uk">Підключитися</Text>
			<Text Lang="fr">Se connecter</Text>
			<Text Lang="pt-BR">Conectar</Text>
			<Text Lang="zh">连接</Text>
			<Text Lang="ko">연결</Text>
			<Text Lang="pl">Połącz</Text>
			<Text Lang="es">Conectarse</Text>
			<Text Lang="it">Collegare</Text>
			<Text Lang="ru">Подключиться</Text>
			<Text Lang="de">Verbinden</Text>
			<Text Lang="ja">接続</Text>
		</TextDefinition>

		<TextDefinition Key="Connect.Description">
			<Context>Tooltip for button 'connect' to an articy:server</Context>
			<Text Lang="en">Connects to the articy:server that was specified by 'host address' above and proceeds to the user page.</Text>
			<Text Lang="uk">Підключитися до articy:server, із заданою «адресою хоста» вище і перейти до користувацької сторінки.</Text>
			<Text Lang="fr">Se connecte à l’articy:server indiqué dans « adresse hôte » ci-dessus et se rend sur la page de l’utilisateur.</Text>
			<Text Lang="pt-BR">Conecta ao articy:server que foi especificado pelo 'endereço de Host' acime e procede para a página de usuário.</Text>
			<Text Lang="zh">连接到上述“服务器地址”指定的 articy:server ，并进入用户页面。</Text>
			<Text Lang="ko">위의 '호스트 주소'에 지정된 articy:server에 연결하고 사용자 페이지로 넘어갑니다.</Text>
			<Text Lang="pl">Łączy się z serwerem articity:server podanym w polu 'Adres hosta' powyżej i przenosi do strony użytkownika.</Text>
			<Text Lang="es">Se conecta al servidor de articy:server especificado por la 'dirección de host "y accede a la página del usuario.</Text>
			<Text Lang="it">Collegati all'articy:server che è stato specificato nel 'indirizzo server'  e raggiungi la pagina utente.</Text>
			<Text Lang="ru">Подключиться к articy:server, заданным  "адресом хоста" выше и перейти к пользовательской странице.</Text>
			<Text Lang="de">Baut die Verbindung zu dem oben unter 'Host-Adresse' angegebenen articy:server auf und leitet zur User-Seite weiter.</Text>
			<Text Lang="ja">上記のホストアドレスから与えられたarticy:serverに接続し、ユーザーページへ進んでください。</Text>
		</TextDefinition>

		<TextDefinition Key="Errors.HostUnknown.Description">
			<Context>Error text when the text field 'host name' is empty or invalid</Context>
			<Text Lang="en">Invalid host address!</Text>
			<Text Lang="uk">Неправильна адреса хоста!</Text>
			<Text Lang="fr">Adresse hôte invalide !</Text>
			<Text Lang="pt-BR">Indereço de Host inválido!</Text>
			<Text Lang="zh">无效的主机地址！</Text>
			<Text Lang="ko">호스트 주소가 잘못되었습니다!</Text>
			<Text Lang="pl">Nieprawidłowy adres hosta!</Text>
			<Text Lang="es">¡Dirección de host no válida!</Text>
			<Text Lang="it">L'indirizzo dell'host non è valido!</Text>
			<Text Lang="ru">Неверный адрес хоста!</Text>
			<Text Lang="de">Ungültige Host-Adresse!</Text>
			<Text Lang="ja">ホストアドレス無効！</Text>
		</TextDefinition>

		<TextDefinition Key="Errors.InvalidPort.Description">
			<Context>Error text when the 'port' text field contains an invalid port</Context>
			<Text Lang="en">Invalid port number!</Text>
			<Text Lang="uk">Неправильний номер порту!</Text>
			<Text Lang="fr">Numéro de port invalide !</Text>
			<Text Lang="pt-BR">Número de porto inválido!</Text>
			<Text Lang="zh">无效的端口号！</Text>
			<Text Lang="ko">잘못된 포트 번호입니다!</Text>
			<Text Lang="pl">Nieprawidłowy port!</Text>
			<Text Lang="es">¡Número de puerto no válido!</Text>
			<Text Lang="it">Numero di porta non valido!</Text>
			<Text Lang="ru">Неверный номер порта!</Text>
			<Text Lang="de">Ungültige Port-Nummer!</Text>
			<Text Lang="ja">ポートナンバー無効！</Text>
		</TextDefinition>

		<TextDefinition Key="Errors.EmptyPort.Description">
			<Context>Error text when the 'port' text field is empty</Context>
			<Text Lang="en">Port number is missing!</Text>
			<Text Lang="uk">Номер порту відсутній!</Text>
			<Text Lang="fr">Numéro de port absent !</Text>
			<Text Lang="pt-BR">Número de porte está faltando!</Text>
			<Text Lang="zh">缺少端口号！</Text>
			<Text Lang="ko">포트 번호가 누락되었습니다!</Text>
			<Text Lang="pl">Nie podano portu!</Text>
			<Text Lang="es">¡No has especificado el número de puerto!</Text>
			<Text Lang="it">Manca il numero di porta!</Text>
			<Text Lang="ru">Отсутствует номер порта!</Text>
			<Text Lang="de">Port-Nummer fehlt!</Text>
			<Text Lang="ja">ポートナンバーがありません！</Text>
		</TextDefinition>

		<TextDefinition Key="Errors.WellknownPort.Description">
			<Context>Error text when the text field 'port' contains one of the well known ports (below 1023) which we forbid</Context>
			<Text Lang="en">Reserved port number!</Text>
			<Text Lang="uk">Номер порту зарезервований!</Text>
			<Text Lang="fr">Numéro de port réservé !</Text>
			<Text Lang="pt-BR">Número de porto reservado!</Text>
			<Text Lang="zh">已占用端口号！</Text>
			<Text Lang="ko">예약된 포트 번호!</Text>
			<Text Lang="pl">Ten port jest zarezerwowany!</Text>
			<Text Lang="es">¡Número de puerto reservado!</Text>
			<Text Lang="it">Numero di porta riservato!</Text>
			<Text Lang="ru">Номер порта зарезервирован!</Text>
			<Text Lang="de">Reservierte Port-Nummer!</Text>
			<Text Lang="ja">ポートナンバー保留！</Text>
		</TextDefinition>

		<TextDefinition Key="Host.DropDownEntry">
			<Context>Text template for the entries in the dropdown list that remembers the recently used host/port pairs. 0=host address, 1=port number.</Context>
			<Text Lang="en">{0} (Port: {1})</Text>
			<Text Lang="uk">{0} (Port: {1})</Text>
			<Text Lang="fr">{0} (Port : {1})</Text>
			<Text Lang="pt-BR">{0} (Porto: {1})</Text>
			<Text Lang="zh">{0} (Port: {1})</Text>
			<Text Lang="ko">{0} (포트: {1})</Text>
			<Text Lang="pl">{0} (Port:{1})</Text>
			<Text Lang="es">{0} (Puerto: {1})</Text>
			<Text Lang="it">{0} (Porta: {1})</Text>
			<Text Lang="ru">{0} (Port: {1})</Text>
			<Text Lang="de">{0} (Port: {1})</Text>
			<Text Lang="ja">{0} (ポート: {1})</Text>
		</TextDefinition>

		<TextDefinition Key="Host.RemoveEntryToolTip">
			<Context>ToolTip text for the button that removes an entry from the recent host/port dropdown list.</Context>
			<Text Lang="en">Remove server entry from list.</Text>
			<Text Lang="uk">Видалити запис серверу зі списку</Text>
			<Text Lang="fr">Supprimer l’entrée du serveur de la liste.</Text>
			<Text Lang="pt-BR">Remover entrada de servidor da lista.</Text>
			<Text Lang="zh">从列表中删除服务器条目。</Text>
			<Text Lang="ko">목록에서 서버 항목을 제거하십시오.</Text>
			<Text Lang="pl">Usuń serwer z listy</Text>
			<Text Lang="es">Eliminar de la lista la entrada del servidor.</Text>
			<Text Lang="it">Rimuovi il server dalla lista.</Text>
			<Text Lang="ru">Удалить запись сервера из списка.</Text>
			<Text Lang="de">Server-Eintrag aus Liste entfernen.</Text>
			<Text Lang="ja">サーバー登録をリストから消去してください。</Text>
		</TextDefinition>

	</Category>

