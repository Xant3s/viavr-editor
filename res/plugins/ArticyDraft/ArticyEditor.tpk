		<TextDefinition Key="Replace.Description">
			<Context>tooltip for a button in the search-replace-dialog</Context>
			<Text Lang="en">Searches the next hit and replaces it with the given word.</Text>
			<Text Lang="uk">Пошук наступного співпадіння та його заміна заданим словом.</Text>
			<Text Lang="fr">Recherche le prochain mot ressemblant et le remplace par le mot donné.</Text>
			<Text Lang="pt-BR">Procura pelo próximo êxito e o substitui com a palavra dada.</Text>
			<Text Lang="zh">查找下一个匹配项并使用给定词替换它。</Text>
			<Text Lang="ko">다음 검색어를 검색하여 주어진 단어로 바꿉니다.</Text>
			<Text Lang="pl">Wyszukuje kolejne wystąpienie i zastępuje je podanym słowem.</Text>
			<Text Lang="es">Busca la nueva coincidencia y la reemplaza con la palabra escogida.</Text>
			<Text Lang="it">Cerca la prossima corrispondenza e sostituiscila con la parola data.</Text>
			<Text Lang="ru">Поиск следующего совпадения и замена его заданным словом.</Text>
			<Text Lang="de">Sucht nach dem nächsten Treffer und ersetzt ihn mit dem angegebenen Wort.</Text>
		</TextDefinition>

		<TextDefinition Key="ReplaceAll.Caption">
			<Context>text for a button in the search-replace-dialog</Context>
			<Text Lang="en">Replace all</Text>
			<Text Lang="uk">Замінити все</Text>
			<Text Lang="fr">Tout remplacer</Text>
			<Text Lang="pt-BR">Substituir todos</Text>
			<Text Lang="zh">全部替换</Text>
			<Text Lang="ko">모두 모두 바꾸기</Text>
			<Text Lang="pl">Wymień wszystkie</Text>
			<Text Lang="es">Reemplazar todas</Text>
			<Text Lang="it">Sostituisci tutto</Text>
			<Text Lang="ru">Заменить все</Text>
			<Text Lang="de">Alle ersetzen</Text>
		</TextDefinition>

		<TextDefinition Key="ReplaceAll.Description">
			<Context>tooltip for a button in the search-replace-dialog</Context>
			<Text Lang="en">Replaces all occurrences with the given word.</Text>
			<Text Lang="uk">Замінити всі співпадіння заданим словом.</Text>
			<Text Lang="fr">Remplace toutes les occurrences par le mot donné.</Text>
			<Text Lang="pt-BR">Substituir todas as ocorrências com a palavra dada.</Text>
			<Text Lang="zh">用给定的词替换所有出现的匹配项。</Text>
			<Text Lang="ko">관련된 모든 문자를 주어진 단어로 교체합니다.</Text>
			<Text Lang="pl">Zamienia wszystkie wystąpienia podanym słowem.</Text>
			<Text Lang="es">Reemplaza todas las ocurrencias con la palabra seleccionada</Text>
			<Text Lang="it">Sostituisci tutte le occorrenze con la parola data.</Text>
			<Text Lang="ru">Заменяет все совпадения заданным словом.</Text>
			<Text Lang="de">Ersetzt alle Treffer mit dem angegebenen Wort.</Text>
		</TextDefinition>

		<TextDefinition Key="ReplacedMessage.Count">
			<Context>text for a messagebox used by the search-replace-dialog</Context>
			<Text Lang="en">{0} occurrences have been replaced.</Text>
			<Text Lang="uk">{0} замінено співпадінь.</Text>
			<Text Lang="fr">{0} occurrences ont été remplacées.</Text>
			<Text Lang="pt-BR"><![CDATA[{0} ocorrências foram substituidas. 
]]></Text>
			<Text Lang="zh">{0} 个匹配项已被替换。</Text>
			<Text Lang="ko">{0}개 항목이 바뀌었습니다.</Text>
			<Text Lang="pl">{0} wystąpień zostało zastąpionych.</Text>
			<Text Lang="es">Se han efectuado {0} reemplazos.</Text>
			<Text Lang="it">{0} occorrenze sono state sostituite.</Text>
			<Text Lang="ru">{0} совпадений было заменено.</Text>
			<Text Lang="de">{0} Treffer wurden ersetzt.</Text>
		</TextDefinition>

		<TextDefinition Key="ReplacedButClaimedMessage.Count">
			<Context>text for a messagebox used by the search-replace-dialog</Context>
			<Text Lang="en">{0} occurrences have been replaced. {1} occurences could not be replaced.</Text>
			<Text Lang="uk"><![CDATA[{0} замінено співпадінь.
{0} співпадніь  не вдалось замінити.]]></Text>
			<Text Lang="fr">{0} occurrences ont été remplacées. {1} occurrences n'ont pas pu être remplacées.</Text>
			<Text Lang="pt-BR"><![CDATA[{0} ocorrências foram substituidas. 
{1} ocorrências não puderam ser substituidas.]]></Text>
			<Text Lang="zh">{0} 事件已被替换。{1} 事件无法替换。</Text>
			<Text Lang="ko">{0}개 항목이 바뀌었습니다. {1}개의 항목을 바꾸지 못했습니다.</Text>
			<Text Lang="pl">{0} wystąpień zostało zastąpionych. {1} wystąpień nie mogło zostało zastąpionych.</Text>
			<Text Lang="es">Se han efectuado {0} reemplazos. No se ha(n) podido reemplazar {1} ocurrencia(s)</Text>
			<Text Lang="it">{0} occorrenze sono state sostituite. {1} occorrenze impossibili da sostituire.</Text>
			<Text Lang="ru"><![CDATA[{0} совпадений было заменено.
{1} совпадений не удалось заменить.]]></Text>
			<Text Lang="de">{0} Treffer wurden ersetzt. {1} Treffer konnten nicht ersetzt werden.</Text>
		</TextDefinition>

		<TextDefinition Key="SearchReachedStart.Caption">
			<Context>title for a messagebox used by the search-replace-dialog</Context>
			<Text Lang="en">Search</Text>
			<Text Lang="uk">Пошук</Text>
			<Text Lang="fr">Recherche</Text>
			<Text Lang="pt-BR">Procurar</Text>
			<Text Lang="zh">查找</Text>
			<Text Lang="ko">찾기</Text>
			<Text Lang="pl">Szukaj</Text>
			<Text Lang="es">Buscar</Text>
			<Text Lang="it">Cerca</Text>
			<Text Lang="ru">Поиск</Text>
			<Text Lang="de">Suche</Text>
		</TextDefinition>

		<TextDefinition Key="SearchReachedStart.Info">
			<Context>text for a messagebox used by the search-replace-dialog</Context>
			<Text Lang="en">The search has reached its start.</Text>
			<Text Lang="uk">Пошук дійшов до початку.</Text>
			<Text Lang="fr">La recherche a ateint son début.</Text>
			<Text Lang="pt-BR">A procura alcançou seu início.</Text>
			<Text Lang="zh">该查找已到达开始时位置。</Text>
			<Text Lang="ko">문서를 끝까지 찾았습니다.</Text>
			<Text Lang="pl">Wyszukiwanie osiągnęło początek.</Text>
			<Text Lang="es">Se ha iniciado la búsqueda.</Text>
