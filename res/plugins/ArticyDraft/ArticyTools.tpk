<?xml version='1.0' encoding='utf-8' standalone='yes' ?>
<TextPackage BaseNamespace="Articy" GenerateIds="True" xml:space="preserve" xmlns="http://nevigo.com/TextPackage.xsd">

	<Category Name="System">

		<TextDefinition Key="Tools.CommercialUseDenied">
			<Context>Text shown when commercial use is denied</Context>
			<Text Lang="en">(non-commercial use only)</Text>
			<Text Lang="uk">(лише для некомерційного використання)</Text>
			<Text Lang="fr">(usage non commercial seulement)</Text>
			<Text Lang="pt-BR">(Apenas para usos não-comerciais)</Text>
			<Text Lang="zh">（仅限非商业用途）</Text>
			<Text Lang="ko">(비-상업적 용도만 사용)</Text>
			<Text Lang="pl">(tylko dla niekomercyjnego użytku)</Text>
			<Text Lang="es">(solo para uso no comercial)</Text>
			<Text Lang="it">(ad uso esclusivamente non commerciale)</Text>
			<Text Lang="ru">(только для не коммерческого использования)</Text>
			<Text Lang="de">(nur für nicht-kommerzielle Verwendung)</Text>
		</TextDefinition>

		<TextDefinition Key="Tools.LicenseStatus.Unlicensed">
			<Context>no license has been found</Context>
			<Text Lang="en">No license</Text>
			<Text Lang="uk">Немає ліцензії</Text>
			<Text Lang="fr">Aucune licence</Text>
			<Text Lang="pt-BR">Sem licença</Text>
			<Text Lang="zh">无许可证</Text>
			<Text Lang="ko">라이선스 없음</Text>
			<Text Lang="pl">Brak licencji</Text>
			<Text Lang="es">Sin licencia</Text>
			<Text Lang="it">Nessuna licenza</Text>
			<Text Lang="ru">Нет лицензии</Text>
			<Text Lang="de">Unlizensiert</Text>
		</TextDefinition>

		<TextDefinition Key="Tools.LicenseStatus.Prefix_A">
			<Context>Prefix for license info (single-user)</Context>
