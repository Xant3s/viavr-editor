			<Text Lang="uk">Тип проекту:</Text>
			<Text Lang="fr">Type du projet :</Text>
			<Text Lang="pt-BR">Tipo de projeto:</Text>
			<Text Lang="zh">项目类型：</Text>
			<Text Lang="ko">프로젝트 유형:</Text>
			<Text Lang="pl">Typ projektu:</Text>
			<Text Lang="es">Tipo de proyecto:</Text>
			<Text Lang="it">Tipo di progetto:</Text>
			<Text Lang="ru">Тип проекта:</Text>
			<Text Lang="de">Projekttyp:</Text>
			<Text Lang="ja">プロジェクトの種類：</Text>
		</TextDefinition>

		<TextDefinition Key="LockedBy.Label">
			<Context>label for the "locked by" info field</Context>
			<Text Lang="en">Excl. claimed by:</Text>
			<Text Lang="uk">Присвоєно у виключному режимі:</Text>
			<Text Lang="fr">Revendiqué exclusivement par :</Text>
			<Text Lang="pt-BR">Excl. reivindicado por:</Text>
			<Text Lang="zh">Excl. 认领人：</Text>
			<Text Lang="ko">단독 모드 할당자:</Text>
			<Text Lang="es">Bloqueada en exclusiva por:</Text>
			<Text Lang="it">Reclamato esclusivamente da:</Text>
			<Text Lang="ru">Присвоено в исключительном режиме:</Text>
			<Text Lang="de">Exkl. beansprucht von:</Text>
			<Text Lang="ja">ロックの人：</Text>
		</TextDefinition>

		<TextDefinition Key="LockedAt.Label">
