		<xs:sequence>
			<xs:group ref="ad:TemplatableObjectType" />
			<xs:element name="Visibility" type="ad:VisibilityType"/>
			<xs:element name="Selectability" type="ad:SelectabilityType"/>
			<xs:element name="PreviewImage" type="ad:PreviewImageType" minOccurs="0" />
			<xs:element name="Position" type="ad:PointType" />
			<xs:element name="ZIndex" type="xs:float" />
			<xs:element name="Fill" type="ad:FillType" />
			<xs:element name="Outline" type="ad:OutlineType" />
			<xs:element name="ShowDisplayName" type="xs:boolean" />
			<xs:element name="DisplayNameColor" type="ad:ColorType" />
			<xs:element name="DisplayNameSize" type="xs:int" />
			<xs:element name="DropShadow" type="xs:boolean" />
			<xs:element name="DisplayNamePosition" type="ad:PointType" />
			<xs:element name="Transformation" type="ad:TransformationType" />
			<xs:element name="Coordinates" type="ad:CoordinatesType"/>
			<xs:element name="Opacity" type="xs:float" />
			<xs:element name="Image" type="ad:ReferenceType" />
			<xs:element name="ClipRect" type="ad:RectangleType" />
			<xs:element name="Anchors" type="ad:LocationAnchorsType" />
		</xs:sequence>
		<xs:attributeGroup ref="ad:TemplatableObjectAttributeGroup" />
		<xs:attribute name="CShape" type="ad:CShapeType" use="required" fixed="Rectangle" />
	</xs:complexType>

	<xs:complexType name="LocationTextType">
		<xs:sequence>
			<xs:group ref="ad:TemplatableObjectType" />
			<xs:element name="Visibility" type="ad:VisibilityType"/>
			<xs:element name="Selectability" type="ad:SelectabilityType"/>
			<xs:element name="PreviewImage" type="ad:PreviewImageType" minOccurs="0" />
			<xs:element name="Position" type="ad:PointType" />
			<xs:element name="ZIndex" type="xs:float" />
			<xs:element name="Fill" type="ad:FillType" />
			<xs:element name="Outline" type="ad:OutlineType" />
			<xs:element name="DropShadow" type="xs:boolean" />
			<xs:element name="DisplayNamePosition" type="ad:PointType" />
			<xs:element name="Transformation" type="ad:TransformationType" />
			<xs:element name="Coordinates" type="ad:CoordinatesType"/>
			<xs:element name="Anchors" type="ad:LocationAnchorsType" />
		</xs:sequence>
		<xs:attributeGroup ref="ad:TemplatableObjectAttributeGroup" />
		<xs:attribute name="CShape" type="ad:CShapeType" use="required" fixed="Rectangle" />
	</xs:complexType>


	<xs:complexType name="LinkStyleType">
		<xs:attribute name="Kind" type="ad:LinkStyleKindType" use="required" />
		<xs:attribute name="Size" type="ad:SizeNamesType" use="required" />
	</xs:complexType>
	
	<xs:complexType name="LinkType">
		<xs:sequence>
			<xs:group ref="ad:TemplatableObjectSimpleDisplayNameType" />
            <xs:element name="Visibility" type="ad:VisibilityType"/>
            <xs:element name="Selectability" type="ad:SelectabilityType"/>
			<xs:element name="Position" type="ad:PointType" />
			<xs:element name="ZIndex" type="xs:float" />
			<xs:element name="ShowDisplayName" type="xs:boolean" />
			<xs:element name="DisplayNameColor" type="ad:ColorType" />
			<xs:element name="DropShadow" type="xs:boolean" />
			<xs:element name="Target" type="ad:ReferenceType" minOccurs="0"/>
			<xs:element name="Style" type="ad:LinkStyleType" />
		</xs:sequence>
		<xs:attributeGroup ref="ad:TemplatableObjectAttributeGroup" />
	</xs:complexType>

	<xs:complexType name="LocationSettingsType">
		<xs:sequence>
			<xs:element name="ShowDisplayNameForZone" type="ad:BoolType" />
			<xs:element name="DropShadowForZone" type="ad:BoolType" />
			<xs:element name="DisplayNameSizeForZone" type="xs:float" />
			<xs:element name="DisplayNameColorForZone" type="ad:ColorType" />

			<xs:element name="ShowDisplayNameForPath" type="ad:BoolType" />
			<xs:element name="DropShadowForPath" type="ad:BoolType" />
			<xs:element name="DisplayNameSizeForPath" type="xs:float" />
			<xs:element name="DisplayNameColorForPath" type="ad:ColorType" />

			<xs:element name="ShowDisplayNameForImage" type="ad:BoolType" />
			<xs:element name="DropShadowForImage" type="ad:BoolType" />
			<xs:element name="DisplayNameSizeForImage" type="xs:float" />
			<xs:element name="DisplayNameColorForImage" type="ad:ColorType" />

			<xs:element name="ShowDisplayNameForSpot" type="ad:BoolType" />
			<xs:element name="DropShadowForSpot" type="ad:BoolType" />
			<xs:element name="DisplayNameColorForSpot" type="ad:ColorType" />
			<xs:element name="SpotStyleKind" type="ad:SpotStyleKindType" />
			<xs:element name="SpotStyleSize" type="ad:SizeNamesType" />

			<xs:element name="ShowDisplayNameForLink" type="ad:BoolType" />
			<xs:element name="DropShadowForLink" type="ad:BoolType" />
			<xs:element name="DisplayNameColorForLink" type="ad:ColorType" />
			<xs:element name="LinkStyleKind" type="ad:LinkStyleKindType" />
			<xs:element name="LinkStyleSize" type="ad:SizeNamesType" />

			<xs:element name="DropShadowForText" type="ad:BoolType" />

		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="LocationType">
		<xs:sequence>
			<xs:group ref="ad:TemplatableObjectType" />
			<xs:element name="References" type="ad:ReferencesType" minOccurs="0"/>
			<xs:element name="PreviewImage" type="ad:PreviewImageType" minOccurs="0"/>
<!-- removed in 2.4
			<xs:element name="BackgroundImage" type="ad:ReferenceType" minOccurs="0"/>
			<xs:element name="BackgroundWidth" type="xs:short" minOccurs="0"/>
			<xs:element name="BackgroundHeight" type="xs:short" minOccurs="0"/>
-->
			<xs:element name="Settings" type="ad:LocationSettingsType" />
		</xs:sequence>
		<xs:attributeGroup ref="ad:TemplatableObjectAttributeGroup" />
	</xs:complexType>

	<!-- ========= entities ========= -->
	
	<xs:complexType name="EntityType" mixed="true">
		<xs:sequence>
			<xs:group ref="ad:TemplatableObjectType" />
			<xs:element name="References" type="ad:ReferencesType" minOccurs="0"/>
			<xs:element name="PreviewImage" type="ad:PreviewImageType" minOccurs="0"/>
		</xs:sequence>
		<xs:attributeGroup ref="ad:TemplatableObjectAttributeGroup" />
	</xs:complexType>

	<!-- ========= assets ========= -->

	<xs:complexType name="AssetType">
		<xs:sequence>
			<xs:group ref="ad:TemplatableObjectType"/>
			<xs:element name="PreviewImage" type="ad:PreviewImageType" minOccurs="0"/>
			<xs:element name="AssetFilename" type="xs:string"/>
			<xs:element name="AssetPath" type="xs:string"/>
			<xs:element name="OriginalSource" type="xs:string"/>
		</xs:sequence>
		<xs:attributeGroup ref="ad:TemplatableObjectAttributeGroup" />
	</xs:complexType>

	<!-- ========= journeys ========= -->

	<xs:complexType name="JourneyRefType">
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="IdRef" type="ad:LongIdType" use="required"/>
				<!-- the Id of the referenced object -->
				<xs:attribute name="PinRef" type="ad:LongIdType" use="optional"/>
				<!-- the Id of the referenced pin within the object, when a journey point references a pin -->
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>

    <xs:group name="JourneyPointSettingsTypeGroup">
      <xs:sequence>
        <xs:element name="BackgroundImageMode" type="ad:BackgroundImageModeType" />
        <xs:element name="BackgroundImage" type="ad:ReferenceType" minOccurs="0"/>
        <xs:element name="BackgroundImagePositioningMode" type="ad:BackgroundImagePositioningModeType"/>
        <xs:element name="BackgroundColorMode" type="ad:BackgroundColorModeType" />
        <xs:element name="BackgroundColor" type="ad:ColorType" minOccurs="0" />
        <xs:element name="BackgroundColorGradientMode" type="ad:BackgroundColorGradientModeType" />
        <xs:element name="Duration" type="xs:int"/>
      </xs:sequence>
    </xs:group>

    <xs:complexType name="JourneyPointSettingsType">
      <xs:sequence>
        <xs:group ref="ad:JourneyPointSettingsTypeGroup"/>
      </xs:sequence>
    </xs:complexType>
  
	<xs:complexType name="JourneySettingsType">
		<xs:sequence>
            <xs:group ref="ad:JourneyPointSettingsTypeGroup"/>
            <xs:element name="TransitionMode" type="ad:TransitionModeType"/>
		</xs:sequence>
	</xs:complexType>

	<!-- attributes of a variable -->
	<xs:complexType name="JourneyVariable">
		<xs:attribute name="Name" type="xs:string" use="required"/>
		<xs:attribute name="DataType" type="ad:VariableDataTypeType" use="required"/>
		<xs:attribute name="Value" type="xs:string" use="required"/>
	</xs:complexType>

	<!-- the list of initial or changed values for variables -->
	<xs:complexType name="VariableValuesListType">
		<xs:sequence>
			<xs:element name="Variable" type="ad:JourneyVariable" minOccurs="0" maxOccurs="unbounded"/>
		</xs:sequence>
		<xs:attribute name="Count" type="xs:int" use="required"/>
	</xs:complexType>

	<!-- an method return value entry -->
	<xs:complexType name="JourneyMethodReturnValueType">
		<xs:attribute name="Name" type="xs:string" use="required"/>		<!-- the name of the method -->
		<xs:attribute name="DataType" type="ad:VariableDataTypeType" use="required"/>
		<xs:attribute name="Value" type="xs:string" use="required"/>	<!-- either boolean (True, False) or an integer number -->
	</xs:complexType>

	<!-- the list of return values for methods in scripts -->
	<xs:complexType name="JourneyMethodReturnValuesType">
		<xs:sequence>
			<xs:element name="ScriptText" type="xs:string" minOccurs="0" maxOccurs="1"/>	<!-- the text of the script as reference -->
			<xs:element name="MethodValue" type="ad:JourneyMethodReturnValueType" minOccurs="0" maxOccurs="unbounded"/>	<!-- 0-n values one for each method call -->
		</xs:sequence>
		<xs:attribute name="Count" type="xs:int" use="required"/>
	</xs:complexType>

	<!-- definition of a journey point -->
	<xs:complexType name="JourneyPointType">
		<xs:sequence>
			<xs:element name="Target" type="ad:JourneyRefType" />
            <xs:element name="Text" type="ad:LocalizableTextType" minOccurs="0"/>
            <xs:element name="ExternalId" type="xs:string" />
            <xs:element name="ShortId" type="xs:string" />
			<xs:element name="Settings" type="ad:JourneyPointSettingsType" />
			<xs:element name="ChangedVariableValues" type="ad:VariableValuesListType" />
			<xs:element name="MethodReturnValues" type="ad:JourneyMethodReturnValuesType" minOccurs="0"/>
		</xs:sequence>
		<xs:attribute name="Type" type="ad:TypeOfJourneyPointType" use="required"/>
		<xs:attribute name="ReachedBy" type="ad:ReachedByType" use="required"/>
	</xs:complexType>
	
	<!-- a list of journey points -->
	<xs:complexType name="JourneyPointsType">
		<xs:sequence>
			<xs:element name="JourneyPoint" type="ad:JourneyPointType" minOccurs="0" maxOccurs="unbounded"/>
		</xs:sequence>
		<xs:attribute name="Count" type="xs:int" use="required"/>
	</xs:complexType>

	<xs:complexType name="JourneyType">
		<xs:sequence>
			<xs:group ref="ad:NamedObjectType"/>
			<xs:element name="References" type="ad:ReferencesType" />
			<xs:element name="Settings" type="ad:JourneySettingsType" />
			<xs:element name="InitialVariableValues" type="ad:VariableValuesListType" />
			<xs:element name="JourneyPoints" type="ad:JourneyPointsType" />
		</xs:sequence>
		<xs:attributeGroup ref="ad:SimpleObjectAttributeGroup" />
	</xs:complexType>

	<!-- ========= documents ========= -->

	<xs:complexType name="DocumentType">
		<xs:sequence>
			<xs:group ref="ad:TemplatableObjectType"/>
		</xs:sequence>
		<xs:attributeGroup ref="ad:TemplatableObjectAttributeGroup" />
	</xs:complexType>

	<xs:complexType name="TextObjectType">
		<xs:sequence>
			<xs:group ref="ad:TemplatableObjectType"/>
			<xs:element name="References" type="ad:ReferencesType" minOccurs="0"/>
			<xs:element name="PreviewImage" type="ad:PreviewImageType" minOccurs="0" />
		</xs:sequence>
		<xs:attributeGroup ref="ad:TemplatableObjectAttributeGroup" />
	</xs:complexType>

	<!-- ========= global variables ======== -->

	<xs:complexType name="VariableSetType">
		<xs:sequence>
			<xs:element name="Url" type="xs:string" />
			<xs:element name="TechnicalName" type="ad:TechnicalNameType" />
			<xs:element name="Description" type="ad:LocalizableTextType" />
			<xs:element name="Variables" type="ad:VariablesType" />
		</xs:sequence>
		<xs:attributeGroup ref="ad:SimpleObjectAttributeGroup" />
	</xs:complexType>

	<xs:complexType name="VariablesType">
		<xs:sequence>
			<xs:element name="Variable" type="ad:VariableType" minOccurs="0" maxOccurs="unbounded"/>
		</xs:sequence>
		<xs:attribute name="Count" type="xs:int" use="required"/>			
	</xs:complexType>

	<xs:complexType name="VariableType">
		<xs:sequence>
			<xs:element name="TechnicalName" type="ad:TechnicalNameType" />
			<xs:element name="Description" type="ad:LocalizableTextType" />
			<xs:element name="DataType" type="ad:VariableDataTypeType" />
			<xs:element name="DefaultValue" type="xs:string" />
		</xs:sequence>
	</xs:complexType>

	<!-- ========= project settings ======== -->

	<!-- settings for the flow -->
	<xs:complexType name="FlowSettingsType">
		<xs:sequence>
			<xs:element name="BuiltInScriptSupport" type="ad:BoolType" />
			<xs:element name="GridSize" type="xs:int" />
			<xs:element name="GridSizeEnforced" type="ad:BoolType" />
			<xs:element name="SpacingHorizontal" type="xs:int" />
			<xs:element name="SpacingVertical" type="xs:int" />
			<xs:element name="SpacingEnforced" type="ad:BoolType" />
		</xs:sequence>
	</xs:complexType>

	<!-- external application settings -->
	<xs:complexType name="ApplicationDefinitionType">
		<xs:sequence>
			<xs:element name="Name" type="xs:string" />
			<xs:element name="Command" type="xs:string" />
			<xs:element name="WorkingDirectory" type="xs:string" />
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="ExternalApplicationsType">
		<xs:choice>
			<xs:element name="ApplicationDefinition" type="ad:ApplicationDefinitionType" minOccurs="0" maxOccurs="unbounded" />
		</xs:choice>
	</xs:complexType>

	<!-- main element of project settings -->
	<xs:complexType name="ProjectSettingsType">
		<xs:sequence>
			<xs:element name="FlowSettings" type="ad:FlowSettingsType" />
			<xs:element name="JourneySettings" type="ad:JourneySettingsType" />				<!-- the settings definition is shared with the journey object -->
			<xs:element name="LocationSettings" type="ad:LocationSettingsType" />			<!-- the settings definition is shared with the location object -->
			<xs:element name="ExternalApplications" type="ad:ExternalApplicationsType" />
		</xs:sequence>
		<xs:attributeGroup ref="ad:SimpleObjectAttributeGroup" />
	</xs:complexType>

	<!-- ===========================================================
	             types for main document structure
	============================================================ -->

	<xs:complexType name="SettingsType">
		<xs:sequence>
			<xs:element name="ExportMarkup" type="xs:boolean" />
			<xs:element name="ExportQueries" type="xs:boolean" />
			<xs:element name="WriteNamespace" type="xs:boolean" />
			<xs:element name="WriteAllVariables" type="xs:boolean" />
		</xs:sequence>
	</xs:complexType>
	
	<!-- a entry in the list of export errors -->
	<xs:complexType name="ErrorEntryType">
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="Severity" type="ad:ErrorSeverityType" default="Soft" />
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	
	<xs:complexType name="ExportErrorsType">
		<xs:choice>
			<xs:element name="Error" type="ad:ErrorEntryType" minOccurs="0" maxOccurs="unbounded"/>
		</xs:choice>
	</xs:complexType>

	<!-- the generic nodes that reflect the object order as seen in the projects navigator tree -->
	<xs:complexType name="NodeType" mixed="true">
		<xs:sequence>
			<xs:element name="Node" type="ad:NodeType" minOccurs="0" maxOccurs="unbounded"/>
		</xs:sequence>
		<xs:attribute name="IdRef" type="ad:LongIdType" use="required"/>
		<xs:attribute name="Type" type="xs:string" use="required"/>    <!-- this attribute is only to make the export more human readable so it has no strict checking -->
	</xs:complexType>

	<!-- the hierarchy container element -->
	<xs:complexType name="HierarchyType">
		<xs:sequence>
			<xs:element name="Node" type="ad:NodeType"/>
		</xs:sequence>
	</xs:complexType>

	<!-- list of all objects that can be found in the flattened content aread of the export -->
	<xs:complexType name="ContentType">
		<xs:choice minOccurs="0" maxOccurs="unbounded">
			
			<!-- the main project -->
			<xs:element name="Project" type="ad:ProjectType"/>

			<!-- the main project -->
			<xs:element name="ProjectSettings" type="ad:ProjectSettingsType"/>

			<!-- system folder objects -->
			<xs:element name="Flow" type="ad:SystemFolderType"/>
			<xs:element name="Locations" type="ad:SystemFolderType"/>
			<xs:element name="Journeys" type="ad:SystemFolderType"/>
			<xs:element name="ObjectCustomization" type="ad:SystemFolderType"/>
			<xs:element name="Entities" type="ad:SystemFolderType"/>
			<xs:element name="Assets" type="ad:SystemFolderType"/>
			<xs:element name="Features" type="ad:SystemFolderType"/>
			<xs:element name="Documents" type="ad:SystemFolderType"/>
			<xs:element name="ObjectTemplates" type="ad:SystemFolderType"/>
			<xs:element name="TypedObjectTemplates" type="ad:SystemFolderType"/>
			<xs:element name="PropertyTemplates" type="ad:SystemFolderType" />
			<xs:element name="TypedPropertyTemplates" type="ad:SystemFolderType" />
			<xs:element name="GlobalVariables" type="ad:SystemFolderType" />

			<!-- user folder objects (folders a user can create) -->
			<xs:element name="EntitiesUserFolder" type="ad:UserFolderType"/>
			<xs:element name="FeaturesUserFolder" type="ad:UserFolderType"/>
			<xs:element name="ObjectTemplatesUserFolder" type="ad:UserFolderType"/>
            <xs:element name="TypedPropertyTemplatesUserFolder" type="ad:UserFolderType" />
			<xs:element name="LocationsUserFolder" type="ad:UserFolderType"/>
			<xs:element name="AssetsUserFolder" type="ad:UserFolderType"/>
			<xs:element name="DocumentsUserFolder" type="ad:UserFolderType"/>
			<xs:element name="JourneysUserFolder" type="ad:UserFolderType"/>

			<!-- definition objects of custom template/feature/properties -->
			<xs:element name="FeatureDefinition" type="ad:FeatureDefinitionType"/>
			<xs:element name="TextPropertyDefinition" type="ad:TextPropertyDefinitionType"/>
			<xs:element name="BooleanPropertyDefinition" type="ad:BooleanPropertyDefinitionType"/>
			<xs:element name="NumberPropertyDefinition" type="ad:NumberPropertyDefinitionType"/>
			<xs:element name="ReferenceSlotPropertyDefinition" type="ad:ReferenceSlotPropertyDefinitionType"/>
			<xs:element name="ReferenceStripPropertyDefinition" type="ad:ReferenceStripPropertyDefinitionType"/>
			<xs:element name="QueryReferenceStripPropertyDefinition" type="ad:QueryReferenceStripPropertyDefinitionType"/>
			<xs:element name="EnumerationPropertyDefinition" type="ad:EnumerationPropertyDefinitionType" />
			<xs:element name="ScriptPropertyDefinition" type="ad:ScriptPropertyDefinitionType"/>
			<xs:element name="ObjectTemplateDefinition" type="ad:ObjectTemplateDefinitionType"/>
			
			<!-- flow related objects -->
			
			<!-- common objects -->
			<xs:element name="Comment" type="ad:CommentType"/>
			<xs:element name="Connection" type="ad:ConnectionType"/>
			
			<xs:element name="FlowFragment" type="ad:FlowFragmentType"/>
			<xs:element name="Dialogue" type="ad:DialogueType"/>

			<!-- elements only valid inside dialogs -->
			<xs:element name="DialogueFragment" type="ad:DialogueFragmentType"/>
			<xs:element name="Jump" type="ad:JumpType"/>
			<xs:element name="Hub" type="ad:HubType"/>

			<!-- condition / instruction nodes -->
			<xs:element name="Condition" type="ad:ConditionType"/>
			<xs:element name="Instruction" type="ad:InstructionType"/>

			<!-- location related objects -->
			<xs:element name="Location" type="ad:LocationType"/>
            <xs:element name="LayerFolder" type="ad:LayerFolderType"/>
			<xs:element name="Spot" type="ad:SpotType"/>
			<xs:element name="Zone" type="ad:ZoneType"/>
			<xs:element name="Path" type="ad:PathType"/>
			<xs:element name="Link" type="ad:LinkType"/>
			<xs:element name="LocationImage" type="ad:LocationImageType"/>
			<xs:element name="LocationText" type="ad:LocationTextType"/>

			<!-- Entities -->
			<xs:element name="Entity" type="ad:EntityType"/>

			<!-- Assets -->
			<xs:element name="Asset" type="ad:AssetType"/>

			<!-- Journey -->
			<xs:element name="Journey" type="ad:JourneyType"/>

			<!-- Document -->
			<xs:element name="Document" type="ad:DocumentType" />
			<xs:element name="TextObject" type="ad:TextObjectType" />

			<!-- GlobalVariables -->
			<xs:element name="VariableSet" type="ad:VariableSetType" />

		</xs:choice>
	</xs:complexType>

	<xs:complexType name="ExportType">
		<xs:sequence>
			<xs:element name="Settings" type="ad:SettingsType" />
			<xs:element name="Content" type="ad:ContentType"/>
			<xs:element name="Hierarchy" type="ad:HierarchyType"/>
			<xs:element name="ExportErrors" type="ad:ExportErrorsType" minOccurs="0"/>
		</xs:sequence>
		
		<!-- Version gives the version of the export format, not the version of articy:draft -->
		<xs:attribute name="Version" type="xs:string" use="required" fixed="3.0" />
		<xs:attribute name="CreatorTool" type="xs:string" use="required"/>
		<xs:attribute name="CreatorVersion" type="xs:string" use="required" />
		<xs:attribute name="CreatedOn" type="xs:dateTime" use="required" />
	</xs:complexType>

	<!-- The Root element of the export -->
	<xs:element name="Export" type="ad:ExportType"/>

</xs:schema>
