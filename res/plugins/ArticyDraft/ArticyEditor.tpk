		<TextDefinition Key="ToolTip.Locked">
			<Context/>
			<Text Lang="en">Check locked areas.</Text>
			<Text Lang="de">Überprüfen Sie gesperrte Bereiche.</Text>
			<Text Lang="ru">Проверьте запертые помещения.</Text>
			<Text Lang="uk">Перевірте заблоковані зони.</Text>
