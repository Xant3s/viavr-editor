		<TextDefinition Key="Exception.TemplateNotFound">
			<Context/>
			<Text Lang="en">Template "{0}" does not exist.</Text>
			<Text Lang="uk">Шаблон "{0}" не існує.</Text>
			<Text Lang="fr">Le modèle "{0}" n'existe pas.</Text>
			<Text Lang="pt-BR">Módulo "{0}" não existe.</Text>
