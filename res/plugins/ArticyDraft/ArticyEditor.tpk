			<Text Lang="zh">"({0} 次)</Text>
			<Text Lang="ko">({0} 회)</Text>
			<Text Lang="de">({0} mal)</Text>
			<Text Lang="it">({0} volte)</Text>
		</TextDefinition>

	</Category>

