			<Text Lang="ko">단일-사용자</Text>
			<Text Lang="pl">Pojedynczy użytkownik</Text>
			<Text Lang="es">Usuario único</Text>
			<Text Lang="it">Utente Singolo</Text>
			<Text Lang="ru">Однопользовательский</Text>
