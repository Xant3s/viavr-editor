		<TextDefinition Key="Empty.Description">
			<Context/>
			<Text Lang="en">Leaves the entity section empty.</Text>
			<Text Lang="uk">Залишає секцію для суб'єктів вільною.</Text>
			<Text Lang="fr">Laisse la section des entités vide.</Text>
			<Text Lang="pt-BR">Deixa a sessão de entidades vazia.</Text>
			<Text Lang="zh">将实体部分保留为空</Text>
			<Text Lang="ko">개체 구역을 비워 둡니다.</Text>
			<Text Lang="pl">Zostawia sekcję podmiotów pustą.</Text>
			<Text Lang="es">Deja vacía la sección de entidades.</Text>
			<Text Lang="it">Lascia la sezione entità vuota.</Text>
			<Text Lang="ru">Оставляет свободной секцию для действующего лица.</Text>
			<Text Lang="de">Lässt den Entitäten-Bereich leer.</Text>
			<Text Lang="ja">デジタル資料のフォルダは作られません。</Text>
		</TextDefinition>

		<TextDefinition Key="Game.Name">
			<Context>Element name of the 'Entity folders for' dropdown box</Context>
