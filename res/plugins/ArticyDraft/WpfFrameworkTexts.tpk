	<!--
	  Help view
	-->
	<Category Name="System" Key="HelpView">

		<TextDefinition Key="HelpView.Button.HelpMouseCursor.Caption" Unused="1">
			<Context>Text for the "Help" button</Context>
			<Text Lang="en">Help</Text>
			<Text Lang="uk">Довідка</Text>
			<Text Lang="fr">Aide</Text>
			<Text Lang="pt-BR">Ajuda</Text>
			<Text Lang="zh">帮助</Text>
