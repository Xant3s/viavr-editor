{
  "compilerOptions": {
    "target": "es5",
    "module": "commonjs",
    "sourceMap": true,
    "strict": true,
    "outDir": "../build", // Output transpiled files to build/electron/
    "rootDir": "../",
    "esModuleInterop": true,
    "noEmitOnError": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "typeRoots": [
      "node_modules/@types"
    ]
  }
}
