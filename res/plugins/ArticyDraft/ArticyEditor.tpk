			<Text Lang="es">Carpeta del proyecto:</Text>
			<Text Lang="it">Cartella del Progetto:</Text>
			<Text Lang="ru">Папка проекта:</Text>
			<Text Lang="de">Projektordner:</Text>
			<Text Lang="ja">ローカルフォルダー：</Text>
		</TextDefinition>

		<TextDefinition Key="ProjectType.Label">
			<Context>label for the an info field in the tooltip of a single-user project in the projects list</Context>
