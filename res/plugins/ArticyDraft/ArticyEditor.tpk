	<Category Name="Ui" Namespace=".Presentation">

		<TextDefinition Key="MarkAsStart.Caption">
			<Context/>
			<Text Lang="en">Mark as starting point</Text>
			<Text Lang="uk">Позначає як початкову точку</Text>
			<Text Lang="fr">Marquer comme point de départ</Text>
			<Text Lang="pt-BR">Marcar como ponto de início</Text>
			<Text Lang="zh">标记为起点</Text>
			<Text Lang="ko">출발지점으로 표시</Text>
			<Text Lang="pl">Zaznacz jako punkt startowy</Text>
			<Text Lang="es">Marcar como punto de partida</Text>
			<Text Lang="it">Segna come punto di partenza</Text>
			<Text Lang="ru">Помечает как начальную точку</Text>
			<Text Lang="de">Markiere als Startpunkt</Text>
		</TextDefinition>

		<TextDefinition Key="MarkAsStart.Description">
			<Context/>
			<Text Lang="en">Marks the selected node as a starting point for new presentations.</Text>
			<Text Lang="uk">Позначає обрану вітку як початкову точку для нової презентації.</Text>
			<Text Lang="fr">Marque le nœud sélectionné comme point de départ pour de nouvelles présentations.</Text>
			<Text Lang="pt-BR">Marca o nó selecionado como um ponto de início para novas apresentações</Text>
			<Text Lang="zh">将所选节点标记为新演示的起点。</Text>
			<Text Lang="ko">선택한 노드를 새 프레젠테이션의 시작점으로 표시합니다.</Text>
			<Text Lang="pl">Zaznacza wybrany węzeł jako punkt startowy dla nowych prezentacji.</Text>
			<Text Lang="es">Marca el nodo seleccionado como punto de partida en nuevas presentaciones.</Text>
			<Text Lang="it">Segna lo snodo selezionato come punto di partenza per le nuove presentazioni.</Text>
			<Text Lang="ru">Помечает выбранный Узел как начальную точку для новой презентации.</Text>
			<Text Lang="de">Markiert den selektierten Knoten als Startpunkt für neue Präsentationen.</Text>
		</TextDefinition>

		<TextDefinition Key="StartFromSelection.Caption">
			<Context/>
			<Text Lang="en">Start from selection</Text>
			<Text Lang="uk">Почати з виділення</Text>
			<Text Lang="fr">Commencer à partir de la sélection</Text>
			<Text Lang="pt-BR">Começar da seleção</Text>
			<Text Lang="zh">从所选内容开始</Text>
			<Text Lang="ko">선택 지점부터 시작</Text>
			<Text Lang="pl">Rozpocznij z zaznaczenia</Text>
			<Text Lang="es">Reproducir desde selección</Text>
			<Text Lang="it">Inizia dalla selezione</Text>
			<Text Lang="ru">Начать с выделения</Text>
			<Text Lang="de">Starte von aktueller Selektion</Text>
		</TextDefinition>

		<TextDefinition Key="StartFromSelection.Description">
			<Context/>
			<Text Lang="en">Starts a new presentation (Journey) from the currently selected object.</Text>
			<Text Lang="uk">Починає нову презентацію (Journey) з обраного об'єкта.</Text>
			<Text Lang="fr">Démarre une nouvelle présentation (Trajet) à partir de l'objet sélectionné actuellement.</Text>
			<Text Lang="pt-BR">Começar uma nova apresentação (jornada) do objeto atualmente selecionado.</Text>
			<Text Lang="zh">从当前选定的对象开始新的演示（旅程）。</Text>
			<Text Lang="ko">현재 선택한 객체에서 새 프레젠테이션(여정)을 시작합니다.</Text>
			<Text Lang="pl">Rozpoczyna nową prezentację z obecnie zaznaczonego obiektu.</Text>
			<Text Lang="es">Inicia una nueva presentación empezando por el objeto seleccionado.</Text>
			<Text Lang="it">Inizia una nuova presentazione dal l'oggetto selezionato al momento.</Text>
			<Text Lang="ru">Начать новую презентацию с выбранного объекта.</Text>
			<Text Lang="de">Startet eine neue Präsentation (Journey) vom momentan ausgewählten Objekt.</Text>
		</TextDefinition>

		<TextDefinition Key="StartFromParent.Caption">
			<Context/>
			<Text Lang="en">Start from parent</Text>
			<Text Lang="uk">Почати з батьківського об'єкта</Text>
			<Text Lang="fr">Commencer à partir du parent</Text>
			<Text Lang="pt-BR">Começar de parente</Text>
			<Text Lang="zh">从父级开始</Text>
			<Text Lang="ko">부모부터 시작</Text>
			<Text Lang="pl">Zacznij z obiektu nadrzędnego</Text>
			<Text Lang="es">Reproducir desde el padre</Text>
			<Text Lang="it">Inizia dal genitore</Text>
			<Text Lang="ru"><![CDATA[Проверить
начать с родительского объекта]]></Text>
			<Text Lang="de">Starte vom übergeordnetem Element</Text>
		</TextDefinition>

		<TextDefinition Key="StartFromParent.Description">
			<Context/>
			<Text Lang="en">Starts a new presentation (Journey) from the parent object.</Text>
			<Text Lang="uk">починає нову презентацію (Journey) з батьківського об'єкта.</Text>
			<Text Lang="fr">Démarre une nouvelle présentation (Trajet) à partir de l'objet parent.</Text>
			<Text Lang="pt-BR">Começar uma nova apresentação (jornada) do objeto parente.</Text>
			<Text Lang="zh">从父对象开始新的演示（旅程）。</Text>
			<Text Lang="ko">상위 객체에서 새 프레젠테이션(여정)을 시작합니다.</Text>
			<Text Lang="pl">Rozpoczyna nową prezentację z obiektu nadrzędnego.</Text>
			<Text Lang="es">Inicia una nueva presentación empezando por el objeto padre.</Text>
			<Text Lang="it">Inizia una nuova presentazione dal'oggetto padre.</Text>
			<Text Lang="ru">Начать новую презентацию родительского объекта.</Text>
			<Text Lang="de">Startet eine neue Präsentation (Journey) vom übergeordneten Element.</Text>
		</TextDefinition>

		<TextDefinition Key="StartFromStartPoint.Caption">
			<Context/>
			<Text Lang="en">Start from start point</Text>
			<Text Lang="uk">Почати з стартової точки</Text>
			<Text Lang="fr">Commencer du point de départ</Text>
			<Text Lang="pt-BR">Começar do ponto de início</Text>
			<Text Lang="zh">从起点开始</Text>
			<Text Lang="ko">시작 지점부터 시작</Text>
			<Text Lang="pl">Zacznij z punktu startowego</Text>
			<Text Lang="es">Reproducir desde punto de partida</Text>
			<Text Lang="it">Inizia dal punto di partenza</Text>
			<Text Lang="ru">Начать со стартовой точки</Text>
			<Text Lang="de">Starte vom Startpunkt</Text>
		</TextDefinition>

		<TextDefinition Key="StartFromStartPoint.Description">
			<Context/>
			<Text Lang="en">Starts a new presentation (Journey) from the selected start point.</Text>
			<Text Lang="uk">Починає нова презентацію (Journey) з обраної точки старту.</Text>
			<Text Lang="fr">Démarre une nouvelle présentation (Trajet) à partir du point de départ sélectionné.</Text>
			<Text Lang="pt-BR">Começar uma nova apresentação (jornada) do ponto de início selecionado</Text>
			<Text Lang="zh">从选定的起点开始新的演示（旅程）。</Text>
			<Text Lang="ko">선택한 시작 지점에서 새 프레젠테이션(여정)을 시작합니다.</Text>
			<Text Lang="pl">Rozpoczyna nową prezentację z zaznaczonego punktu startowego.</Text>
			<Text Lang="es">Reproduce la presentación desde el punto de partida seleccionado.</Text>
			<Text Lang="it">Inizia una nuova presentazione dal punto di partenza selezionato.</Text>
			<Text Lang="ru">Начать новую презентацию с выбранной точки старта.</Text>
			<Text Lang="de">Startet eine neue Präsentation (Journey) vom ausgewählten Startpunkt.</Text>
		</TextDefinition>

		<TextDefinition Key="StartFromHere.Caption">
			<Context/>
			<Text Lang="en">Start presentation from here</Text>
			<Text Lang="uk">Почати презентацію з цієї точки</Text>
			<Text Lang="fr">Commencer la présentation à partir d'ici</Text>
			<Text Lang="pt-BR">Começar apresentação daqui</Text>
			<Text Lang="zh">从此处开始演示</Text>
			<Text Lang="ko">여기서 프레젠테이션 시작</Text>
			<Text Lang="pl">Zacznij prezentację stąd</Text>
			<Text Lang="es">Reproducir desde aquí</Text>
			<Text Lang="it">Inizia la presentazione da qui</Text>
			<Text Lang="ru">Начать презентацию с этой точки</Text>
			<Text Lang="de">Starte Präsentation von hier</Text>
		</TextDefinition>

		<TextDefinition Key="StartFromHere.Description">
			<Context/>
			<Text Lang="en">Starts a new presentation (Journey) beginning with this object.</Text>
			<Text Lang="uk">Починає нову презентацію (Journey) з цього об'єкта.</Text>
			<Text Lang="fr">Démarre une nouvelle présentation (Trajet) en commançant avec cet objet.</Text>
			<Text Lang="pt-BR">Começar uma nova apresentação (jornada) começando com este objeto</Text>
			<Text Lang="zh">从这个对象开始新的演示（旅程）。</Text>
			<Text Lang="ko">이 객체부터 시작하여 새 프레젠테이션(여정)을 시작합니다.</Text>
			<Text Lang="pl">Rozpoczyna prezentację z tego obiektu.</Text>
			<Text Lang="es">Inicia una nueva presentación desde este objeto.</Text>
			<Text Lang="it">Inizia una nuova presentazione da questo oggetto.</Text>
			<Text Lang="ru">Начинает новую презентацию с этого объекта.</Text>
			<Text Lang="de">Startet eine neue Präsentation (Journey) von hier</Text>
		</TextDefinition>

		<TextDefinition Key="BrokenReference.Caption">
			<Context/>
			<Text Lang="en"><![CDATA[Invalid journey point
The referenced flow object does not exist or cannot be reached from here anymore!]]></Text>
			<Text Lang="uk">Неприпустима точка Journey. Запитуваний об'єкт потоку не існує, або більше не доступний звідси.</Text>
			<Text Lang="fr"><![CDATA[Point de trajet non valide
L'objet de flux référencé n'existe pas ou n'est plus accessible à partir d'ici !]]></Text>
			<Text Lang="pt-BR"><![CDATA[Ponto de jornada inválido
O objeto de fluxo referenciado não existe or não pode mais ser alcançado daqui!]]></Text>
			<Text Lang="zh"><![CDATA[无效的旅程点
引用的流对象不存在或从此处无法再访问！]]></Text>
			<Text Lang="ko"><![CDATA[잘못된 여정 지점
참조된 흐름 객체가 존재하지 않거나 여기에서 더 이상 찾을 수 없습니다!]]></Text>
			<Text Lang="pl"><![CDATA[Niepoprawny punkt tury
Obiekt flowu, do którego się odwołuje, nie istnieje lub nie można zyskać do niego dostępu!]]></Text>
			<Text Lang="es"><![CDATA[Punto de viaje no válido
El objeto de flujo referenciado no existe o ya no se puede acceder a él.]]></Text>
			<Text Lang="it"><![CDATA[Punto non valido nel tragitto
L'oggetto del diagramma di flusso riferito non esiste o non può essere più raggiunto!]]></Text>
			<Text Lang="ru"><![CDATA[Недопустимая точка путешествия
Запрашиваемый объект потока не существует, либо не может быть достигнут.]]></Text>
			<Text Lang="de"><![CDATA[Ungültiger Journey-Point
Das referenzierte Flow-Objekt existiert nicht mehr oder kann von hier aus nicht mehr erreicht werden.]]></Text>
		</TextDefinition>

		<TextDefinition Key="BrokenReference.Description">
			<Context/>
			<Text Lang="en">Please open the journey point's property sheet to see which object was formerly referenced.</Text>
			<Text Lang="uk">Будь ласка, відкрийте лист властивостей точки Journey, щоб побачити на який об'єкт раніше посилалися.</Text>
			<Text Lang="fr">Veuillez ouvrir la feuille de propriétés du point de trajet pour voir quel objet était précédemment référencé.</Text>
			<Text Lang="pt-BR">Por favor abra a folha de propriedade do ponto de jornada cujo objeto foi anteriormente referenciado.</Text>
			<Text Lang="zh">请打开旅程点的属性表，以查看曾经引用的对象。</Text>
			<Text Lang="ko">이전에 참조한 객체를 보려면 여정 지점의 속성 시트를 여십시오.</Text>
			<Text Lang="pl">Proszę otworzyć arkusz właściwości punktu tury, żeby zobaczyć, który obiekt został wcześniej wywołany.</Text>
			<Text Lang="es">Abre la hoja de propiedades de ese punto del viaje para averiguar cuál era el objeto referenciado.</Text>
			<Text Lang="it">Si prega di aprire la scheda delle proprietà dei punti del tragitto per vedere quale oggetto è stato precedentemente riferito.</Text>
			<Text Lang="ru">Пожалуйста, откройте лист свойств точки путешествия, чтобы увидеть на какой объект ссылались.</Text>
			<Text Lang="de">Öffnen Sie die Eigenschaften des Journey-Points um zu sehen, welches Objekt vorher referenziert wurde.</Text>
		</TextDefinition>

		<TextDefinition Key="NoBranchesPlayerMode.Caption">
			<Context/>
			<Text Lang="en">All outgoing connections lead to conditions that are evaluated to false.</Text>
			<Text Lang="uk">Всі вихідні з'єднання призводять до умов, які оцінюються як хибні.</Text>
			<Text Lang="fr">Toutes les connexions sortantes conduisent à des conditions déterminées comme fausses.</Text>
			<Text Lang="pt-BR">Todas as conexões de saída levam para condições que são avaliadas para falso.</Text>
			<Text Lang="zh">所有传出连接都会导致评估结果为false的状态。</Text>
			<Text Lang="ko">모든 나가는 연결은 false로 평가 되는 조건으로 이어집니다.</Text>
			<Text Lang="de">Alle ausgehenden Verbindungen führen zu Bedingungen, die "false" zurückgeben.</Text>
		</TextDefinition>

		<TextDefinition Key="NoBranchesPlayerMode.Description">
			<Context/>
			<Text Lang="en">Switch to analysis mode or check the flow to see the reasons for this dead end.</Text>
			<Text Lang="uk">Перейдіть до режиму аналізу або перевірте потік, щоб побачити причини цього тупика.</Text>
			<Text Lang="fr">Passez en mode analyse ou vérifiez le flux pour voir les raisons de cette impasse.</Text>
			<Text Lang="pt-BR">Trocar para modo de análise ou checar o fluxo para ver as razões para este beco sem saída.</Text>
			<Text Lang="zh">切换至分析模式或检查“流”以查看此死亡结局的原因。</Text>
			<Text Lang="ko">분석 모드로 전환 하거나 흐름을 확인 하 여이 데드 엔드에 대한 이유를 볼 수 있습니다.</Text>
			<Text Lang="de">Wechseln Sie zum Analyse-Modus oder überprüfen Sie den Flow, um die entsprechenden Bedingungen zu sehen.</Text>
		</TextDefinition>

		<TextDefinition Key="SelectInputPin.Description">
			<Context/>
			<Text Lang="en">Choose an input pin to start from</Text>
			<Text Lang="uk">Вибрати вхідний контакт як початкову точку</Text>
			<Text Lang="fr">Choisissez une broche d'entrée à partir de laquelle commencer</Text>
			<Text Lang="pt-BR">Escolha um pino de entrada para começar</Text>
			<Text Lang="zh">选择要作为开端的输入Pin</Text>
			<Text Lang="ko">시작할 입력 핀을 선택</Text>
			<Text Lang="pl">Wybierz punkt wejścia jako punkt startowy</Text>
			<Text Lang="es">Elegir conector de entrada como punto de partida</Text>
			<Text Lang="it">Scegli un connettore di ingresso come punto di partenza</Text>
			<Text Lang="ru">Выбрать входящий контакт как начальную точку</Text>
			<Text Lang="de">Wählen Sie einen Eingangs-Pin als Startpunkt</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.Caption">
			<Context/>
			<Text Lang="en">REC</Text>
			<Text Lang="uk">Запис</Text>
			<Text Lang="fr">REC</Text>
			<Text Lang="pt-BR">REC</Text>
			<Text Lang="zh">录制</Text>
			<Text Lang="ko">녹음</Text>
			<Text Lang="pl">REC</Text>
			<Text Lang="es">Grabar</Text>
			<Text Lang="it">REC</Text>
			<Text Lang="ru">Запись</Text>
			<Text Lang="de">REC</Text>
		</TextDefinition>

	</Category>

	<Category Name="Ui" Namespace=".Presentation.ControlBar">

		<TextDefinition Key="RecordMode.SaveToProject.Description">
			<Context/>
			<Text Lang="en">Stores the temporary journey in the project's 'Journeys' folder.</Text>
			<Text Lang="uk">Зберігає тимчасову journey у папці «Journeys» проекту.</Text>
			<Text Lang="fr">Enregistre le trajet temporaire dans le dossier 'Trajets' du projet.</Text>
			<Text Lang="pt-BR">Guarda a jornada temporária na pasta 'Jornadas' do projeto.</Text>
			<Text Lang="zh">将临时旅程存储在项目的“旅程”文件夹中。</Text>
			<Text Lang="ko">임시 이동 경로를 프로젝트의 '여정' 폴더에 저장합니다.</Text>
			<Text Lang="pl">Przechowuje tymczasowo turę w określonym folderze w projekcie.</Text>
			<Text Lang="es">Guarda el viaje temporal en una carpeta específica del proyecto.</Text>
			<Text Lang="it">Conserva il tragitto temporaneo nella cartella specificata nel progetto.</Text>
			<Text Lang="ru">Сохранить временное путешествие в специальную папку проекта.</Text>
			<Text Lang="de">Speichert die temporäre Journey unter dem Ordner "Journeys" im Projekt ab.</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.StopRecordMode.Description">
			<Context/>
			<Text Lang="en">Stops the record mode and switches back to view mode.</Text>
			<Text Lang="uk">Зупиняє режим запису і переходить в режим перегляду.</Text>
			<Text Lang="fr">Arrete le mode d'enregistrement et revenient au mode d'affichage.</Text>
			<Text Lang="pt-BR">Para o modo de gravação e troca de volta para o modo de visualização.</Text>
			<Text Lang="zh">停止录制模式兵切换回查看模式。</Text>
			<Text Lang="ko">기록 모드를 중지하고 다시 보기 모드로 전환합니다.</Text>
			<Text Lang="pl">Zatrzymuje tryb nagrywania i powraca do trybu widoku.</Text>
			<Text Lang="es">Detiene la grabación y vuelve al modo de visualización.</Text>
			<Text Lang="it">Interrompi la modalità registrazione e passa alla modalità di visualizzazione.</Text>
			<Text Lang="ru">Останавливает режим записи и переходит в режим просмотра.</Text>
			<Text Lang="de">Stoppt den Aufzeichnungsmodus und wechselt zurück zum Anzeigemodus.</Text>
		</TextDefinition>

		<TextDefinition Key="ViewMode.StartRecordMode.Description">
			<Context/>
			<Text Lang="en">Starts the record mode.</Text>
			<Text Lang="uk">Починає режим запису.</Text>
			<Text Lang="fr">Démarre le mode d'enregistrement.</Text>
			<Text Lang="pt-BR">Começa modo de gravação</Text>
			<Text Lang="zh">启动录制模式。</Text>
			<Text Lang="ko">기록 모드를 시작합니다.</Text>
			<Text Lang="pl">Rozpoczyna tryb nagrywania.</Text>
			<Text Lang="es">Inicia el modo de grabación.</Text>
			<Text Lang="it">Attiva la modalità registrazione.</Text>
			<Text Lang="ru">Начинает режим записи.</Text>
			<Text Lang="de">Startet den Aufzeichnungsmodus.</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.DesignerMode.Description">
			<Context/>
			<Text Lang="en">Analysis Mode - Show 'false' options on conditions and visualize every scripting expression along the journey.</Text>
			<Text Lang="uk">Режим аналізу - Показує «false»  параметри умов та візуалізуйте кожне скриптове ценарій вираження під час подорожі.</Text>
			<Text Lang="fr">Mode Analyse - Afficher les 'fausses' options sur les conditions et visualiser chaque expression de script le long du trajet.</Text>
			<Text Lang="pt-BR">Modo de Análise - Mostra opções 'Falso' em condições e vizualiza todas as expressões de Scripting pela jornada.</Text>
			<Text Lang="zh">分析模式 - 在条件上显示“错误”选项，并可视化整个旅程中的每个脚本表达式。</Text>
			<Text Lang="ko">분석 모드 - 조건에 따라 'false' 옵션을 표시하고 이동 중에 모든 스크립팅 식을 시각화합니다.</Text>
			<Text Lang="pl">Tryb Analizy - pokazuje opcje z zaprzeczonymi warunkami i zatrzymuje w każdym równaniu skryptu w czasie tury.</Text>
			<Text Lang="de">Analyse-Modus - Stelle bei Bedingungen auch die ungültigen Pfade dar und zeige jedes Skript im Verlauf der Journey explizit an.</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.PlayerMode.Description">
			<Context/>
			<Text Lang="en">Player Mode - Hide 'false' options on conditions and skip scripting expressions along the journey.</Text>
			<Text Lang="uk">Режим гравця - Приховує «false» параметри умов та пропускаї вирази скриптів під час подорожі.</Text>
			<Text Lang="fr">Mode Joueur - Masquer les 'fausses' options sur les conditions et passer les expressions de script tout au long du trajet.</Text>
			<Text Lang="pt-BR">Modo de Jogador - Esconde opções 'Falso' em condições e pula expressões de Scripting pela jornada.</Text>
			<Text Lang="zh">玩家模式 - 隐藏条件中的“错误”选项，并跳过整个旅程中的脚本表达式。</Text>
			<Text Lang="ko">플레이어 모드 - 조건에 따라 'false' 옵션을 숨기고 이동 중에 스크립팅 식을 건너뜁니다.</Text>
			<Text Lang="pl">Tryb Odtwarzana - ukryw</Text>
			<Text Lang="de">Spieler-Modus - Verstecke bei Bedingungen die ungültigen Optionen und überspringe alle Skripte im Verlauf der Journey.</Text>
		</TextDefinition>

		<TextDefinition Key="General.EnterFullscreen.Description">
			<Context/>
			<Text Lang="en">Opens the presentation in full-screen mode on the selected display.</Text>
			<Text Lang="uk">Відкриває презентацію у повноекранному режимі на вибрано дисплеї.</Text>
			<Text Lang="fr">Ouvre la presentation en mode plein écran sur l'affichage sélectionné.</Text>
			<Text Lang="pt-BR">Abre a apresentação em modo tela cheia na exibição selecionada.</Text>
			<Text Lang="zh">在所选显示器上以全屏模式打开演示。</Text>
			<Text Lang="ko">선택한 디스플레이에서 전체 화면 모드로 프레젠테이션을 엽니다.</Text>
			<Text Lang="pl">Otwiera prezentację w trybie pełnoekranowym na wybranym wyświetlaczu.</Text>
			<Text Lang="es">Inicia la presentación a pantalla completa a partir del punto seleccionado.</Text>
			<Text Lang="it">Apri la presentazione in modalità schermo intero nello schermo selezionato.</Text>
			<Text Lang="ru">Открывает презентацию в полноэкранном режиме на выбранном дисплее.</Text>
			<Text Lang="de">Öffnet die Präsentation im Vollbild-Modus auf dem ausgewählten Bildschirm.</Text>
		</TextDefinition>

		<TextDefinition Key="General.LeaveFullscreen.Description">
			<Context/>
			<Text Lang="en">Leaves the full-screen mode.</Text>
			<Text Lang="uk">Виходить з повноекранного режиму</Text>
			<Text Lang="fr">Quitte le mode plein écran.</Text>
			<Text Lang="pt-BR">Deixa o modo tela cheia.</Text>
			<Text Lang="zh">退出全屏模式。</Text>
			<Text Lang="ko">전체 화면 모드를 종료합니다.</Text>
			<Text Lang="pl">Zamyka bieżącą prezentację pełnoekranową.</Text>
			<Text Lang="es">Cierra la presentación actual a pantalla completa.</Text>
			<Text Lang="it">Chiudi la presentazione a schermo intero corrente.</Text>
			<Text Lang="ru">Закрывает текущую полноэкранную презентацию.</Text>
			<Text Lang="de">Beendet den Vollbild-Modus.</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.StepBack.Description">
			<Context/>
			<Text Lang="en">Navigates back without changing the journey.</Text>
			<Text Lang="uk">Повертається назад не змінюючи Journey.</Text>
			<Text Lang="fr">Navigue en arrière sans changer le trajet.</Text>
			<Text Lang="pt-BR">Navega de volta sem mudar a jornada.</Text>
			<Text Lang="zh">在不改变旅程的情况下返回。</Text>
			<Text Lang="ko">여정을 변경하지 않고 뒤로 돌아간다.</Text>
			<Text Lang="pl">Nawiguje wstecz bez zmiany w turze.</Text>
			<Text Lang="es">Vuelve atrás sin cambiar el viaje.</Text>
			<Text Lang="it">Naviga indietro senza cambiare il tragitto.</Text>
			<Text Lang="ru">Возвращается назад не изменяя путешествие.</Text>
			<Text Lang="de">Geht einen Schritt zurück, ohne die Journey zu ändern.</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.StepBack.Caption">
			<Context/>
			<Text Lang="en">Back</Text>
			<Text Lang="uk">Назад</Text>
			<Text Lang="fr">Retour</Text>
			<Text Lang="pt-BR">Para trás</Text>
			<Text Lang="zh">返回</Text>
			<Text Lang="ko">뒤로</Text>
			<Text Lang="pl">Wstecz</Text>
			<Text Lang="es">Atrás</Text>
			<Text Lang="it">Indietro</Text>
			<Text Lang="ru">Назад</Text>
			<Text Lang="de">Zurück</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.Delete.Description">
			<Context/>
			<Text Lang="en">Removes the current step and rewinds the presentation to the last valid point.</Text>
			<Text Lang="uk">Видаляє поточний крок і перемотує презентацію до останьої доступної точки.</Text>
			<Text Lang="fr">Enlève l'étape en cours et recommence la présentation depuis le dernier point valide.</Text>
			<Text Lang="pt-BR">Remove o passo atual e rebobina a apresentação para o último ponto válido.</Text>
			<Text Lang="zh">删除当前步骤并将演示回退至最后一个有效点。</Text>
			<Text Lang="ko">현재 단계를 제거하고 프레젠테이션을 마지막 유효한 지점으로 다시 연결합니다.</Text>
			<Text Lang="pl">Usuwa obecny krok i przenosi prezentację do ostatniego, poprawnego punktu.</Text>
			<Text Lang="es">Elimina el paso actual y lleva la presentación hasta el último punto válido.</Text>
			<Text Lang="it">Rimuovi il passaggio corrente e muovi la presentazione all'ultimo punto valido.</Text>
			<Text Lang="ru">Удаляет текущий шаг и переводит презентацию к последней доступной точке.</Text>
			<Text Lang="de">Entfernt den aktuellen Schritt und spult die Präsentation zum letzten gültigen Punkt zurück.</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.Delete.Caption">
			<Context/>
			<Text Lang="en">Delete</Text>
			<Text Lang="uk">Видалити</Text>
			<Text Lang="fr">Supprimer</Text>
			<Text Lang="pt-BR">Deletar</Text>
			<Text Lang="zh">删除</Text>
			<Text Lang="ko">삭제</Text>
			<Text Lang="pl">Usuń</Text>
			<Text Lang="es">Eliminar</Text>
			<Text Lang="it">Cancella</Text>
			<Text Lang="ru">Удалить</Text>
			<Text Lang="de">Entfernen</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.Submerge.Description">
			<Context/>
			<Text Lang="en">Submerges into the node and includes contained children in the presentation.</Text>
			<Text Lang="uk">Занурюється у вітку і включає в  дочірні записи, що містяться в презентації.</Text>
			<Text Lang="fr">Submerge dans le nœud et inclut les enfants contenus dans la présentation.</Text>
			<Text Lang="pt-BR">Submerge no nó e inclui crianças na apresentação.</Text>
			<Text Lang="zh">沉浸到节点中，并在演示中包含子级。</Text>
			<Text Lang="ko">컨테이너/폴더 열기는 노드와 노드에 포함 된 하위 항목을 프레젠테이션에 포함 합니다.</Text>
			<Text Lang="pl">Wchodzi w węzeł i pokazuje zawarte dzieci.</Text>
			<Text Lang="es">Despliega el nodo y muestra los objetos que contiene.</Text>
			<Text Lang="it">Immergiti nello snodo e mostra i figli contenuti.</Text>
			<Text Lang="ru">Погружается в контакт и показывает содержащиеся в нем дочерние записи.</Text>
			<Text Lang="de">Taucht in den Knoten ein und durchläuft auch die Kind-Knoten in dieser Präsentation.</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.Submerge.Caption">
			<Context/>
			<Text Lang="en">Submerge</Text>
			<Text Lang="uk">Зануритись</Text>
			<Text Lang="fr">Submerger</Text>
			<Text Lang="pt-BR">Submergir</Text>
			<Text Lang="zh">沉浸</Text>
			<Text Lang="ko">컨테이너/폴더 열기</Text>
			<Text Lang="pl">Wejdź</Text>
			<Text Lang="es">Desplegar</Text>
			<Text Lang="it">Immergiti</Text>
			<Text Lang="ru">Погрузиться</Text>
			<Text Lang="de">Eintauchen</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.Emerge.Description">
			<Context/>
			<Text Lang="en">Emerges out of the current node and proceeds to the parent's successor.</Text>
			<Text Lang="uk">Виринає з поточної вітки і показує наслідника батьківського елементу.</Text>
			<Text Lang="fr">Émerge du nœud actuel et passe au successeur du parent.</Text>
			<Text Lang="pt-BR">Emerge fora do nó e procede para o sucessor dos parentes.</Text>
			<Text Lang="zh">从当前节点出现并继续推进至父节点的后续节点。</Text>
			<Text Lang="ko">컨테이너/폴더 나가기는 현재 노드에서 상위 항목으로 이동합니다.</Text>
			<Text Lang="pl">Wychodzi z obecnego węzła i pokazuje następny objekt rodzica.</Text>
			<Text Lang="es">Sale del nodo actual y muestra el nodo padre.</Text>
			<Text Lang="it">Emergi dallo snodo corrente e mostra il successore del padre.</Text>
			<Text Lang="ru">Выходит из текущего контакта и показывает приемника родительского элемента.</Text>
			<Text Lang="de">Taucht aus dem aktuellen Knoten auf und springt auf den Nachfolger des übergeordneten Knotens.</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.Emerge.Caption">
			<Context/>
			<Text Lang="en">Emerge</Text>
			<Text Lang="uk">Виринути</Text>
			<Text Lang="fr">Émerger</Text>
			<Text Lang="pt-BR">Emergir</Text>
			<Text Lang="zh">出现</Text>
			<Text Lang="ko">컨테이너/폴더 나가기</Text>
			<Text Lang="pl">Wyjdź</Text>
			<Text Lang="es">Emerger</Text>
			<Text Lang="it">Emergi</Text>
			<Text Lang="ru">Выйти</Text>
			<Text Lang="de">Auftauchen</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.Skip.Description">
			<Context/>
			<Text Lang="en">Skips the child elements inside this node and proceeds with the next successor on this level.</Text>
			<Text Lang="uk">Пропускає дочірні елемненти всредині цієї вітки та переходить до наступого наслідника батькоівського елементу.</Text>
			<Text Lang="fr">Ignore les éléments enfants à l'intérieur de ce nœud et passe au successeur suivant à ce niveau.</Text>
			<Text Lang="pt-BR">Pula todos os elementos crianças dentro deste nó com o próximo sucessor neste nível.</Text>
			<Text Lang="zh">跳过此节点内的子元素，然后继续执行此级别的后续元素。</Text>
			<Text Lang="ko">이 노드 내의 하위 요소를 스킵하고 이 수준에서 다음의 항목으로 넘어갑니다.</Text>
			<Text Lang="pl">Pomija elementy dzieci i przechodzi do następnego rodzeństwa.</Text>
			<Text Lang="es">Omite los elementos contenidos y se mueve hasta el siguiente .</Text>
			<Text Lang="it">Salta gli elementi figli e muovi al prossimo fratello.</Text>
			<Text Lang="ru">Пропускает дочерние записи и двигается к следующему элементы.</Text>
			<Text Lang="de">Überspringt die enthaltenen Kinder und geht zum nächsten Nachfolger auf dieser Ebene.</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.Skip.Caption">
			<Context/>
			<Text Lang="en">Skip</Text>
			<Text Lang="uk">Пропустити</Text>
			<Text Lang="fr">Passer</Text>
			<Text Lang="pt-BR">Pular</Text>
			<Text Lang="zh">跳过</Text>
			<Text Lang="ko">건너뛰기</Text>
			<Text Lang="pl">Pomiń</Text>
			<Text Lang="es">Omitir</Text>
			<Text Lang="it">Salta</Text>
			<Text Lang="ru">Пропустить</Text>
			<Text Lang="de">Überspringen</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.Next.Description">
			<Context/>
			<Text Lang="en">Continues with the next element in the sequence.</Text>
			<Text Lang="uk">Переходить до наступного елементу в послідовностію</Text>
			<Text Lang="fr">Continue avec le prochain élément dans la séquence.</Text>
			<Text Lang="pt-BR">Continua com o próximo elemento na sequência</Text>
			<Text Lang="zh">继续序列中的下一个元素。</Text>
			<Text Lang="ko">다음 단계로 이어지는 순서대로 계속하십시오.</Text>
			<Text Lang="pl">Przechodzi do następnego elementu w sekwencji.</Text>
			<Text Lang="es">Avanza hasta el siguiente elemento de la secuencia.</Text>
			<Text Lang="it">Continua con il prossimo elemento nella sequenza.</Text>
			<Text Lang="ru">Переходит к следующему элементу в последовательности.</Text>
			<Text Lang="de">Fährt mit dem nächsten Element in der Sequenz fort.</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.Next.Caption">
			<Context/>
			<Text Lang="en">Next</Text>
			<Text Lang="uk">Наступний</Text>
			<Text Lang="fr">Suivant</Text>
			<Text Lang="pt-BR">Próximo</Text>
			<Text Lang="zh">下一个</Text>
			<Text Lang="ko">다음</Text>
			<Text Lang="pl">Dalej</Text>
			<Text Lang="es">Siguiente</Text>
			<Text Lang="it">Prossimo</Text>
			<Text Lang="ru">Следующий</Text>
			<Text Lang="de">Weiter</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.Branch.Description">
			<Context/>
			<Text Lang="en">Select this to continue the journey on this branch.</Text>
			<Text Lang="uk">Виберіть це для продовження Journey в цій гілці.</Text>
			<Text Lang="fr">Selectioner ceci pour continuer le trajet sur cette branche.</Text>
			<Text Lang="pt-BR">Selecione isto para continuar a jornada neste ramo.</Text>
			<Text Lang="zh">选择该选项以继续此分支的旅程</Text>
			<Text Lang="ko">이 분기에서 계속할 여정을 선택하십시오.</Text>
			<Text Lang="pl">Wybierz to, żeby kontynuować turę z tej gałęzi.</Text>
			<Text Lang="es">Prosigue el viaje desde esta rama.</Text>
			<Text Lang="it">Seleziona questo per continuare il tragitto con questo ramo.</Text>
			<Text Lang="ru">Выберите это для продолжения путешествия по этой ветке.</Text>
			<Text Lang="de">Auswählen um auf diesem Zweig fortzufahren.</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.Branch.Caption">
			<Context/>
			<Text Lang="en">Branch</Text>
			<Text Lang="uk">Гілка</Text>
			<Text Lang="fr">Branche</Text>
			<Text Lang="pt-BR">Ramificar</Text>
			<Text Lang="zh">分支</Text>
			<Text Lang="ko">분기</Text>
			<Text Lang="pl">Gałąź</Text>
			<Text Lang="es">Ramificar</Text>
			<Text Lang="it">Ramo</Text>
			<Text Lang="ru">Ветка</Text>
			<Text Lang="de">Abzweigen</Text>
		</TextDefinition>

		<TextDefinition Key="RecordMode.EndPoint.Caption">
			<Context/>
			<Text Lang="en">End of journey</Text>
			<Text Lang="uk">Завершити Journey</Text>
			<Text Lang="fr">Fin du trajet</Text>
			<Text Lang="pt-BR">Fim da jornada</Text>
			<Text Lang="zh">旅程终点</Text>
			<Text Lang="ko">여정의 끝</Text>
			<Text Lang="pl">Koniec tury</Text>
			<Text Lang="es">Fin del viaje</Text>
			<Text Lang="it">Fine del tragitto</Text>
			<Text Lang="ru">Завершить путешествие</Text>
			<Text Lang="de">Ende der Journey</Text>
		</TextDefinition>

		<TextDefinition Key="ViewMode.NavigateBack.Description">
			<Context/>
			<Text Lang="en">Steps back to the last point in the presentation.</Text>
			<Text Lang="uk">Повертається до останньої точки презентації</Text>
			<Text Lang="fr">Retourne au dernier point dans la présentation.</Text>
			<Text Lang="pt-BR">Volta para o último ponto na apresentação</Text>
			<Text Lang="zh">退回至演示的最后一个点。</Text>
			<Text Lang="ko">프레젠테이션의 이전 지점으로 이동합니다.</Text>
			<Text Lang="pl">Cofa do ostatniego punktu w prezentacji.</Text>
			<Text Lang="es">Vuelve al último punto de la presentación.</Text>
			<Text Lang="it">Ritorna all'ultimo punto della presentazione.</Text>
			<Text Lang="ru">Отступает к предыдущей точке презентации.</Text>
			<Text Lang="de">Geht einen Schritt zurück zum vorherigen Punkt in der Präsentation.</Text>
		</TextDefinition>

		<TextDefinition Key="ViewMode.NavigateBack.Caption">
			<Context/>
			<Text Lang="en">Back</Text>
			<Text Lang="uk">Назад</Text>
			<Text Lang="fr">Retour</Text>
			<Text Lang="pt-BR">Para trás</Text>
			<Text Lang="zh">返回</Text>
			<Text Lang="ko">뒤로</Text>
			<Text Lang="pl">Wstecz</Text>
			<Text Lang="es">Atrás</Text>
			<Text Lang="it">Indietro</Text>
			<Text Lang="ru">Назад</Text>
			<Text Lang="de">Zurück</Text>
		</TextDefinition>

		<TextDefinition Key="ViewMode.NavigateForward.Description">
			<Context/>
			<Text Lang="en">Moves forward to the next point in the presentation.</Text>
			<Text Lang="uk">Рухається вперед до наступної точки презентації.</Text>
			<Text Lang="fr">Avance au prochain point dans la présentation.</Text>
			<Text Lang="pt-BR">Move para frente para o próximo ponto na apresentação.</Text>
			<Text Lang="zh">向前移动到演示的下一个点。</Text>
			<Text Lang="ko">프레젠테이션의 다음 지점로 이동합니다.</Text>
			<Text Lang="pl">Przechodzi do następnego punktu w prezentacji.</Text>
			<Text Lang="es">Avanza hasta el siguiente punto de la presentación.</Text>
			<Text Lang="it">Avanza al prossimo punto della presentazione.</Text>
			<Text Lang="ru">Двигается вперед к следующей точке презентации.</Text>
			<Text Lang="de">Geht einen Schritt vor zum nächsten Punkt in der Präsentation.</Text>
		</TextDefinition>

		<TextDefinition Key="ViewMode.NavigateForward.Caption">
			<Context/>
			<Text Lang="en">Next</Text>
			<Text Lang="uk">Вперед</Text>
			<Text Lang="fr">Suivant</Text>
			<Text Lang="pt-BR">Próximo</Text>
			<Text Lang="zh">下一个</Text>
			<Text Lang="ko">다음</Text>
			<Text Lang="pl">Dalej</Text>
			<Text Lang="es">Siguiente</Text>
			<Text Lang="it">Prossimo</Text>
			<Text Lang="ru">Вперед</Text>
			<Text Lang="de">Weiter</Text>
		</TextDefinition>

		<TextDefinition Key="ViewMode.StopAutoPlay.Description">
			<Context/>
			<Text Lang="en">Stops the current auto-play mode.</Text>
			<Text Lang="uk">Зупиняє автоматичне відтворення</Text>
			<Text Lang="fr">Arrête le mode de lecture automatique actuel.</Text>
			<Text Lang="pt-BR">Para o atual modo de jogo-automático.</Text>
			<Text Lang="zh">停止当前的自动播放模式。</Text>
			<Text Lang="ko">현재 자동 재생 모드를 중지합니다.</Text>
			<Text Lang="pl">Zatrzymuje obecny tryb automatyczny.</Text>
			<Text Lang="es">Detiene el modo de reproducción automática.</Text>
			<Text Lang="it">Ferma l'attuale modalità di auto avvio.</Text>
			<Text Lang="ru">Останавливает автоматическое воспроизведение.</Text>
			<Text Lang="de">Hält den momentanen Auto-Play-Modus an.</Text>
		</TextDefinition>

		<TextDefinition Key="ViewMode.StartAutoPlay.Description">
			<Context/>
			<Text Lang="en">Starts auto-playing the presentation.</Text>
			<Text Lang="uk">Починає автоматичне відтворення презентації.</Text>
			<Text Lang="fr">Démarre la lecture automatique de la présentation.</Text>
			<Text Lang="pt-BR">Começa á jogar automaticamente a apresentação.</Text>
			<Text Lang="zh">开始自动播放演示。</Text>
			<Text Lang="ko">프레젠테이션을 자동 재생으로 시작합니다.</Text>
			<Text Lang="pl">Zatrzymuje automatyczne odtwarzanie prezentacji.</Text>
			<Text Lang="es">Inicia la reproducción automática de la presentación.</Text>
			<Text Lang="it">Inizia con auto avvio della presentazione.</Text>
			<Text Lang="ru">Начинает автоматическое воспроизведение Презентации.</Text>
			<Text Lang="de">Startet den Auto-Play-Modus für diese Präsentation.</Text>
		</TextDefinition>

	</Category>

	<!--
	  DocumentView
	-->
	<Category Name="Ui" Namespace=".DocumentView">

		<TextDefinition Key="ModelPicker.SelectImage.Caption">
			<Context>Used in document view for the image link model picker</Context>
			<Text Lang="en">Please choose an image.</Text>
			<Text Lang="uk">Будь ласка виберіть зображення.</Text>
			<Text Lang="fr">Veuillez choisir un image.</Text>
			<Text Lang="pt-BR">Por favor escolha uma imagem.</Text>
			<Text Lang="zh">请选择图像。</Text>
			<Text Lang="ko">이미지를 선택하십시오.</Text>
			<Text Lang="pl">Proszę wybrać obrazek.</Text>
			<Text Lang="es">Por favor, elige una imagen.</Text>
			<Text Lang="it">Si prega di selezionare un'immagine.</Text>
			<Text Lang="ru">Пожалуйста, выберите изображение.</Text>
			<Text Lang="de">Bitte wählen Sie ein Bild.</Text>
		</TextDefinition>

		<TextDefinition Key="LinkImage.Caption">
			<Context>dummy name of link with an image</Context>
			<Text Lang="en">Image</Text>
			<Text Lang="uk">Зображення</Text>
			<Text Lang="fr">Image</Text>
			<Text Lang="pt-BR">Imagem</Text>
			<Text Lang="zh">图像</Text>
			<Text Lang="ko">이미지</Text>
			<Text Lang="pl">Obrazek</Text>
			<Text Lang="es">Imagen</Text>
			<Text Lang="it">Immagine</Text>
			<Text Lang="ru">Изображение</Text>
			<Text Lang="de">Bild</Text>
		</TextDefinition>

		<TextDefinition Key="LinkImage.Description">
			<Context>dummy name of link with an image</Context>
			<Text Lang="en">Create a new chapter showing an image-asset.</Text>
			<Text Lang="uk">Створити новий розділ, що показує ресурс-зображення.</Text>
			<Text Lang="fr">Créer un nouveau chapitre montrant un atout-image.</Text>
			<Text Lang="pt-BR">Criar um novo capítulo mostrando um recurso de imagem.</Text>
			<Text Lang="zh">创建显示图像资源的新章节。</Text>
			<Text Lang="ko">이미지 에셋을 보여주는 새 장 생성</Text>
			<Text Lang="pl">Tworzy nowy rozdział pokazujący asset typu obraz.</Text>
			<Text Lang="es">Crea un nuevo capítulo con un recurso de imagen.</Text>
			<Text Lang="it">Crea un nuovo capitolo mostrando un asset immagine.</Text>
			<Text Lang="ru">Создать новую главу показывающую ресурс-изображение.</Text>
