<?xml version='1.0' encoding='utf-8' standalone='yes' ?>
<TextPackage BaseNamespace="Articy.WpfFramework" GenerateIds="True" xml:space="preserve" xmlns="http://nevigo.com/TextPackage.xsd">

	<!--
	  misc buttons
	-->
	<Category Name="System" Key="Buttons">

		<TextDefinition Key="Navigation.Cancel">
