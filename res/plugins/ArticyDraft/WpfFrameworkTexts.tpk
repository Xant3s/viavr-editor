			<Text Lang="uk">Вилучити '{0}' зі словника</Text>
			<Text Lang="fr">Supprimer « {0} » du dictionnaire</Text>
			<Text Lang="pt-BR">Remover '{0}' do dicionário</Text>
			<Text Lang="zh">将 '{0}' 从字典移除</Text>
			<Text Lang="ko">디렉토리에 '{0}' 제거</Text>
			<Text Lang="de">'{0}' aus dem Wörterbuch entfernen</Text>
		</TextDefinition>

	</Category>

