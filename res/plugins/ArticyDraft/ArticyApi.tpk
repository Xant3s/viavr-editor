		<TextDefinition Key="ParseError.MoreOpeningThanClosingBraces">
			<Context/>
			<Text Lang="en">There are more opening than closing braces (Type: {0}).</Text>
			<Text Lang="uk">Відкривних дужок більше ніж закривних (Тип: {0}).</Text>
