	<Category Name="Ui" Namespace=".DownloadAdditionalLanguages">

		<TextDefinition Key="Button.Caption">
			<Context>text for the button to open the 'download spellchecker dicts'</Context>
			<Text Lang="en">Additional languages...</Text>
			<Text Lang="uk">Додаткові мови...</Text>
			<Text Lang="fr">Langues additionnelles…</Text>
			<Text Lang="pt-BR">Idiomas adicionais...</Text>
			<Text Lang="zh">其他语言...</Text>
			<Text Lang="ko">추가 언어…</Text>
			<Text Lang="pl">Dodatkowe języki...</Text>
			<Text Lang="es">Idiomas adicionales...</Text>
			<Text Lang="it">Lingue aggiuntive...</Text>
			<Text Lang="ru">Дополнительные языки…</Text>
			<Text Lang="de">Weitere Sprachen...</Text>
		</TextDefinition>

		<TextDefinition Key="Button.Description">
			<Context>tooltip for the button to open the 'download spellchecker dicts'</Context>
			<Text Lang="en">Shows a list of additional downloadable languages</Text>
			<Text Lang="uk">Показує список додаткових мов для завантаження</Text>
			<Text Lang="fr">Montrer une liste de langues supplémentaires téléchargeables</Text>
			<Text Lang="pt-BR">Mostra uma lista de idiomas adicionais para download</Text>
			<Text Lang="zh">显示其他可下载语言的列表</Text>
			<Text Lang="ko">추가로 다운로드 가능한 언어 목록 표시</Text>
			<Text Lang="pl">Pokazuje listę dodatkowych języków do pobrania</Text>
			<Text Lang="es">Muestra una lista de idiomas adicionales que se pueden descargar</Text>
			<Text Lang="it">Mostra una lista di lingue aggiuntive scaricabili.</Text>
			<Text Lang="ru">Показывает список дополнительных скачиваемых языков</Text>
			<Text Lang="de">Zeigt eine Liste weiterer Sprachen zum Herunterladen an</Text>
		</TextDefinition>

		<TextDefinition Key="Dialog.Title">
			<Context>Window title for the spelldict download dialog</Context>
			<Text Lang="en">Download additional languages</Text>
			<Text Lang="uk">Завантажити додаткові мови</Text>
			<Text Lang="fr">Télécharger des langues supplémentaires</Text>
			<Text Lang="pt-BR">Baixar idiomas adicionais</Text>
			<Text Lang="zh">下载其他语言</Text>
			<Text Lang="ko">추가 언어 다운로드</Text>
			<Text Lang="pl">Pobierz dodatkowe języki</Text>
			<Text Lang="es">Descargar idiomas adicionales</Text>
			<Text Lang="it">Download di lingue aggiuntive</Text>
			<Text Lang="ru">Скачать дополнительные языки</Text>
			<Text Lang="de">Weitere Sprachen herunterladen</Text>
		</TextDefinition>

		<TextDefinition Key="Dialog.Pending">
			<Context>Overlaytext for the spelldict download dialog when downloading the list of available languages</Context>
			<Text Lang="en">Downloading list of available spelling dictionaries...</Text>
			<Text Lang="uk">Завантаження списку доступних орфографічних словників...</Text>
			<Text Lang="fr">Téléchargement de la liste de dictionnaires d'orthographe disponibles…</Text>
			<Text Lang="pt-BR">Baixando lista de dicionários de ortografia disponíveis</Text>
			<Text Lang="zh">正在下载可用的拼写词典列表...</Text>
			<Text Lang="ko">사용 가능한 철자 사전 목록을 다운로드하는 중…</Text>
			<Text Lang="pl">Pobieranie listy dostępnych słowników...</Text>
			<Text Lang="es">Descargando lista de diccionarios ortográficos disponibles...</Text>
			<Text Lang="it">Scaricando la lista dei dizionari per controllo ortografico disponibili...</Text>
			<Text Lang="ru">Загрузка списка доступных словарей правописания …</Text>
			<Text Lang="de">Liste der Wörterbücher für die Rechtschreibprüfung wird heruntergeladen...</Text>
		</TextDefinition>

		<TextDefinition Key="Dialog.FailedToDownloadList">
			<Context>Overlaytext for the spelldict download dialog when downloading the list of available languages has failed</Context>
			<Text Lang="en">List of spelling dictionaries could not be retrieved.</Text>
			<Text Lang="uk">Список орфографічних словників не вдалося отримати.</Text>
			<Text Lang="fr">Impossible de récupérer la liste des dictionnaires d'orthograph.</Text>
			<Text Lang="pt-BR">Lista de dicionários de ortografia não pode ser recuperado.</Text>
			<Text Lang="zh">无法检索拼写词典列表。</Text>
			<Text Lang="ko">철자 사전 목록을 검색할 수 없습니다.</Text>
			<Text Lang="pl">Lista słowników nie może zostać pobrana.</Text>
			<Text Lang="es">No se ha podido conseguir la lista de diccionarios ortográficos.</Text>
			<Text Lang="it">Impossibile ottenere la lista dei dizionari per il controllo ortografico.</Text>
