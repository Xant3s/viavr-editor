		<TextDefinition Key="Filter.Caption">
			<Context>file format filter in custom docx export</Context>
			<Text Lang="en">Word Document (*.docx)|*.docx|All Files (*.*)|*.*</Text>
			<Text Lang="uk">Word Документ (*.docx)|*.docx|Всі файли (*.*)|*.*</Text>
			<Text Lang="fr">Document Word (*.docx)|*.docx|Tous les Fichiers (*.*)|*.*</Text>
			<Text Lang="pt-BR"><![CDATA[Documento Word 
(*.docx)|*.docx|Todos os arquivos(*.*)|*.*]]></Text>
			<Text Lang="zh">Word 文档(*.docx)|*.docx|所有文件 (*.*)|*.*</Text>
			<Text Lang="ko">워드 문서 (*.docx)|*.docx|모든 파일 (*.*)|*.*</Text>
			<Text Lang="pl">Dokument Word (*.docx)|*docx|Wszystkie pliki (*.*)|*.*</Text>
			<Text Lang="es">Documento de Word (*.docx)|*.docx|Todos los archivos (*.*)|*.*</Text>
