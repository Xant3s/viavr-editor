		</TextDefinition>

		<TextDefinition Key="ParseError.Number.InvalidValue">
			<Context>Thrown when a number value is expected but not supplied</Context>
			<Text Lang="en">Expected a number, but found: '{0}'.</Text>
			<Text Lang="uk">Очікувалося число, а знайдено '{0}'.</Text>
			<Text Lang="fr">Un nombre était attendu mais nous avons trouvé : '{0}'.</Text>
			<Text Lang="pt-BR">Esperado um número, mas achou: '{0}'.</Text>
			<Text Lang="zh">应为数字，但找到了'{0}'。</Text>
