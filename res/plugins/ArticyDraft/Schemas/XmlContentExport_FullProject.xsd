	</xs:simpleType>

	<xs:simpleType  name="TransformMatrixType">
		<xs:restriction base="ad:ListOfFloatsType" >
			<xs:maxLength value="9"/>
			<xs:minLength value="9" />
		</xs:restriction>		
	</xs:simpleType >	
	
	<xs:complexType name="TransformationType" >
		<xs:sequence>
			<xs:element name="Rotation" type="xs:float" />
