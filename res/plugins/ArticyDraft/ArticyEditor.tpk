		<TextDefinition Key="CustomTrait.QueryReferenceStripTrait.Properties.Caption">
			<Context/>
			<Text Lang="en">Strip (calculated) properties</Text>
			<Text Lang="uk">Властивості рядка (обчислені)</Text>
			<Text Lang="fr">Propriétés (calculées) du bordereau</Text>
			<Text Lang="pt-BR">Propriedades de tiras (calculadas)</Text>
