			<Text Lang="ru">Экспорт векторов/изображений (.xps)</Text>
			<Text Lang="ja">ベクター/画像エクスポート（.xps）</Text>
		</TextDefinition>

		<TextDefinition Key="Command.ExportFlowToXps.Description">
			<Context/>
			<Text Lang="en">Export this view as a vector graphic file in XPS format.</Text>
			<Text Lang="de">Exportiert diese Ansicht als Vektorgrafik-Datei im XPS Format.</Text>
			<Text Lang="ko">이 보기를 XPS 형식의 벡터 그래픽 파일로 내보냅니다.</Text>
			<Text Lang="uk">Експортуйте це подання як векторний графічний файл у форматі XPS.</Text>
			<Text Lang="fr">Exportez cette vue comme un fichier graphique vectoriel au format XPS.</Text>
			<Text Lang="pt-BR">Exportar esta visualização como um arquivo gráfico vetorial em formato XPS.</Text>
			<Text Lang="zh">将该视图导出为XPS格式的矢量图形文件。</Text>
			<Text Lang="pl">Wyeksportuj ten widok jako wektorowy plik graficzny w formacie XPS.</Text>
			<Text Lang="es">Exporte esta vista como un archivo gráfico vectorial en formato XPS.</Text>
			<Text Lang="it">Esportare questa vista come file grafico vettoriale in formato XPS.</Text>
			<Text Lang="ru">Экспортируйте этот вид в виде векторного графического файла в формате XPS.</Text>
			<Text Lang="ja">このビューをXPS形式のベクターグラフィックファイルとしてエクスポートします。</Text>
		</TextDefinition>

		<TextDefinition Key="Command.ExportLocationToXps.Caption">
			<Context>tooltip text for toolbox button</Context>
			<Text Lang="en">Vector/image export (.xps)</Text>
			<Text Lang="de">Vektor/Bild export (.xps)</Text>
			<Text Lang="ko">벡터/이미지 내보내기(.xps)</Text>
			<Text Lang="uk">Експорт вектора/зображення (.xps)</Text>
			<Text Lang="fr">Exportation de vecteurs/image (.xps)</Text>
			<Text Lang="pt-BR">Vetor/exportação de imagens (.xps)</Text>
			<Text Lang="zh">矢量/图像输出（.xps）。</Text>
			<Text Lang="pl">Eksport wektorów/obrazów (.xps)</Text>
			<Text Lang="es">Exportación de vectores/imágenes (.xps)</Text>
			<Text Lang="it">Esportazione di vettori/immagini (.xps)</Text>
			<Text Lang="ru">Экспорт векторов/изображений (.xps)</Text>
			<Text Lang="ja">ベクター/画像エクスポート（.xps）</Text>
		</TextDefinition>

		<TextDefinition Key="Command.ExportLocationToXps.Description">
			<Context/>
			<Text Lang="en">Export this view as a vector graphic file in XPS format.</Text>
			<Text Lang="de">Exportiert diese Ansicht als Vektorgrafik-Datei im XPS Format.</Text>
			<Text Lang="ko">이 보기를 XPS 형식의 벡터 그래픽 파일로 내보냅니다.</Text>
			<Text Lang="uk">Експортуйте це подання як векторний графічний файл у форматі XPS.</Text>
			<Text Lang="fr">Exportez cette vue comme un fichier graphique vectoriel au format XPS.</Text>
			<Text Lang="pt-BR">Exportar esta visualização como um arquivo gráfico vetorial em formato XPS.</Text>
			<Text Lang="zh">将该视图导出为XPS格式的矢量图形文件。</Text>
			<Text Lang="pl">Wyeksportuj ten widok jako wektorowy plik graficzny w formacie XPS.</Text>
			<Text Lang="es">Exporte esta vista como un archivo gráfico vectorial en formato XPS.</Text>
			<Text Lang="it">Esportare questa vista come file grafico vettoriale in formato XPS.</Text>
