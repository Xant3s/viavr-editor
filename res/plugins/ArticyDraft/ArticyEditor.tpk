		<TextDefinition Key="Error.FailedToCreateModel">
			<Context>unknown error (will show exception).</Context>
			<Text Lang="en">Cannot create new object: '{0}'. Unknown error.</Text>
			<Text Lang="uk">Неможливо створити новий об'єкт: '{0}'. Невідома помилка.</Text>
			<Text Lang="fr">Impossible de créer un nouvel objet : « {0} ». Erreur inconnue.</Text>
			<Text Lang="pt-BR"><![CDATA[Não pôde criar novo objeto: '{0}';
Erro desconhecido.]]></Text>
