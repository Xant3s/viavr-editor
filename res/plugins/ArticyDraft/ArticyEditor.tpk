			<Text Lang="uk">для вибраних типів/шаблонів</Text>
			<Text Lang="fr">pour les types/modèles sélectionnés</Text>
			<Text Lang="pt-BR">para tipos/módulos selecionados</Text>
			<Text Lang="zh">所选类型/模板</Text>
			<Text Lang="ko">선택한 유형/템플릿</Text>
			<Text Lang="de">für die selektierten Typen/Vorlagen</Text>
		</TextDefinition>

