		<TextDefinition Key="SelectTemplate.DialogInfo.Caption">
			<Context>subtitle text in the dialog window that asks the user to pick a template</Context>
			<Text Lang="en">Please choose a template.</Text>
			<Text Lang="uk">Будь ласка, виберіть шаблон об'єкта.</Text>
