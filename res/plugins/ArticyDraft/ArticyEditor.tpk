		<TextDefinition Key="Messages.DoubleTechnicalName.Description">
			<Context>bbcode formated string for displaying an item with invalid technical name</Context>
			<Text Lang="en">[col=white][b]{0}[/b][/col][col=darkgray]: Technical name '[/col][col=red][b]{1}[/b][/col][col=darkgray]' used more than once.[/col]</Text>
			<Text Lang="uk">[col=white][b]{0}[/b][/col][col=darkgray]: Технічна назву '[/col][col=red][b]{1}[/b][/col][col=darkgray]' використано більше одного разу.[/col]</Text>
			<Text Lang="fr">[col=white][b]{0}[/b][/col][col=darkgray] : Nom Technique « [/col][col=red][b]{1}[/b][/col][col=darkgray] » utilisé plus d'une fois.[/col]</Text>
			<Text Lang="pt-BR">[col=white][b]{0}[/b][/col][col=darkgray]: Nome técnico '[col][col=red][b]{1}[/b][/col][col=darkgray]' usado mais de uma vez.[/col]</Text>
			<Text Lang="zh">[col=white][b]{0}[/b][/col][col=darkgray]: 技术名称 '[/col][col=red][b]{1}[/b][/col][col=darkgray]' 被重复使用了多次。[/col]</Text>
			<Text Lang="ko">[col=white][b]{0}[/b][/col][col=darkgray]: 기술 이름 '[/col][col=red][b]{1}[/b][/col][col=darkgray]' 을 두 번 이상 사용되었습니다.[/col]</Text>
			<Text Lang="pl">[col=white][b]{0}[/b][/col][col=darkgray]: Nazwa techniczna '[/col][col=red][b]{1}[/b][/col][col=darkgray]' użyta więcej niż jeden raz.[/col]</Text>
			<Text Lang="es">[col=white][b]{0}[/b][/col][col=darkgray]: El nombre técnico '[/col][col=red][b]{1}[/b][/col][col=darkgray]' ha sido usado más de una vez.[/col]</Text>
			<Text Lang="it">[col=white][b]{0}[/b][/col][col=darkgray]: Nome tecnico '[/col][col=red][b]{1}[/b][/col][col=darkgray]' usato più di una volta.[/col]</Text>
			<Text Lang="ru">[col=white][b]{0}[/b][/col][col=darkgray]: Техническое имя '[/col][col=red][b]{1}[/b][/col][col=darkgray]' использовано более одного раза.[/col]</Text>
			<Text Lang="de">[col=white][b]{0}[/b][/col][col=darkgray]: Technischer Name '[/col][col=red][b]{1}[/b][/col][col=darkgray]' wird mehrfach verwendet.[/col]</Text>
		</TextDefinition>

