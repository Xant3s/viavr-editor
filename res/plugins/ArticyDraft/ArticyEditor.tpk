			<Text Lang="pl">Dzieje się tutaj:</Text>
			<Text Lang="es">Sucede desde:</Text>
			<Text Lang="it">Succede qui:</Text>
			<Text Lang="ru">Случается здесь:</Text>
			<Text Lang="de">Flow-Knoten, die in diesem Schauplatz stattfinden:</Text>
		</TextDefinition>

