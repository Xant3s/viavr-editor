{
  "name": "viavr-editor",
  "version": "0.1.0",
  "description": "VIA-VR Editor",
  "main": "dist/src/App/App.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps && cd plugins/Spoke && yarn install --ignore-scripts",
    "build": "tsc",
    "watch": "tsc -w",
    "start": "electron .",
    "prestart": "npm run build",
    "package": "npm run build && electron-builder build",
    "package:win": "npm-run-all package copy-dependencies:win",
    "copy-dependencies:win": "cpy plugins out/win-unpacked --parents --dot",
    "test": "mocha --config test/.mocharc.jsonc",
    "clean": "rimraf ./dist ./out"
  },
  "keywords": [],
  "author": "Samuel Truman",
  "license": "none",
  "devDependencies": {
    "@types/chai": "^4.3.0",
    "@types/jquery": "^3.5.13",
    "@types/mocha": "^9.1.0",
    "chai": "^4.3.6",
    "cpy-cli": "^3.1.1",
    "electron": "^11.3.0",
    "electron-builder": "^22.14.13",
    "electron-reloader": "^1.2.1",
    "mocha": "^9.2.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^3.0.2",
    "ts-mockito": "^2.6.1",
    "ts-node": "^10.4.0",
    "typescript": "^4.2.2"
  },
  "dependencies": {
    "adm-zip": "^0.5.9",
    "extract-zip": "^2.0.1",
    "fast-folder-size": "^1.6.1",
    "fs-extra": "^10.0.0",
    "jquery": "^3.6.0",
    "node-fetch": "^2.6.7"
  },
  "build": {
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "fileAssociations": [
      {
        "ext": [
          "via"
        ],
        "name": "VIA-VR Project",
        "description": "VIA-VR Project"
      }
    ],
    "directories": {
      "output": "./out"
    },
    "asarUnpack": [
      "**/*.node"
    ],
    "buildDependenciesFromSource": true,
    "npmRebuild": true
  }
}
