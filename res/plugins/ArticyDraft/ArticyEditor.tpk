	<!--
	  SCM History
	-->
	<Category Name="Ui" Namespace=".RibbonToolBar.ScmHistory">

		<TextDefinition Key="History.Description">
			<Context>Tooltip for the whole control</Context>
			<Text Lang="en">Latest partition actions</Text>
			<Text Lang="uk">Останні дії розділу</Text>
			<Text Lang="fr">Actions de partitions récentes</Text>
			<Text Lang="pt-BR">Últimas ações de partição</Text>
			<Text Lang="zh">最新分区操作</Text>
			<Text Lang="ko">최신 파티션 작업</Text>
			<Text Lang="pl">Najnowsze akcje partycji</Text>
			<Text Lang="es">Últimas acciones de partición</Text>
			<Text Lang="it">Ultime azioni di partizione</Text>
			<Text Lang="ru">Последние действия раздела</Text>
			<Text Lang="de">Letze Partitions-Aktionen</Text>
		</TextDefinition>

		<TextDefinition Key="Entry.Claimed.Format">
			<Context>Entry in a log that lists all partition claiming/unclaiming actions of the opened project; 0=username, 1=partition name</Context>
			<Text Lang="en">{0} claimed "{1}".</Text>
			<Text Lang="uk">{0} присвоїв «{1}»</Text>
			<Text Lang="fr">{0} a revendiqué « {1} ».</Text>
			<Text Lang="pt-BR">{0} reivindicado como "{1}".</Text>
			<Text Lang="zh">{0} 认领了 "{1}"。</Text>
			<Text Lang="ko">{0}이(가) "{1}"을(를) 할당했습니다.</Text>
			<Text Lang="pl">{0} zarezerwował '{1}'.</Text>
			<Text Lang="es">{0} ha reclamado "{1}".</Text>
			<Text Lang="it">{0} ha reclamato "{1}".</Text>
			<Text Lang="ru">{0} присвоил "{1}".</Text>
			<Text Lang="de">{0} hat "{1}" beansprucht.</Text>
		</TextDefinition>

		<TextDefinition Key="Entry.Unclaimed.Format">
			<Context>Entry in a log that lists all partition claiming/unclaiming actions of the opened project; 0=username, 1=partition name</Context>
			<Text Lang="en">{0} unclaimed "{1}".</Text>
			<Text Lang="uk">{0} скасував присвоєння «{1}»</Text>
			<Text Lang="fr">{0} a abandonné « {1} ».</Text>
			<Text Lang="pt-BR">{0} não reivindicado como "{1}".</Text>
			<Text Lang="zh">{0} 取消认领了 "{1}"。</Text>
			<Text Lang="ko">{0}이(가) "{1}"을(를) 할당 해제했습니다.</Text>
			<Text Lang="pl">{0} odrezerwował '{1}'.</Text>
			<Text Lang="es">{0} ha liberado "{1}".</Text>
			<Text Lang="it">{0} ha tolto il reclamo su "{1}".</Text>
			<Text Lang="ru">{0} отчужден "{1}".</Text>
			<Text Lang="de">{0} hat "{1}" freigegeben.</Text>
		</TextDefinition>

		<TextDefinition Key="Entry.Published.Format">
			<Context>Entry in a log that lists all partition claiming/unclaiming actions of the opened project; 0=username, 1=partition name</Context>
			<Text Lang="en">{0} published changes on "{1}".</Text>
			<Text Lang="uk">{0} опублікував зміни в «{1}»</Text>
			<Text Lang="fr">{0} a publié des modifications sur « {1} ».</Text>
			<Text Lang="pt-BR">{0} publíca mudanças em "{1}".</Text>
			<Text Lang="zh">{0} 已在 "{1}"上上传更改。</Text>
			<Text Lang="ko">{0}이(가) "{1}"에 대한 변경 사항을 게시했습니다.</Text>
			<Text Lang="pl">{0} opublikował zmiany '{1}'.</Text>
			<Text Lang="es">{0} ha publicado cambios en "{1}".</Text>
			<Text Lang="it">{0} ha pubblicato modifiche su "{1}".</Text>
			<Text Lang="ru">{0} опубликовал изменения в "{1}".</Text>
			<Text Lang="de">{0} hat Änderungen auf "{1}" publiziert.</Text>
		</TextDefinition>

		<TextDefinition Key="Entry.Terminated.Format">
			<Context>Entry in a log that lists all partition claiming/unclaiming actions of the opened project; 0=username, 1=partition name</Context>
			<Text Lang="en">{0} forced an unclaim on "{1}".</Text>
			<Text Lang="uk">{0} викликав примусове скасування присвоєння «{1}»</Text>
			<Text Lang="fr">{0} a forcé un abandon sur « {1} ».</Text>
			<Text Lang="pt-BR">{0} força não-reivindicação como "{1}".</Text>
			<Text Lang="zh">{0} 强制对 "{1}"取消认领。</Text>
			<Text Lang="ko">{0}이(가) "{1}"을(를) 강제로 할당 해제했습니다.</Text>
			<Text Lang="pl">{0} siłą odrezerwował '{1}'.</Text>
			<Text Lang="es">{0} a forzado que "{1}" fuese liberada.</Text>
			<Text Lang="it">{0} ha rimosso forzatamente i reclami su "{1}".</Text>
			<Text Lang="ru">{0} вызвал принудительное отчужден "{1}".</Text>
			<Text Lang="de">{0} hat die Freigabe von "{1}" erzwungen.</Text>
		</TextDefinition>

		<TextDefinition Key="Entry.Created.Format">
			<Context>Entry in a log that lists all partition claiming/unclaiming actions of the opened project; 0=username, 1=partition name</Context>
			<Text Lang="en">{0} turned "{1}" into a new partition.</Text>
			<Text Lang="uk">{0} перетворив «{1}» у нове розділення.</Text>
			<Text Lang="fr">{0} a transformé « {1} » en une nouvelle partition.</Text>
			<Text Lang="pt-BR">{0} transformou "{1}" em uma nova partição.</Text>
			<Text Lang="zh">{0} 将 "{1}" 转换为新分区。</Text>
			<Text Lang="ko">{0}이(가) "{1}"을(를) 새 파티션으로 변환했습니다.</Text>
			<Text Lang="pl">{0} zamienił '{1}' na nową partycję.</Text>
			<Text Lang="es">{0} ha convertido "{1}" en una nueva partición.</Text>
			<Text Lang="it">{0} ha trasformato "{1}" in una nuova partizione.</Text>
			<Text Lang="ru">{0} преобразовал "{1}" в новый раздел.</Text>
			<Text Lang="de">{0} hat "{1}" in eine neue Partition umgewandelt.</Text>
		</TextDefinition>

		<TextDefinition Key="Entry.Retired.Format">
			<Context>Entry in a log that lists all partition claiming/unclaiming actions of the opened project; 0=username, 1=partition name</Context>
			<Text Lang="en">{0} has canceled partition "{1}".</Text>
			<Text Lang="uk">{0} розформував розділення «{1}»</Text>
			<Text Lang="fr">{0} a annulé la partition « {1} ».</Text>
			<Text Lang="pt-BR">{0} cancelou a partição "{1}".</Text>
			<Text Lang="zh">{0} 已取消分区 "{1}"。</Text>
			<Text Lang="ko">{0}이(가) 파티션 "{1}"을(를) 취소했습니다.</Text>
			<Text Lang="pl">{0} wycofał partycję '{1}'.</Text>
			<Text Lang="es">{0} ha retirado la partición "{1}".</Text>
			<Text Lang="it">{0} ha ritirato la partizione "{1}".</Text>
			<Text Lang="ru">{0} расформировал раздел "{1}".</Text>
			<Text Lang="de">{0} hat die Partition "{1}" aufgelöst.</Text>
		</TextDefinition>

	</Category>

