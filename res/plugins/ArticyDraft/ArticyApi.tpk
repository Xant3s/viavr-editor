			<Text Lang="it">Attesa una frase di tipo 'FROM', trovato invece '{0}'.</Text>
			<Text Lang="ru">Ожидался оператор 'FROM', а был обнаружен '{0]'.</Text>
			<Text Lang="de">Erwarte 'FROM'-Klausel, vorgefunden wurde aber: '{0}'.</Text>
		</TextDefinition>

		<TextDefinition Key="ParseError.ExpectedEndOfQueryButFound">
			<Context/>
			<Text Lang="en">Expecting end of query, but found: '{0}'.</Text>
			<Text Lang="uk">Очікувався кінець запиту, але знайдено '{0}'.</Text>
			<Text Lang="fr">Attend la fin de la requête, mais a trouvé: '{0}'.</Text>
			<Text Lang="pt-BR">Esperando fim de consulta, mas encontrou: '{0}'.</Text>
