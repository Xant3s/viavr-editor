<?xml version='1.0' encoding='utf-8' standalone='yes' ?>
<TextPackage BaseNamespace="Articy.Models" GenerateIds="True" xml:space="preserve" xmlns="http://nevigo.com/TextPackage.xsd">

	<!--
	  Structural nodes
	-->
	<Category Name="Ui">

		<TextDefinition Key="ArticyApp._Self_.Caption" Unused="1">
			<Context>Object type name of the root model. Currently not to be seen anywhere; no loca!</Context>
			<Text Lang="en">Articy</Text>
			<Text Lang="fr">Articy</Text>
			<Text Lang="pt-BR">Articy</Text>
			<Text Lang="zh">Articy</Text>
			<Text Lang="ko">Articy</Text>
			<Text Lang="pl">Articy</Text>
			<Text Lang="de">Articy</Text>
		</TextDefinition>

	</Category>

	<!--
	  ######## General Nodes ########
	-->
	<!--
	  General / Project
	-->
	<Category Name="System" Namespace=".General.Project">

		<TextDefinition Key="_Self_.Caption" Unused="1">
			<Context>Object type name of a project. Currently not to be seen anywhere;</Context>
