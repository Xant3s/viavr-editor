			<Text Lang="pl">Projekt</Text>
			<Text Lang="de">Projekt</Text>
		</TextDefinition>

	</Category>

	<!--
	  General / Comment
	-->
	<Category Name="System" Namespace=".General.Comment">

		<TextDefinition Key="_Self_.Default" Unused="1">
			<Context>Default name for newly  created annotations; will most probably changed by the user at a later time</Context>
			<Text Lang="en">Untitled annotation</Text>
			<Text Lang="uk">Об'єднана анотація</Text>
			<Text Lang="fr">Annotation sans titre</Text>
