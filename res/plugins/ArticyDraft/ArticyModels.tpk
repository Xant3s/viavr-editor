		<TextDefinition Key="TraitNumberPrecisionValidator.Caption">
			<Context>Format string for the error message</Context>
			<Text Lang="en">"{0}" is violating maximum precision constraint "{1}"!</Text>
			<Text Lang="uk">"{0}" порушує максимальне обмеження по точності "{1}"!</Text>
			<Text Lang="fr">« {0} » ne respecte pas la contrainte de précision maximale « {1} » !</Text>
			<Text Lang="pt-BR">"{0}" é  a restrição de precisão máxima "{1}"!</Text>
			<Text Lang="zh">"{0}" 违反了最大精度限制 "{1}"！</Text>
			<Text Lang="ko">"{0}"이(가) 최대 정밀 제한 "{1}"을(를) 위반하고 있습니다!</Text>
			<Text Lang="pl">{0}' narusza maksymalne wartości precyzji '{1}'!</Text>
			<Text Lang="es">¡"{0}" viola la restricción de precisión máxima "{1}"!</Text>
			<Text Lang="it">"{0}" sta violando il limite massimo di precisione "{1}"!</Text>
			<Text Lang="ru">"{0}" нарушает максимальное ограничение по точности "{1}"!</Text>
			<Text Lang="de">"{0}" verletzt die Bedingung "{1}" zur maximalen Genauigkeit!</Text>
		</TextDefinition>

		<TextDefinition Key="TraitLocalizedStringValidCharsValidator.Caption">
