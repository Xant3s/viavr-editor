		<TextDefinition Key="MaxLength.Description">
			<Context>Tooltip in property editor</Context>
			<Text Lang="en">Defines the maximum text length.</Text>
			<Text Lang="uk"><![CDATA[Визначає максимальну довжину тексту.
]]></Text>
			<Text Lang="fr">Définie la longueur maximale du texte.</Text>
			<Text Lang="pt-BR">Define a extensão máximo do texto.</Text>
			<Text Lang="zh">定义最大文本长度。</Text>
