		<TextDefinition Key="DisallowedChars.Description">
			<Context>Tooltip in property editor</Context>
			<Text Lang="en">A list of all invalid characters.</Text>
			<Text Lang="uk">Список усіх недійсних символів.</Text>
			<Text Lang="fr">Liste de tous les caractères invalides.</Text>
			<Text Lang="pt-BR">Uma lista de todos os caracteres inválidos</Text>
			<Text Lang="zh">所有无效字符的列表。</Text>
			<Text Lang="ko">모든 잘못된 캐릭터 목록입니다.</Text>
			<Text Lang="pl">Lista nieprawidłowych znaków.</Text>
			<Text Lang="es">Una lista con todos los caracteres no válidos.</Text>
			<Text Lang="it">Una lista dei caratteri non disponibili.</Text>
			<Text Lang="ru">Список недопустимых символов</Text>
			<Text Lang="de">Eine Liste aller ungültigen Zeichen.</Text>
		</TextDefinition>

		<TextDefinition Key="MaxLength.Caption">
			<Context>Label in property editor</Context>
			<Text Lang="en">Max Length</Text>
			<Text Lang="uk">Максимальна довжина</Text>
			<Text Lang="fr">Longueur maximale</Text>
			<Text Lang="pt-BR">Extensão máxima</Text>
			<Text Lang="zh">最大长度</Text>
			<Text Lang="ko">최대 길이</Text>
			<Text Lang="pl">Maksymalna długość</Text>
			<Text Lang="es">Longitud máxima</Text>
			<Text Lang="it">Lunghezza massima</Text>
			<Text Lang="ru">Максимальная длина</Text>
			<Text Lang="de">Max. Länge</Text>
