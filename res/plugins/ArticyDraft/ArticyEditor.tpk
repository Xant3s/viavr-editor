			<Text Lang="fr">Transformation en partition</Text>
			<Text Lang="pt-BR">Transformando em partição</Text>
			<Text Lang="zh">转换为分区</Text>
			<Text Lang="ko">파티션으로 변환하는 중</Text>
			<Text Lang="pl">Zmiana w partycję</Text>
			<Text Lang="es">Transformando en partición</Text>
			<Text Lang="it">Trasformando in una partizione</Text>
			<Text Lang="ru">Превращение в раздел</Text>
			<Text Lang="de">In Partition umwandeln</Text>
		</TextDefinition>

		<TextDefinition Key="CreatePartition.InfoLine">
			<Context>Info line for the create partition progress dialog</Context>
			<Text Lang="en">Transforming object into a partition.</Text>
			<Text Lang="uk">Перетворення об'єкта в розділ.</Text>
			<Text Lang="fr">Transformation de l'objet en partition.</Text>
			<Text Lang="pt-BR">Transformando o objeto em partição.</Text>
			<Text Lang="zh">将对象转换为分区。</Text>
			<Text Lang="ko">객체를 파티션으로 변환하는 중입니다.</Text>
			<Text Lang="pl">Zmiana obiektu w partychę.</Text>
			<Text Lang="es">Transformando el objeto en una partición.</Text>
			<Text Lang="it">Trasformando l'oggetto in una partizione.</Text>
			<Text Lang="ru">Превращение объекта в раздел.</Text>
