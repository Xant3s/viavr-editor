			<Text Lang="es">Se puede llegar desde:</Text>
			<Text Lang="it">Può essere raggiunto da qui:</Text>
			<Text Lang="ru">Отсюда можно добраться до:</Text>
			<Text Lang="de">Schauplätze, auf die aus diesem Schauplatz verwiesen wird:</Text>
		</TextDefinition>

		<TextDefinition Key="LocatedStoryElements.Caption">
			<Context>label text of a reference strip in the location's property sheet; strip lists all links to flow elements</Context>
			<Text Lang="en">Flow nodes happening in this location:</Text>
