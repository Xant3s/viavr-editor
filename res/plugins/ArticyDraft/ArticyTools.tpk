			<Text Lang="en">Steam</Text>
			<Text Lang="uk">Steam</Text>
			<Text Lang="fr">Steam</Text>
			<Text Lang="pt-BR">Steam</Text>
			<Text Lang="zh">Steam</Text>
			<Text Lang="ko">스팀</Text>
			<Text Lang="de">Steam</Text>
			<Text Lang="ru">Steam</Text>
