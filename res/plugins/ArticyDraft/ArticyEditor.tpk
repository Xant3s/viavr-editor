			<Text Lang="pl">Można wprowadzić z:</Text>
			<Text Lang="es">Se accede desde:</Text>
			<Text Lang="it">Si può entrare da:</Text>
			<Text Lang="ru">Можно войти из:</Text>
			<Text Lang="de">Schauplätze, die auf diesen Schauplatz verweisen:</Text>
		</TextDefinition>

		<TextDefinition Key="OutgoingLocations.Caption">
			<Context>label text of a reference strip in the location's property sheet; strip lists all links to other locations</Context>
			<Text Lang="en">Outbound links to other locations:</Text>
			<Text Lang="uk">Посилання для виходу в інші локації:</Text>
