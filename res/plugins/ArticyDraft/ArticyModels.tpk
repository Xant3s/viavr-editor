			<Text Lang="fr">« {0} » ne doit pas être vide !</Text>
			<Text Lang="pt-BR">"{0}" não deve estar vazio!</Text>
			<Text Lang="zh">"{0}" 不能为空！</Text>
			<Text Lang="ko">"{0}"은(는) 비워 둘 수 없습니다!</Text>
			<Text Lang="pl">{0}' nie może być puste!</Text>
			<Text Lang="es">¡"{0}" no puede estar vacío!</Text>
			<Text Lang="it">"{0}" non può essere vuoto!</Text>
			<Text Lang="ru">"{0}" не должен быть пустым!</Text>
			<Text Lang="de">"{0}" darf nicht leer sein!</Text>
		</TextDefinition>

		<TextDefinition Key="TraitLocalizedStringNonEmptyValidator.Caption">
			<Context>Format string for the error message</Context>
			<Text Lang="en">"{0}" must not be empty!</Text>
			<Text Lang="uk">"{0}" не повинно бути порожнім!</Text>
			<Text Lang="fr">« {0} » ne doit pas être vide !</Text>
			<Text Lang="pt-BR">"{0}" não deve estar vazio!</Text>
			<Text Lang="zh">"{0}" 不能为空！</Text>
