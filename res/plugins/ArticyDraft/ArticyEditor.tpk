			<Text Lang="en">Insert a new chapter.</Text>
			<Text Lang="uk">Вставити новий розділ.</Text>
			<Text Lang="fr">Insérer un nouveau chapitre.</Text>
			<Text Lang="pt-BR">Inserir um novo capítulo.</Text>
			<Text Lang="zh">插入新章节。</Text>
			<Text Lang="ko">새 장을 삽입합니다.</Text>
			<Text Lang="pl">Wstaw nowy rozdział</Text>
			<Text Lang="es">Inserta un nuevo capítulo.</Text>
			<Text Lang="it">Inserisci un nuovo capitolo</Text>
			<Text Lang="ru">Вставить новую главу.</Text>
