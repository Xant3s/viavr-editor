		<TextDefinition Key="TechnicalName.Caption">
			<Context>Label in property editor</Context>
			<Text Lang="en">Technical name</Text>
			<Text Lang="uk">Технічна назва</Text>
			<Text Lang="fr">Nom technique</Text>
			<Text Lang="pt-BR">Nome técnico</Text>
			<Text Lang="zh">技术名称</Text>
			<Text Lang="ko">기술 이름</Text>
			<Text Lang="pl">Nazwa tehniczna</Text>
			<Text Lang="es">Nombre técnico</Text>
			<Text Lang="it">Nome Tecnico</Text>
			<Text Lang="ru">Техническое имя</Text>
			<Text Lang="de">Technischer Name</Text>
		</TextDefinition>

		<TextDefinition Key="TechnicalName.Description">
			<Context>Tooltip in property editor</Context>
			<Text Lang="en">This name is used to identify this property in queries and exports (like XML).</Text>
			<Text Lang="uk">Ця назва використовується для ідентифікації цієї властивості в запитах та експорті (як XML).</Text>
			<Text Lang="fr">Ce nom est utilisé pour identifier cette propriété dans les requêtes et les exportations (comme XML).</Text>
			<Text Lang="pt-BR">Este nome é usado para identificar esse propriedade em questões e exportações (como XML).</Text>
			<Text Lang="zh">此名称用于在查询和导出（如XML）中标识此属性。</Text>
			<Text Lang="ko">이 이름은 쿼리와 내보내기 (XML 등)에서이 속성을 식별 하는 데 사용 됩니다.</Text>
			<Text Lang="pl">Nazwa służąca do zidentyfikowania tej właściwości w pliku XML.</Text>
			<Text Lang="es">Este nombre se utiliza para identificar esta propiedad en la exportación XML.</Text>
			<Text Lang="it">Questo nome identifica questo attributo nel file XML esportato.</Text>
			<Text Lang="ru">Это имя используется для идентификации этого свойства в экспорте XML .</Text>
			<Text Lang="de">Dieser Name wird in Abfragen und einigen Exporten (z.B. XML) benutzt, um die Eigenschaft zu identifizieren.</Text>
		</TextDefinition>

		<TextDefinition Key="ToolTip.Caption">
			<Context>Label in property editor</Context>
			<Text Lang="en">Tooltip</Text>
			<Text Lang="uk">Підказка</Text>
			<Text Lang="fr">Infobulle</Text>
			<Text Lang="pt-BR">Barra de Ferramentas</Text>
			<Text Lang="zh">工具提示</Text>
			<Text Lang="ko">말풍선</Text>
			<Text Lang="pl">Podpowiedź</Text>
			<Text Lang="es">Descripción emergente</Text>
			<Text Lang="it">Suggerimento</Text>
			<Text Lang="ru">Подсказка</Text>
			<Text Lang="de">Tooltip</Text>
		</TextDefinition>

		<TextDefinition Key="ToolTip.Description">
			<Context>Tooltip in property editor</Context>
			<Text Lang="en">Tooltip displayed within articy:draft to describe the property.</Text>
			<Text Lang="uk">Інформація підказки відображається в articy:draft, щоб описати властивість.</Text>
			<Text Lang="fr">Infobulle affichée dans articy:draft pour décrire la propriété.</Text>
			<Text Lang="pt-BR">Barra de Ferramentas exibidas dentro de articy:draft para descrever a propriedade</Text>
			<Text Lang="zh">在 articy:draft 中显示工具提示用以描述属性。</Text>
			<Text Lang="ko">말풍선은 속성을 설명 하기 위해 articy:draft에 표시 됩니다.</Text>
			<Text Lang="pl">Podpowiedź wyświetlana w articy:draft do opisania właściwości.</Text>
			<Text Lang="es">Información mostrada en articy:draft para describir la propiedad.</Text>
			<Text Lang="it">Mostra i suggerimenti all'interno di articy:draft per descrivere gli attributi.</Text>
			<Text Lang="ru">Информация подсказки отображается в articy:draft, чтобы описать свойство.</Text>
			<Text Lang="de">In articy:draft angezeigter Tooltip zur Beschreibung der Eigenschaft.</Text>
		</TextDefinition>

		<TextDefinition Key="IsMandatory.Caption">
			<Context>Label in property editor</Context>
			<Text Lang="en">Is mandatory</Text>
			<Text Lang="uk">Є обов'язковим</Text>
			<Text Lang="fr">Est obligatoire</Text>
			<Text Lang="pt-BR">É mandatório</Text>
			<Text Lang="zh">强制属性</Text>
			<Text Lang="ko">필수</Text>
			<Text Lang="pl">Jest obowiązkowe</Text>
			<Text Lang="es">Es obligatoria</Text>
			<Text Lang="it">È obbligatorio</Text>
			<Text Lang="ru">Является обязательным</Text>
			<Text Lang="de">Ist zwingend</Text>
		</TextDefinition>

		<TextDefinition Key="IsMandatory.Description">
			<Context>Tooltip in property editor</Context>
			<Text Lang="en">Mandatory properties must have a value set.</Text>
			<Text Lang="uk">Обов'язкові властивості повинні мати значення.</Text>
			<Text Lang="fr">Les propriétés obligatoires doivent avoir une valeur déterminée.</Text>
			<Text Lang="pt-BR">Propriedades mandatórias devem ter um valor definido.</Text>
			<Text Lang="zh">强制属性必须设置值。</Text>
			<Text Lang="ko">필수 속성은 설정 값을 가지고 있어야 합니다.</Text>
			<Text Lang="pl">Obowiązkowe właściwości muszą mieć wartość</Text>
			<Text Lang="es">Las propiedades obligatorias no pueden dejarse vacías.</Text>
			<Text Lang="it">Gli attributi obbligatori devono avere un valore.</Text>
			<Text Lang="ru">Обязательные свойства должны иметь значение.</Text>
			<Text Lang="de">Für zwingende Eigenschaften muss ein Wert angegeben werden.</Text>
		</TextDefinition>

		<TextDefinition Key="IsExportRelevant.Caption">
			<Context>Label in property editor</Context>
			<Text Lang="en">Add to XML-export</Text>
			<Text Lang="uk">додати в експорт XML</Text>
			<Text Lang="fr">Ajouter à l’exportation XML</Text>
			<Text Lang="pt-BR">Adicionar ao exporte XML</Text>
			<Text Lang="zh">添加至XML导出</Text>
			<Text Lang="ko">XML 내보내기에 추가</Text>
			<Text Lang="pl">Dodaj do eksportu XML</Text>
			<Text Lang="es">Añadir a exportación XML</Text>
			<Text Lang="it">Aggiungi all'esportazione XML</Text>
			<Text Lang="ru">Добавить в экспорт XML</Text>
			<Text Lang="de">Dem XML-Export hinzufügen</Text>
		</TextDefinition>

		<TextDefinition Key="IsExportRelevant.Description">
			<Context>Tooltip in property editor</Context>
			<Text Lang="en">Shall articy:draft include this property in the XML export?</Text>
			<Text Lang="uk">Аarticy:draft повинен включити цю властивість при експорті XML?</Text>
			<Text Lang="fr">articy:draft doit-il inclure cette propriété dans l’exportation XML ?</Text>
			<Text Lang="pt-BR">Articy:draft deve incluir essa propriedade no exporte XML?</Text>
			<Text Lang="zh">articy:draft 是否应在XML导出中包含此属性？</Text>
			<Text Lang="ko">이 속성을 XML 내보내기에서 포함 해야 합니까?</Text>
			<Text Lang="pl">Czy artiy:draft powinien dołączać to właściwość do pliku XML?</Text>
