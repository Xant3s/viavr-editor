		<TextDefinition Key="AllowedAssets.Description">
			<Context>Tooltip in property editor</Context>
			<Text Lang="en">Allows changing the list of allowed assets.</Text>
			<Text Lang="uk">Дозволяє вам змінити список дозволених ресурсів.</Text>
			<Text Lang="fr">Autorise la modification de la liste des atouts autorisés.</Text>
