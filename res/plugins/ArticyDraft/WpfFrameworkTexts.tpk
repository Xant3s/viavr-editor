	<Category Name="System" Namespace=".Spellcheck">

		<TextDefinition Key="AddToIgnoreList.Caption">
			<Context>context menu entry for spellchecker, command that adds the given word ({0}) to the list of always ignored words</Context>
			<Text Lang="en">Add '{0}' to dictionary</Text>
			<Text Lang="uk">Додати '{0}' до словника</Text>
			<Text Lang="fr">Ajouter « {0} » au dictionnaire</Text>
			<Text Lang="pt-BR">Adicionar '{0}' ao dicionário</Text>
			<Text Lang="zh">将 '{0}' 添加至字典</Text>
			<Text Lang="ko">디렉토리에 '{0}' 추가</Text>
			<Text Lang="de">'{0}' zum Wörterbuch hinzufügen</Text>
		</TextDefinition>

		<TextDefinition Key="RemoveFromIgnoreList.Caption">
			<Context>context menu entry for spellchecker, command that removes the given word ({0}) from the list of always ignored words</Context>
