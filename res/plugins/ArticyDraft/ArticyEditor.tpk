		<TextDefinition Key="FileSize.DisplayFormat">
			<Context>text pattern for a textblock of an asset's property sheet; 0=file size in bytes</Context>
			<Text Lang="de">{0:N0} Bytes</Text>
			<Text Lang="uk">{0:N0} байт</Text>
			<Text Lang="pt-BR">{0:N0} bytes</Text>
			<Text Lang="zh">{0:N0} 字节</Text>
			<Text Lang="ko">{0:N0} 바이트</Text>
