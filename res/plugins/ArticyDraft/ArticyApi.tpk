		</TextDefinition>

		<TextDefinition Key="ParseError.ExpectedFromClause">
			<Context/>
			<Text Lang="en">Expecting 'FROM' clause, but reached end of text.</Text>
			<Text Lang="uk">Очікувався оператор 'FROM', але досягнуто кінеця тексту.</Text>
			<Text Lang="fr">Attend la clause 'FROM', mais atteint la fin du texte.</Text>
			<Text Lang="pt-BR">Esperando da cláusula 'FROM', mas alcançou fim de texto.</Text>
