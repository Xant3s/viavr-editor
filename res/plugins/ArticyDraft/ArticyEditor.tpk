		<TextDefinition Key="OfflineMode.Caption" Unused="1">
			<Context>caption text for the offline mode</Context>
			<Text Lang="en">offline mode</Text>
			<Text Lang="uk">Офлайн режим</Text>
			<Text Lang="fr">mode hors-ligne</Text>
			<Text Lang="pt-BR">Modo offline</Text>
			<Text Lang="zh">脱机模式</Text>
			<Text Lang="ko">오프라인 모드</Text>
			<Text Lang="pl">tryb offline</Text>
			<Text Lang="de">Offline-Modus</Text>
