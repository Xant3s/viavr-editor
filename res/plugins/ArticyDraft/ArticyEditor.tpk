		<TextDefinition Key="Command.RemoveWorkingCopy.Description">
			<Context>Description for the "remove project folder" command</Context>
			<Text Lang="en">Remove project folder</Text>
			<Text Lang="uk">Вилучити папку проекту</Text>
			<Text Lang="fr">Supprimer le dossier du projet</Text>
			<Text Lang="pt-BR">Remover pasta de projeto</Text>
