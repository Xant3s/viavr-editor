			<Text Lang="zh">[col=white]创建分区 "[/col][col=#FF71A0A0]{0}[/col][col=white]"[/col]</Text>
			<Text Lang="ko"><![CDATA[[col=white]파티션 생성 "[/col][col=#FF71A0A0]{0}[/col][col=white]"[/col]
]]></Text>
			<Text Lang="pl">[col=white]Stwórz partycję'[/col][col=#FF1A0A0]{0}[/col][col=white]'[/col]</Text>
			<Text Lang="es">[col=white]Crear partición "[/col][col=#FF71A0A0]{0}[/col][col=white]"[/col]</Text>
			<Text Lang="it">[col=white]Crea partizione "[/col][col=#FF71A0A0]{0}[/col][col=white]"[/col]</Text>
