	<!--
	  IModelBase
	-->
	<Category Name="System" Namespace=".IModelBase">

		<TextDefinition Key="DisplayName.Caption">
			<Context>Display name of the property DisplayName of the class "Articy.ModelFramework.BaseModel".</Context>
			<Text Lang="en">Name</Text>
			<Text Lang="uk">Назва</Text>
			<Text Lang="fr">Nom</Text>
			<Text Lang="pt-BR">Nome</Text>
			<Text Lang="zh">名称</Text>
			<Text Lang="ko">이름</Text>
			<Text Lang="pl">Nazwa</Text>
			<Text Lang="es">Nombre</Text>
			<Text Lang="it">Nome</Text>
			<Text Lang="ru">Имя</Text>
			<Text Lang="de">Name</Text>
		</TextDefinition>

		<TextDefinition Key="DisplayName.Description">
			<Context>Description of the property DisplayName of the class "Articy.ModelFramework.BaseModel".</Context>
			<Text Lang="en">The displayed name of this node.</Text>
			<Text Lang="uk">Відображувана назва цієї вітки.</Text>
			<Text Lang="fr">Le nom affiché de ce nœud.</Text>
			<Text Lang="pt-BR">O nome do nó exibido</Text>
			<Text Lang="zh">此节点的显示名称。</Text>
			<Text Lang="ko">이 노드의 표시될 이름</Text>
			<Text Lang="pl">Wyświetlana nazwa dla tego węzła</Text>
			<Text Lang="es">El nombre de visualización este nodo.</Text>
			<Text Lang="it">Il nome visualizzato su questo snodo.</Text>
			<Text Lang="ru">Отображаемое имя этого узла.</Text>
			<Text Lang="de">Der angezeigte Name für diesen Knoten.</Text>
		</TextDefinition>

		<TextDefinition Key="Id.Caption">
			<Context>Display name of the property Id of the class "Articy.ModelFramework.BaseModel".</Context>
			<Text Lang="en">Id</Text>
			<Text Lang="uk">ID</Text>
			<Text Lang="fr">Identité</Text>
			<Text Lang="pt-BR">id</Text>
			<Text Lang="zh">ID</Text>
			<Text Lang="ko">ID</Text>
			<Text Lang="pl">ID</Text>
			<Text Lang="es">Id</Text>
			<Text Lang="it">Id</Text>
			<Text Lang="ru">ID</Text>
			<Text Lang="de">Id</Text>
		</TextDefinition>

		<TextDefinition Key="Id.Description">
			<Context>Description of the property Id of the class "Articy.ModelFramework.BaseModel".</Context>
			<Text Lang="en">A unique ID used to identify this node.</Text>
			<Text Lang="uk">Унікальний ID, що використовується для ідентифікації цієї вітки.</Text>
			<Text Lang="fr">Identité unique utilisée pour identifier ce nœud.</Text>
			<Text Lang="pt-BR">Um ID único utilizado para identificar esse nó.</Text>
			<Text Lang="zh">用于标识此节点的唯一ID。</Text>
			<Text Lang="ko">이 노드를 식별 하는 데 사용 되는 고유 ID입니다.</Text>
			<Text Lang="pl">Unikalne ID używane do rozpoznania tego węzła</Text>
			<Text Lang="es">Un identificador único utilizado para identificar este nodo.</Text>
			<Text Lang="it">Un identificatore (ID) unico per identificare questo snodo.</Text>
			<Text Lang="ru">Уникальный ID используемый для  идентификации этого узла.</Text>
			<Text Lang="de">Eine eindeutige ID um diesen Knoten zu identifizieren.</Text>
		</TextDefinition>

	</Category>

