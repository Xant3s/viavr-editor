		<TextDefinition Key="Trait.InnerConflict.Caption">
			<Context>Property name of "entity" node.</Context>
			<Text Lang="en">Inner Conflict</Text>
			<Text Lang="uk">Внутрішній конфлікт</Text>
			<Text Lang="fr">Conflit interne</Text>
			<Text Lang="pt-BR">Conflito interno</Text>
