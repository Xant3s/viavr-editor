{
  "name": "viavr-editor",
  "version": "0.3.2",
  "description": "VIA-VR Editor",
  "author": "Games Engineering Research Group, University of Wuerzburg",
  "license": "Apache-2.0",
  "main": "build/backend/main.js",
  "homepage": ".",
  "private": true,
  "scripts": {
    "postinstall": "electron-builder install-app-deps && npm run installSpoke && npm run installNearSpark && npm run installReticulum && npm run installVerdaccio",
    "postinstall:linux": "electron-builder install-app-deps && npm run installSpoke",
    "prestart": "npm run build:backend",
    "start": "concurrently --kill-others \"cross-env BROWSER=none npm run start:frontend\" \"wait-on http://localhost:3000 && npm run watch:backend\" \"wait-on http://localhost:3000 && npm run build:backend && electron .\" ",
    "start:frontend": "react-app-rewired start",
    "build:all": " npm run build:frontend && npm run build:backend",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build:frontend": "react-app-rewired build",
    "watch:backend": "tsc -w -p backend/tsconfig.json",
    "package": "npm i && npm run build:all && electron-builder build",
    "package:win": "npm i && npm run build:all && electron-builder build --win",
    "package:linux": "npm run build:all && electron-builder build --linux",
    "package:mac": "npm run build:all && electron-builder build --mac",
    "test": "mocha --config test/.mocharc.jsonc",
    "lint": "eslint --ext .ts,.tsx backend frontend",
    "clean": "rimraf ./build ./dist",
    "eject": "react-scripts eject",
    "installSpoke": "cd res/plugins/spoke && yarn install --ignore-scripts --registry https://registry.npmjs.org",
    "installReticulum": "powershell -Command \"cd ./res/plugins/viavr-reticulum; ./run_check_install.ps1\"",
    "runReticulumWithChecks": "powershell -Command \"cd ./res/plugins/viavr-reticulum; ./run_Windows_Reticulum.ps1\"",
    "runReticulum": "powershell -Command \"cd ./res/plugins/viavr-reticulum; ./run_reticulum_without_checks.ps1\"",
    "installNearSpark": "cd ./res/plugins/viavr-nearspark && npm install",
    "runNearSpark": "cd ./res/plugins/viavr-nearspark && node app.js",
    "installVerdaccio": "cd res/plugins/verdaccio-package-registry && npm install"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.0",
    "@types/chai": "^5.0.1",
    "@types/jquery": "^3.5.14",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.4",
    "@types/node-fetch": "^2.6.4",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^5.51.0",
    "@typescript-eslint/parser": "^5.51.0",
    "chai": "^5.2.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^18.2.3",
    "electron-builder": "^25.1.8",
    "electron-reloader": "^1.2.3",
    "eslint": "^8.33.0",
    "eslint-plugin-react": "^7.32.2",
    "mocha": "^11.1.0",
    "npm-run-all": "^4.1.5",
    "react-app-rewired": "^2.2.1",
    "rimraf": "^6.0.1",
    "ts-mockito": "^2.6.1",
    "ts-node": "^10.7.0",
    "typescript": "^4.6.4",
    "wait-on": "^8.0.2"
  },
  "dependencies": {
    "@egjs/react-view3d": "^2.3.1",
    "@emotion/react": "^11.9.3",
    "@emotion/styled": "^11.9.3",
    "@hello-pangea/dnd": "^18.0.1",
    "@mui/icons-material": "^6.4.4",
    "@mui/material": "^6.4.4",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/electron-devtools-installer": "^4.0.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "adm-zip": "^0.5.9",
    "compare-versions": "^6.1.0",
    "electron-devtools-installer": "^4.0.0",
    "electron-is-dev": "^3.0.1",
    "electron-reload": "^2.0.0-alpha.1",
    "evergreen-ui": "^7.1.9",
    "extract-zip": "^2.0.1",
    "flexlayout-react": "^0.8.2",
    "fs-extra": "^11.3.0",
    "jquery": "^3.6.0",
    "node-fetch": "^2.6.7",
    "qrcode": "^1.5.1",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "react-icons": "^5.4.0",
    "react-inlinesvg": "^3.0.1",
    "react-router-dom": "^6.3.0",
    "react-scripts": "5.0.1",
    "react-tooltip": "^5.21.5",
    "reactflow": "^11.6.0",
    "styled-components": "^6.1.15",
    "tree-kill": "^1.2.2",
    "uuid": "^11.0.5",
    "web-vitals": "^2.1.4"
  },
  "build": {
    "extends": null,
    "extraResources": [
      "res/**/*"
    ],
    "fileAssociations": [
      {
        "ext": [
          "via"
        ],
        "name": "VIA-VR Project",
        "description": "VIA-VR Project"
      }
    ],
    "files": [
      "build/**/*"
    ],
    "directories": {
      "buildResources": "res"
    },
    "asarUnpack": [
      "**/*.node"
    ],
    "buildDependenciesFromSource": true,
    "npmRebuild": true,
    "nsis": {
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": false,
      "include": "res/installer.nsh"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "packageManager": "yarn@1.22.19+sha1.4ba7fc5c6e704fce2066ecbfb0b0d8976fe62447"
}
