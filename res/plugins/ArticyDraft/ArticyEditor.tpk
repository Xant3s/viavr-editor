			<Text Lang="es">[col=white]Eliminar partición "[/col][col=#FF71A0A0]{0}[/col][col=white]"[/col]</Text>
			<Text Lang="it">[col=white]Ritira partizione "[/col][col=#FF71A0A0]{0}[/col][col=white]"[/col]</Text>
