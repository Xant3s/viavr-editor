			<Text Lang="fr">Mettre à jour et revendiquer</Text>
			<Text Lang="pt-BR">Atualizar e reivindicar</Text>
			<Text Lang="zh">更新并认领</Text>
			<Text Lang="ko">업데이트 및 할당</Text>
			<Text Lang="pl">Zaktualizuj i zażądaj</Text>
