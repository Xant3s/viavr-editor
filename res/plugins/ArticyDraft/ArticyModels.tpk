			<Text Lang="fr">Nom affiché</Text>
			<Text Lang="pt-BR">Nome de exibição</Text>
			<Text Lang="zh">显示名称</Text>
			<Text Lang="ko">표시 이름</Text>
			<Text Lang="pl">Nazwa wyświetlana</Text>
			<Text Lang="es">Nombre visible</Text>
			<Text Lang="it">Nome visualizzato</Text>
