			<xs:element name="Outline" type="ad:OutlineType" />
			<xs:element name="ShowDisplayName" type="xs:boolean" />
			<xs:element name="DisplayNameColor" type="ad:ColorType" />
			<xs:element name="DisplayNameSize" type="xs:int" />
			<xs:element name="DropShadow" type="xs:boolean" />
			<xs:element name="DisplayNamePosition" type="ad:PointType" />
