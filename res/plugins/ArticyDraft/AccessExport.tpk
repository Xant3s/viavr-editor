		<TextDefinition Key="Exception.UnknownInternalType">
			<Context>Class type (e.g. "FlowFragment") is not valid</Context>
			<Text Lang="en">Unknown internal type: {0}.</Text>
			<Text Lang="uk">Невідомий внутрішній тип: {0}.</Text>
			<Text Lang="fr">Type interne inconnu : {0}.</Text>
			<Text Lang="pt-BR">Tipo interno desconhecido: {0}.</Text>
			<Text Lang="zh">未知的内部类型： {0}。</Text>
			<Text Lang="ko">알 수 없는 내부 유형: {0}</Text>
			<Text Lang="pl">Nieznany typ wewnętrzny: {0}.</Text>
			<Text Lang="es">Tipo interno desconocido: {0}.</Text>
			<Text Lang="it">Tipo interno sconosciuto: {0}</Text>
			<Text Lang="ru">Неизвестный внутренний тип: {0}.</Text>
			<Text Lang="de">Unbekannter interner Typ: {0}.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.DoubleClassMapping">
			<Context>Mapping of a class to a class layout</Context>
			<Text Lang="en">Type "{0}" is already mapped to a class.</Text>
			<Text Lang="uk">Тип "{0}" вже відноситься до класу.</Text>
			<Text Lang="fr">Le type "{0}" est déjà cartographié sur une classe.</Text>
			<Text Lang="pt-BR">Tipo {0} já está mapeado em uma classe.</Text>
			<Text Lang="zh">类型 "{0}" 已映射至指定类。</Text>
			<Text Lang="ko">{0} 유형은 이미 클래스에 매핑 되어 있습니다.</Text>
			<Text Lang="pl">Typ '{0}' jest już przyporządkowany do klasy.</Text>
			<Text Lang="es">El tipo "{0}" ya se ha mapeado.</Text>
			<Text Lang="it">Il tipo "{0}" è già mappato su una classe.</Text>
			<Text Lang="ru">Тип "{0}" уже относится к классу.</Text>
			<Text Lang="de">Dem Typ "{0}" wurde bereits eine Klasse zugewiesen.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.DoubleTemplateMapping">
			<Context>Mapping of a template to a template layout</Context>
			<Text Lang="en">Template "{0}" is already been assigned a layout.</Text>
			<Text Lang="uk">Шаблону "{0}" вже призначена розмітка.</Text>
			<Text Lang="fr">Le modèle "{0}" a déjà été assigné une disposition.</Text>
			<Text Lang="pt-BR">Módulo "{0}" já está atribuído para um layout.</Text>
			<Text Lang="zh">模板 "{0}" 已分配至指定布局。</Text>
			<Text Lang="ko">템플릿 "{0}"이(가) 이미 레이아웃에 할당되었습니다.</Text>
			<Text Lang="pl">Szablon '{0}' jest już przypisany jako układ.</Text>
			<Text Lang="es">La plantilla "{0}" ya tiene un espacio de trabajo asignado.</Text>
			<Text Lang="it">Il template "{0}" è già stato assegnato a un layout.</Text>
			<Text Lang="ru">Шаблону "{0}" уже назначена разметка.</Text>
			<Text Lang="de">Dem Template "{0}" wurde bereits ein layout zugewiesen.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.NoExportConvention">
			<Context/>
			<Text Lang="en">Access type "{0}" has no export convention.</Text>
			<Text Lang="uk">Тип "{0}" не конвертований для експорта.</Text>
			<Text Lang="fr">Le type d'accès "{0}" n'a pas de convention d'exportation.</Text>
			<Text Lang="pt-BR">Acesso tipo "{0}" não tem convensão de exportação.</Text>
			<Text Lang="zh">访问类型 "{0}" 没有导出协议。</Text>
			<Text Lang="ko">액세스 유형 "{0}"에는 내보내기 규칙이 없습니다.</Text>
			<Text Lang="pl">Typ dostępu '{0}' nie ma konwencji eksportu.</Text>
			<Text Lang="es">El tipo de acceso "{0}" no tiene convención de exportación.</Text>
			<Text Lang="it">Il tipo di accesso "{0}" non ha specifiche sull'esportazione.</Text>
			<Text Lang="ru">Тип "{0}" не конвертирован для экспорта.</Text>
			<Text Lang="de">Für Access-Typ "{0}" ist keine Export-Regel vorhanden.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.UnsupportedType">
			<Context/>
			<Text Lang="en">Unsupported datatype "{0}" for property "{1}".</Text>
			<Text Lang="uk">Властивість "{1}" не підтримує тип даних "{0}".</Text>
			<Text Lang="fr">Type de données non pris en charge "{0}" pour la propriété "{1}".</Text>
			<Text Lang="pt-BR">Tipo de dados não suportado "{0}" por propriedade "{1}".</Text>
			<Text Lang="zh">不支持属性"{1}"的数据类型"{0}" 。</Text>
			<Text Lang="ko">"{1}" 속성에 대해 지원되지 않는 데이터 유형 유형"{0}"입니다.</Text>
			<Text Lang="pl">Nieobsługiwany typ danych '{0}' właściwości '{1}'.</Text>
			<Text Lang="es">Tipo de dato "{0}" no soportado para la propiedad "{1}".</Text>
			<Text Lang="it">Tipo di dato "{0}" non supportato per l'attributo "{1}".</Text>
			<Text Lang="ru">Свойством "{1}" не поддерживается тип данных "{0}".</Text>
			<Text Lang="de">Der Datentyp "{0}" wird von property "{1}" nicht unterstützt.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.UnknownPropertyType">
			<Context/>
			<Text Lang="en">Unknown internal type property "{0}".</Text>
			<Text Lang="uk">Невідома властивість внутрішнього типу "{0}".</Text>
			<Text Lang="fr">Propriété de type interne inconnue "{0}".</Text>
			<Text Lang="pt-BR">Tipo de propriedade interna desconhecida "{0}".</Text>
			<Text Lang="zh">未知的内部类型属性 "{0}"。</Text>
			<Text Lang="ko">알 수 없는 내부 유형 속성 "{0}"입니다.</Text>
			<Text Lang="pl">Nieznany wewnętrzny typ właściwości '{0}'.</Text>
			<Text Lang="es">Tipo de propiedad interna desconocida "{0}".</Text>
			<Text Lang="it">Tipo di attributo interno "{0}" sconosciuto.</Text>
			<Text Lang="ru">Неизвестное свойство внутреннего типа "{0}".</Text>
			<Text Lang="de">Unbekannter interner Datentyp "{0}".</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.TraitNotQualified">
			<Context/>
			<Text Lang="en">Trait names must be fully qualified, e.g. "feature.trait". "{0}" is not fully qualified.</Text>
			<Text Lang="uk">Назви рис необхідно повністю кваліфікувати,наприклад: "особливість.риса". "{0}" не повністю кваліфікована.</Text>
			<Text Lang="fr">Les noms des traits doivent être pleinement qualifiés, par ex. "feature.trait". "{0}" n'est pas entièrement qualifié.</Text>
			<Text Lang="pt-BR">Nomes de características devem ser completamente qualificadas, exemplo "feature.trait". "{0}" não é completamente qualificado.</Text>
			<Text Lang="zh">特征名称必须完全符合限制，例如 "feature.trait"。 "{0}" 不完全符合限制。</Text>
			<Text Lang="ko">특성 이름은 "feature.trait"과 같이 완전히 검증되어야 합니다. {0}은(는) 완전히 검증되지 않았습니다.</Text>
			<Text Lang="pl">Nazwy cechy, muszą zostać w pełni klasyfikujące, np 'funkcja.cecha'. '{0}' nie jest w pełni klasyfikujący.</Text>
			<Text Lang="es">Los nombres de rasgo deben estar completamente calificados ("característica.rasgo"). "{0}" no está completamente calificado.</Text>
			<Text Lang="it">Il nome della caratteristica deve essere completamente definito, per esempio "caratteristica.tratto". "{0}" non è completamente definito.</Text>
			<Text Lang="ru">Названия черт должны быть полностью определены, пример :  "особенность.черта".  "{0}" не полностью определено.</Text>
			<Text Lang="de">Eigenschaften müssen immer vollständig referenziert angegeben werden (z.B. "feature.trait"). "{0}" ist nicht vollständig.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.UnknownFeature">
			<Context/>
			<Text Lang="en">Feature "{0}" does not exist.</Text>
			<Text Lang="uk">Особливість "{0}" не існує.</Text>
			<Text Lang="fr">La fonction "{0}" n'existe pas.</Text>
			<Text Lang="pt-BR">Utilidade "{0}" não existe.</Text>
			<Text Lang="zh">特性 "{0}" 不存在。</Text>
			<Text Lang="ko">"{0}" 기능이 없습니다.</Text>
			<Text Lang="pl">Funkcja '{0}' nie istnieje.</Text>
			<Text Lang="es">La característica "{0}" no existe.</Text>
			<Text Lang="it">La caratteristica "{0}" non esiste.</Text>
			<Text Lang="ru">Особенность "{0}" не существует.</Text>
			<Text Lang="de">Feature "{0}" konnte nicht gefunden werden.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.TemplateFeatureMissing">
			<Context/>
			<Text Lang="en">Template "{0}" does not contain feature "{1}".</Text>
			<Text Lang="uk">Шаблон "{0}" не містить особливості "{1}".</Text>
			<Text Lang="fr">Le modèle "{0}" ne contient pas la fonction "{1}".</Text>
			<Text Lang="pt-BR">Módulo "{0}" não contém utilidade "{1}".</Text>
			<Text Lang="zh">模板 "{0}" 不包含特性 "{1}"。</Text>
			<Text Lang="ko">템플릿 "{0}"에는 "{1}" 기능이 없습니다.</Text>
			<Text Lang="pl">Szablon '{0}' nie zawiera funkcji '{1}'.</Text>
			<Text Lang="es">La plantilla "{0}" no contiene la característica "{1}".</Text>
			<Text Lang="it">Il template "{0}" non contiene la caratteristica "{1}".</Text>
			<Text Lang="ru">Шаблон "{0}" не содержит особенность "{1}".</Text>
			<Text Lang="de">Das Template "{0}" enthält kein Feature "{1}".</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.TemplateTraitMissing">
			<Context/>
			<Text Lang="en">Template "{0}" does not contain trait "{1}".</Text>
			<Text Lang="uk">Шаблон "{0}" не містить рису "{1}".</Text>
			<Text Lang="fr">Le modèle "{0}" ne contient pas le trait "{1}".</Text>
			<Text Lang="pt-BR">Módulo "{0}" não contém utilidade "{1}".</Text>
			<Text Lang="zh">模板 "{0}" 不包含特征 "{1}"。</Text>
			<Text Lang="ko">템플릿 "{0}"에 특성 "{1}"이 없습니다.</Text>
			<Text Lang="pl">Szablon '{0}' nie zawiera cechy '{1}'.</Text>
			<Text Lang="es">La plantilla "{0}" no contiene el rasgo "{1}".</Text>
			<Text Lang="it">Il template "{0}" non contiene la caratteristica "{1}".</Text>
			<Text Lang="ru">Шаблон "{0}" не содержит черту "{1}".</Text>
			<Text Lang="de">Das Template "{0}" enthält keinen Trait "{1}".</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.UnknownTraitType">
			<Context/>
			<Text Lang="en">Unknown type "{0}" for trait "{1}".</Text>
			<Text Lang="uk">Невідомий тип "{0}" риси "{1}".</Text>
			<Text Lang="fr">Type inconnu "{0}" pour le trait "{1}".</Text>
			<Text Lang="pt-BR">Tipo desconhecido "{0}" de característica "{1}".</Text>
			<Text Lang="zh">特征 "{1}"的类型"{0}"未知。</Text>
			<Text Lang="ko">특성 "{1}"에 대한 알 수 없는 유형 "{0}"입니다.</Text>
			<Text Lang="pl">Nieznany typ '{0}' dla cechy '{1}'.</Text>
			<Text Lang="es">Tipo "{0}" desconocido para el rasgo "{1}".</Text>
			<Text Lang="it">Tipo "{0}" sconosciuto per la caratteristica "{1}".</Text>
			<Text Lang="ru">Неизвестный тип "{0}" черты "{1}".</Text>
			<Text Lang="de">Unbekannter Typ "{0}" für Trait "{1}".</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.InvalidTypeDeduction">
			<Context>Don't localize "TypeDeduction" it refers to a so named tag in the XML</Context>
			<Text Lang="en">The "TypeDeduction" attribute may only be used for number types.</Text>
			<Text Lang="uk">Атрибут "TypeDeduction" може використовуватися лише для типів чисел.</Text>
			<Text Lang="fr">L'attribut "Déduction de type" ne peut être utilisé que pour les types de nombres.</Text>
			<Text Lang="pt-BR">O atributo "TypeDeduction" pode apenas ser usado por tipos de número.</Text>
			<Text Lang="zh">"TypeDeduction" 属性仅用于数值类型。</Text>
			<Text Lang="ko">TypeDeduction 속성은 숫자 유형에만 사용할 수 있습니다.</Text>
			<Text Lang="pl">Atrybut 'TypeDeduction' może być wykorzystany jedynie do typów liczbowych.</Text>
			<Text Lang="es">El atributo "TypeDeduction" solo puede usarse en tipos numéricos.</Text>
			<Text Lang="it">L'attributo "TypeDeduction" può essere usato solo per tipi numerici.</Text>
			<Text Lang="ru">Атрибут "TypeDeduction" может быть использован только для типов чисел.</Text>
			<Text Lang="de">Das Attribut "TypeDeduction" darf nur mit Zahlentypen verwendet werden.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.HashCollision">
			<Context/>
			<Text Lang="en">Hash collision detected: {{{0}}} {1}</Text>
			<Text Lang="uk">Виявлено хеш колізію: {{{{0}}} {1}</Text>
			<Text Lang="fr">Collision de hachage détectée: {{{0}}} {1}</Text>
			<Text Lang="pt-BR">Colisão grave detectada: {{{0}}} {1}</Text>
			<Text Lang="zh">检测到哈希冲突： {{{0}}} {1}</Text>
			<Text Lang="ko">해시 충돌 감지됨: {{{0}}} {1}</Text>
			<Text Lang="pl">Wykryto kolizję hashów: {{{0}}} {1}</Text>
			<Text Lang="es">Se ha detectado una colisión de hash: {{{0}}} {1}</Text>
			<Text Lang="it">Collisione hash identificata: {{{0}}} {1}</Text>
			<Text Lang="ru">Обнаружено хэш столкновение: {{{0}}} {1}</Text>
			<Text Lang="de">Hash-Kollision entdeckt: {{{0}}} {1}</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.HashResolve">
			<Context/>
			<Text Lang="en">The following objects have not been exported because of hash collisions</Text>
			<Text Lang="uk">Внаслідок хеш колізії наступні об'єкти не були експортовані</Text>
			<Text Lang="fr">Les objets suivants n'ont pas été exportés en raison de collisions de hachage</Text>
			<Text Lang="pt-BR">Os objetos seguintes não foram exportados por conta de colisões graves</Text>
			<Text Lang="zh">由于哈希冲突，以下对象尚未导出</Text>
			<Text Lang="ko">해시 충돌로 인해 다음 객체를 내보내지 않았습니다.</Text>
			<Text Lang="pl">Następujące obiekty nie zostały wyeksportowane z powodu kolizji hashy</Text>
			<Text Lang="es">Los siguientes objetos no han sido exportados debido a colisiones de hash:</Text>
			<Text Lang="it">I seguenti oggetti non sono stati esportati a causa di collisioni hash</Text>
			<Text Lang="ru">Из-за столкновений в хэше эти объекты не могли быть экспортированы</Text>
			<Text Lang="de">Die folgenden Objekte wurden aufgrund von Hash-Kollisionen nicht exportiert</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.HashCollisionLogged">
			<Context/>
			<Text Lang="en">All hash collisions have been logged to {0}.</Text>
			<Text Lang="uk">Усі хеш колізії збережені в журналі {0}.</Text>
			<Text Lang="fr">Toutes les collisions de hachage ont été enregistrées dans {0}.</Text>
			<Text Lang="pt-BR">Todas as colisões graves foram logadas para {0}.</Text>
			<Text Lang="zh">所有哈希冲突已被记录至 {0}。</Text>
			<Text Lang="ko">모든 해시 충돌이 {0}에 기록되었습니다.</Text>
			<Text Lang="pl">Wszystkie kolizje hashy zostały zarejestrowane do {0}.</Text>
			<Text Lang="es">Todas las colisiones de hash se han registrado en {0}.</Text>
			<Text Lang="it">Tutte le collisioni hash sono state raccolte in {0}.</Text>
			<Text Lang="ru">Все хэш столкновения были сохранены журнале в {0}.</Text>
			<Text Lang="de">Alle Hash-Kollision wurden in die Datei {0} geschrieben.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.UnknownExporterType">
			<Context/>
			<Text Lang="en">No plugin supporting export format {0} has been loaded.</Text>
			<Text Lang="uk">Не завантажено плагін, що підтримує формат експорту {0}.</Text>
			<Text Lang="fr">Aucun plug-in prenant en charge le format d'exportation {0} n'a été chargé.</Text>
			<Text Lang="pt-BR">Nenhum formato de exportação com suporta a plugin {0} foi carregado.</Text>
			<Text Lang="zh">未加载支持导出格式 {0} 的插件。</Text>
			<Text Lang="ko">내보내기 형식 {0}을(를) 지원하는 플러그인이 로드되지 않았습니다.</Text>
			<Text Lang="pl">Wtyczka z obsługą formatu eksportu {0} nie została załadowana.</Text>
			<Text Lang="es">No se ha cargado ningún plugin que soporte el formato de exportación {0}.</Text>
			<Text Lang="it">Nessun plugin per il supporto all'esportazione del formato {0} è stato caricato.</Text>
			<Text Lang="de">Es wurde kein plugin geladen, welches Exporter-Format {0} unterstützt.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.MissingNameAttribute">
			<Context>Error when a the "Name" attribute is missing in the XML. REMARK: don't localize "Name"!</Context>
			<Text Lang="en">All code generator option tags must contain an attribute called "Name".</Text>
			<Text Lang="uk">Усі теги параметрів генератора коду повинні містити атрибут під назвою "Name".</Text>
			<Text Lang="fr">Toutes les balises d'option du générateur de code doivent contenir un attribut appelé "Nom".</Text>
			<Text Lang="pt-BR">Todas as etiquetas de opção de gerador de códigos devem conter um atributo chamada "Name".</Text>
			<Text Lang="zh">所有代码生成器选项标签都必须包含名为"Name"的属性。</Text>
			<Text Lang="ko">모든 코드 생성기 옵션 태그에는 "이름"이라는 속성이 있어야 합니다.</Text>
			<Text Lang="pl">Wszystkie tagi opcji generatora kodu muszą zawierać atrybut o nazwie 'Name'.</Text>
			<Text Lang="es">Todas las etiquetas de opciones de generadores de código deben incluir un atributo con el nombre "Name".</Text>
			<Text Lang="it">Tutte le tag delle opzioni dei generatori di codice devono contenere un attributo chiamato "Name".</Text>
			<Text Lang="de">Alle option Tags eines Code-Generators müssen ein Attribute "Name" besitzen.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.MissingValueAttribute">
			<Context>Error when a the "Value" attribute is missing in the XML. REMARK: don't localize "Value"!</Context>
			<Text Lang="en">All code generator option tags must contain an attribute called "Value".</Text>
			<Text Lang="uk">Усі теги параметрів генератора коду повинні містити атрибут під назвою "Value".</Text>
			<Text Lang="fr">Toutes les balises d'option du générateur de code doivent contenir un attribut appelé "Valeur".</Text>
			<Text Lang="pt-BR">Todas as etiquetas de opção de gerador de códigos devem conter um atributo chamado "Value".</Text>
			<Text Lang="zh">所有代码生成器选项标签都必须包含名为"Value"的属性。</Text>
			<Text Lang="ko">모든 코드 생성기 옵션 태그에는 "값"이라는 속성이 있어야 합니다.</Text>
			<Text Lang="pl">Wszystkie tagi opcji generatora kodu muszą zawierać atrybut o nazwie 'Value'.</Text>
			<Text Lang="es">Todas las etiquetas de opciones de generadores de código deben incluir un atributo con el nombre "Value".</Text>
			<Text Lang="it">Tutte le tag delle opzioni dei generatori di codice devono contenere un attributo chiamato "Value".</Text>
			<Text Lang="de">Alle option Tags eines Code-Generators müssen ein Attribute "Value" besitzen.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.UnknownCodeGenerator">
			<Context/>
			<Text Lang="en">Unknown code generator "{0}".</Text>
			<Text Lang="uk">Невідомий генератор коду "{0}".</Text>
			<Text Lang="fr">Code générateur "{0}" inconnu.</Text>
			<Text Lang="pt-BR">Gerador de código desconhecido "{0}".</Text>
			<Text Lang="zh">未知代码生成器 "{0}"。</Text>
			<Text Lang="ko">알 수 없는 코드 생성기 "{0}"입니다.</Text>
			<Text Lang="pl">Nieznany generator kodu '{0}'.</Text>
			<Text Lang="es">Generador de código desconocido "{0}".</Text>
			<Text Lang="it">Generatore di codice "{0}" sconosciuto.</Text>
			<Text Lang="de">Unbekannter Code-Generator "{0}".</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.WrongValue">
			<Context>Error when a wrong code generator value is encountered. {0}: the wrong value, {1}: the property for the value. REMARK: don't localize "None", "Classes", "Templates" or "Both"!</Context>
			<Text Lang="en">A value of "{0}" is invalid. It must either be "None", "Classes", "Templates" or "Both".</Text>
			<Text Lang="uk">Значення "{0}" не дійсне. Воно повинно бути "None", "Classes", "Templates" або "Both".</Text>
			<Text Lang="fr">Une valeur de "{0}" n'est pas valide. Il doit s'agir de "Aucun", "Classes", "Modèles" ou "Les deux".</Text>
			<Text Lang="pt-BR">Um valor de "{0}" é inválido. Deve ser "None", "Classes", "Templates" ou "Both".</Text>
			<Text Lang="zh">"{0}" 的值无效。它必须是 "None"、 "Classes"、 "Templates" 或 "Both"其中之一。</Text>
			<Text Lang="ko">{0} 값이 잘못되었습니다. "없음", "클래스", "템플릿" 또는 "둘 다" 이어야 합니다.</Text>
			<Text Lang="pl">Wartość '{0}' jest nieprawidłowa. Musi być ona równa 'None', 'Classes', 'Templates' lub 'Both'.</Text>
			<Text Lang="es">El valor de "{0}" no es válido. Debe ser "None", "Classes", "Templates" o "Both".</Text>
			<Text Lang="it">Un valore di "{0}" non è valido. Deve essere "None", "Classes", "Templates" o "Both".</Text>
			<Text Lang="de">Der Wert "{0}" ist ungültig. Er muss entweder "None", "Classes", "Templates" oder "Both" sein.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.WrongBool">
			<Context>Error when a wrong boolean value is encountered. {0}: the wrong value, {1}: the property for the value. REMARK: don't localize "True" and "False"!</Context>
			<Text Lang="en">A value of "{0}" is invalid. It must either be "True" or "False".</Text>
			<Text Lang="uk">Значення "{0}" не дійсне. Воно повинно бути "True" або "False".</Text>
			<Text Lang="fr">Une valeur de "{0}" n'est pas valide. Il doit être soit "Vrai" soit "Faux".</Text>
			<Text Lang="pt-BR">Um valor de "{0}" é inválido. Deve ser "True" ou "False".</Text>
			<Text Lang="zh">"{0}" 的值无效。它必须是 "True" 或 "False"。</Text>
			<Text Lang="ko">{0} 값이 잘못되었습니다. 이는 "참" 또는 "거짓"이어야 합니다.</Text>
			<Text Lang="pl">Wartość '{0}' jest nieprawidłowa. Musi być ona równa 'True' lub 'False'.</Text>
			<Text Lang="es">El valor de "{0}" no es válido. Debe ser "True" o "False".</Text>
			<Text Lang="it">Un valore di "{0}" non è valido. Deve essere o "True" o "False"</Text>
			<Text Lang="de">Der Wert "{0}" ist ungültig. Er muss entweder "True" or "False" sein.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.UnknownVariableType">
			<Context/>
			<Text Lang="en">Unknown variable type "{0}" for global variable "{1}".</Text>
			<Text Lang="uk">Невідомий тип змінної "{0}" для глобальної змінної "{1}".</Text>
			<Text Lang="fr">Type de variable inconnu "{0}" pour la variable globale "{1}".</Text>
			<Text Lang="pt-BR">Tipo de variável desconhecida tipo "{0}" para variável global "{1}".</Text>
			<Text Lang="zh">全局变量 "{1}" 未知的变量类型 "{0}" 。</Text>
			<Text Lang="ko">전역 변수 "{1}"에 대한 알 수 없는 변수 유형 "{0}"입니다.</Text>
			<Text Lang="pl">Nieznana zmienna typu '{0}' dla zmiennej globalnej '{1}'.</Text>
			<Text Lang="es">Tipo de variable "{0}" desconocido para la variable global "{1}".</Text>
			<Text Lang="it">Tipo di variabile "{0}" sconosciuto per la variabile globale "{1}".</Text>
			<Text Lang="de">Unbekannter Variablen-Typ "{0}" für globale Variable "{1}".</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.WriteModelFailed">
			<Context>error if the export of an object property has failed. {0}: name of property, {1}: display name of the object, {2}: type of object (e.g Entity), {3} the numeric Id of that object</Context>
			<Text Lang="de">Der Export der Eigenschaft '{0}' des des Objektes '{1}' (Typ: {2}, Id: {3}) ist fehlgeschlagen.</Text>
			<Text Lang="uk">Не вдалося експортувати властивість '{0}' об’єкта '{1}' (тип: {2}, Id: {3}).</Text>
			<Text Lang="fr">Impossible d'exporter la propriété '{0}' de l'objet '{1}' (Type : {2}, Identifiant : {3}).</Text>
			<Text Lang="pt-BR">A exportação da propriedade '{0}' do objeto '{1}' (tipo: {2}, Id: {3}) falhou.</Text>
			<Text Lang="zh">导出对象 '{1}' (类型：{2}，ID：{3}) 的属性 '{0}' 失败。</Text>
			<Text Lang="ko">객체 '{0}'의 속성 '{1}' 의 내보내기가 (형식: {2}, Id: {3}) 실패 했습니다.</Text>
			<Text Lang="en">Failed to export property '{0}' of object '{1}' (Type: {2}, Id: {3}).</Text>
		</TextDefinition>

