		<TextDefinition Key="Messages.PinScriptSearch.Description">
			<Context>bbcode formated string for displaying an pin with internal issues</Context>
			<Text Lang="en">{0} {1} of '{2}'</Text>
			<Text Lang="uk">{0} {1} of '{2}'</Text>
