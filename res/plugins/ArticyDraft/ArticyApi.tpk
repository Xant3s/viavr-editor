			<Text Lang="ru">Ожидалось 'BY', но был найден '{0}'.</Text>
			<Text Lang="de">Erwarte 'BY', vorgefunden wurde aber: '{0}'.</Text>
		</TextDefinition>

		<TextDefinition Key="ParseError.ExpectedAscOrDescButFound">
			<Context/>
			<Text Lang="en">Expecting 'ASC' or 'DESC', but found '{0}'.</Text>
			<Text Lang="uk">Очікувалося 'ASC' або 'DESC', а знайдено '{0}'.</Text>
			<Text Lang="fr">Attendait 'ASC' ou 'DESC', mais a trouvé '{0}'.</Text>
			<Text Lang="pt-BR">Esperando 'ASC' ou 'DESC', mas encontrou '{0}'.</Text>
