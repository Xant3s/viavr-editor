			<Context/>
			<Text Lang="en">Change anchor color</Text>
			<Text Lang="uk">Змінити колір якору</Text>
			<Text Lang="fr">Changer couleur ancre</Text>
			<Text Lang="pt-BR">Mudar cor de âncora</Text>
