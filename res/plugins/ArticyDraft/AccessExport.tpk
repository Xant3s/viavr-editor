			<Text Lang="es">El ID de plantilla {0:X} ya está registrado.</Text>
			<Text Lang="it">L'id di template {0:X} è già registrato.</Text>
			<Text Lang="ru">ID шаблона {0:X} уже зарегистрирован.</Text>
			<Text Lang="de">Ein Template mit id {0:X} ist bereits registriert.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.ClassNameAlreadyRegistered">
			<Context/>
			<Text Lang="en">Class with name "{0}" is already registered.</Text>
			<Text Lang="uk">Класс з назвою "{0}" вже зареєстрований.</Text>
			<Text Lang="fr">La classe avec le nom "{0}" est déjà enregistrée.</Text>
			<Text Lang="pt-BR">Classe com nome "{0}" já está registrado.</Text>
			<Text Lang="zh">命名为 "{0}" 的类已被注册。</Text>
			<Text Lang="ko">이름이 "{0}"인 클래스가 이미 등록되었습니다.</Text>
