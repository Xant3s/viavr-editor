			<xs:element name="StageDirections" type="ad:LocalizableTextType" minOccurs="0"/>
			<xs:element name="MenuText" type="ad:LocalizableTextType" minOccurs="0" />
		</xs:sequence>
		<xs:attributeGroup ref="ad:TemplatableObjectAttributeGroup" />
	</xs:complexType>

	<xs:complexType name="HubType" mixed="true">
		<xs:sequence>
			<xs:group ref="ad:TemplatableObjectType" />
			<xs:element name="Pins" type="ad:PinsType" minOccurs="0"/>
			<xs:element name="Position" type="ad:PointType" />
			<xs:element name="Size" type="ad:SizeType" />
			<xs:element name="ZIndex" type="xs:float" />
		</xs:sequence>
		<xs:attributeGroup ref="ad:TemplatableObjectAttributeGroup" />
	</xs:complexType>

	<xs:complexType name="JumpType">
		<xs:sequence>
			<xs:group ref="ad:TemplatableObjectSimpleDisplayNameType" />
			<xs:element name="Pins" type="ad:PinsType"/>
			<xs:element name="Position" type="ad:PointType" />
			<xs:element name="Size" type="ad:SizeType" />
			<xs:element name="ZIndex" type="xs:float" />
			<xs:element name="Target" type="ad:ConnectionRefType"/>
		</xs:sequence>
		<xs:attributeGroup ref="ad:TemplatableObjectAttributeGroup" />
	</xs:complexType>

	<xs:complexType name="ConditionType">
		<xs:sequence>
			<xs:group ref="ad:TemplatableObjectSimpleDisplayNameType"/>
			<xs:element name="Expression" type="xs:string" />
			<xs:element name="Pins" type="ad:PinsType"/>
			<xs:element name="Position" type="ad:PointType" />
			<xs:element name="Size" type="ad:SizeType" />
			<xs:element name="ZIndex" type="xs:float" />
		</xs:sequence>
		<xs:attributeGroup ref="ad:TemplatableObjectAttributeGroup" />
	</xs:complexType>

	<xs:complexType name="InstructionType">
		<xs:sequence>
			<xs:group ref="ad:TemplatableObjectSimpleDisplayNameType"/>
			<xs:element name="Expression" type="xs:string" />
			<xs:element name="Pins" type="ad:PinsType"/>
			<xs:element name="Position" type="ad:PointType" />
			<xs:element name="Size" type="ad:SizeType" />
			<xs:element name="ZIndex" type="xs:float" />
		</xs:sequence>
		<xs:attributeGroup ref="ad:TemplatableObjectAttributeGroup" />
	</xs:complexType>


	<!-- ========= location related ========= -->

	<xs:complexType name="FillType">
		<xs:attribute name="Color" type="ad:ColorWithAplhaType" use="required" />
	</xs:complexType>

	<xs:complexType name="OutlineType">
		<xs:attribute name="Color" type="ad:ColorWithAplhaType" use="required" />
