	<Category Name="Ui" Namespace=".Navigator.Conflicts">

		<TextDefinition Key="Messages.InvalidTrait.Description">
			<Context>bbcode formated string for displaying that an item has one invalid property</Context>
			<Text Lang="en">[col=white][b]{0}[/b][/col][col=darkgray]: 1 invalid property value [/col][col=white]([/col][col=lightblue]{1}[/col][col=white])[/col]</Text>
			<Text Lang="uk">[col=white][b]{0}[/b][/col][col=darkgray]: 1 недопустиме значення властивостей [/col][col=white]([/col][col=lightblue]{1}[/col][col=white])[/col]</Text>
