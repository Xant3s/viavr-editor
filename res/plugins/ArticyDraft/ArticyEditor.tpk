	<Category Name="Ui" Namespace=".Enum.ScriptExpressionTypes">

		<TextDefinition Key="Unknown.Caption">
			<Context>text for ScriptExpressionTypes enum combobox</Context>
			<Text Lang="en">No error validation</Text>
			<Text Lang="uk">Немає перевірки помилок</Text>
			<Text Lang="fr">Aucune validation d'erreur</Text>
			<Text Lang="pt-BR">Sem validação de erro</Text>
			<Text Lang="zh">无错误验证</Text>
			<Text Lang="ko">오류 유효성 검사 없음</Text>
			<Text Lang="pl">Błąd nie zatwierdzony</Text>
			<Text Lang="es">Sin validación de errores</Text>
			<Text Lang="it">Nessuna verifica di errore</Text>
			<Text Lang="de">Keine Fehlervalidierung</Text>
		</TextDefinition>

		<TextDefinition Key="Unknown.Description">
			<Context>tooltip for ScriptExpressionTypes enum combobox</Context>
			<Text Lang="en">The content of the script-box won’t be validated at all.</Text>
			<Text Lang="uk">Вміст скрипту не буде затверджений взагалі.</Text>
			<Text Lang="fr">Le contenu de la boîte script ne sera pas validé du tout.</Text>
			<Text Lang="pt-BR">O contexto da caixa-script não será validado.</Text>
			<Text Lang="zh">脚本框的内容将不会进行验证。</Text>
			<Text Lang="ko">스크립트-박스의 내용은 전혀 검증되지 않습니다.</Text>
			<Text Lang="es">Sin validación de errores</Text>
			<Text Lang="it">Nessuna verifica di errore</Text>
			<Text Lang="de">Der Inhalt der Skriptbox wird in keinster Weise validiert.</Text>
		</TextDefinition>

		<TextDefinition Key="Condition.Caption">
			<Context>text for ScriptExpressionTypes enum combobox</Context>
			<Text Lang="en">Condition</Text>
			<Text Lang="uk">Умова</Text>
			<Text Lang="fr">Condition</Text>
			<Text Lang="pt-BR">Condição</Text>
			<Text Lang="zh">条件</Text>
			<Text Lang="ko">조건</Text>
			<Text Lang="pl">Warunek</Text>
			<Text Lang="es">Condición</Text>
			<Text Lang="it">Condizione</Text>
			<Text Lang="de">Bedingung</Text>
		</TextDefinition>

		<TextDefinition Key="Condition.Description">
			<Context>text for ScriptExpressionTypes enum combobox</Context>
			<Text Lang="en">The content of the script-box will be treated as condition and validated in the same way as at input-pins.</Text>
			<Text Lang="uk">Вміст скрипту буде розглядатися як умова та підтверджений так само, як і на вхідних контактах.</Text>
			<Text Lang="fr">Le contenu de la boîte de script sera traité comme une condition et validé de la même manière que les broches d'entrée.</Text>
			<Text Lang="pt-BR">O contexto da caixa-script será tratado como condição e validade do mesmo jeito que pinos de entrada.</Text>
			<Text Lang="zh">脚本框的内容将被视为条件，并以与输入端相同的方式进行验证。</Text>
			<Text Lang="ko">스크립트-박스의 내용은 조건으로 처리되고 입력 핀이 검증됩니다.</Text>
			<Text Lang="es">Condición</Text>
			<Text Lang="it">Condizione</Text>
			<Text Lang="de">Der Inhalt der Skriptbox wird behandelt wie eine Bedingung und genauso validiert wie Eingabe Pins.</Text>
		</TextDefinition>

		<TextDefinition Key="Outcome.Caption">
			<Context>text for ScriptExpressionTypes enum combobox</Context>
			<Text Lang="en">Instruction</Text>
			<Text Lang="uk">Інструкція</Text>
			<Text Lang="fr">Consigne</Text>
			<Text Lang="pt-BR">Instrução</Text>
			<Text Lang="zh">指令</Text>
			<Text Lang="ko">지시</Text>
			<Text Lang="pl">Instrukcja</Text>
			<Text Lang="es">Instrucción</Text>
			<Text Lang="it">Istruzione</Text>
			<Text Lang="de">Anweisung</Text>
		</TextDefinition>

		<TextDefinition Key="Outcome.Description">
			<Context>text for ScriptExpressionTypes enum combobox</Context>
			<Text Lang="en">The content of the script-box will be treated as instruction and validated in the same way as at output-pins.</Text>
			<Text Lang="uk">Вміст скрипту буде розглядатися як інструкція та перевірятиметься так само, як і на вихідних контактах.</Text>
			<Text Lang="fr">Le contenu de la boîte de script sera traité comme une consigne et validé de la même manière que les broches de sortie.</Text>
			<Text Lang="pt-BR">O contexto da caixa-script será tratado como condição e validade do mesmo jeito que pinos de saída.</Text>
			<Text Lang="zh">脚本框的内容将被视为指令，并以与输出Pins相同的方式进行验证。</Text>
			<Text Lang="ko">스크립트 상자의 내용은 명령으로 처리되고 출력 핀이 검증됩니다.</Text>
			<Text Lang="es">Instrucción</Text>
			<Text Lang="it">Istruzione</Text>
			<Text Lang="de">Der Inhalt der Skriptbox wird behandelt wie eine Anweisung und genauso validiert wie Ausgabe Pins.</Text>
		</TextDefinition>

	</Category>

