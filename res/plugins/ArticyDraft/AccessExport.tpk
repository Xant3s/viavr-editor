<?xml version='1.0' encoding='utf-8' standalone='yes' ?>
<TextPackage BaseNamespace="Articy.Export.Access" GenerateIds="True" xml:space="preserve" xmlns="http://nevigo.com/TextPackage.xsd">

	<Category Name="System">

		<TextDefinition Key="Title.Caption">
			<Context>tabcontrol label</Context>
			<Text Lang="en">articy:access</Text>
			<Text Lang="uk">articy:access</Text>
			<Text Lang="fr">articy:access</Text>
			<Text Lang="pt-BR">articy:acess</Text>
			<Text Lang="zh">articy:access</Text>
			<Text Lang="ko">articy:access</Text>
			<Text Lang="pl">articy:access</Text>
			<Text Lang="es">articy:access</Text>
			<Text Lang="it">articy:access</Text>
			<Text Lang="ru">articy:access</Text>
			<Text Lang="de">articy:access</Text>
		</TextDefinition>

		<TextDefinition Key="Label.SelectBundle">
			<Context>Bundle file picker label</Context>
			<Text Lang="en">Load bundle descriptor file:</Text>
			<Text Lang="uk">Завантажте файл дескриптора групи:</Text>
			<Text Lang="fr">Charger le fichier descripteur de collection :</Text>
			<Text Lang="pt-BR">Carregar arquivo descritor de pacote:</Text>
			<Text Lang="zh">加载捆绑描述符文件：</Text>
			<Text Lang="ko">번들 설명자 파일을 로드합니다.</Text>
			<Text Lang="pl">Wczytaj plik deksryptora zestawu:</Text>
			<Text Lang="es">Cargar archivo de descripción de lote:</Text>
			<Text Lang="it">Carica il file descrittore del gruppo:</Text>
			<Text Lang="ru">Загрузить файл описания пакета:</Text>
			<Text Lang="de">Bundle-Beschreibungsdatei laden:</Text>
		</TextDefinition>

		<TextDefinition Key="Label.SelectPackages">
			<Context>Package list label</Context>
			<Text Lang="en">Select packages:</Text>
			<Text Lang="uk">Виберіть пакети:</Text>
			<Text Lang="fr">Sélectionner les packs :</Text>
			<Text Lang="pt-BR">Selecionar pacotes:</Text>
			<Text Lang="zh">选择包体：</Text>
			<Text Lang="ko">패키지 선택:</Text>
			<Text Lang="pl">Wybierz paczki:</Text>
			<Text Lang="es">Seleccionar paquetes:</Text>
			<Text Lang="it">Seleziona i pacchetti:</Text>
			<Text Lang="ru">Выбор пакетов:</Text>
			<Text Lang="de">Pakete wählen:</Text>
		</TextDefinition>

		<TextDefinition Key="Label.SelectFolder">
			<Context>Export folder picker label</Context>
			<Text Lang="en">Select export folder:</Text>
			<Text Lang="uk">Виберіть папку експорту:</Text>
			<Text Lang="fr">Sélectionner dossier d'exportation :</Text>
			<Text Lang="pt-BR">Selecionar pacote de exportação:</Text>
			<Text Lang="zh">选择导出文件夹：</Text>
			<Text Lang="ko">내보내기 파일 선택</Text>
			<Text Lang="pl">Wybierz folder eksportu:</Text>
			<Text Lang="es">Seleccionar archivo de exportación:</Text>
			<Text Lang="it">Seleziona la cartella in cui esportare:</Text>
			<Text Lang="ru">Выберите папку для экспорта:</Text>
			<Text Lang="de">Ordner für den Export wählen:</Text>
		</TextDefinition>

		<TextDefinition Key="FolderBrowser.Description">
			<Context>Description text shown in the "browse for folder" dialog to select the output path</Context>
			<Text Lang="en">Select the folder where the generated export files should be written to.</Text>
			<Text Lang="uk">Виберіть папку, куди слід записати створені файли експорту.</Text>
			<Text Lang="fr">Sélectionnez le dossier dans lequel les fichiers d'exportation générés doivent être écrits.</Text>
			<Text Lang="pt-BR">Selecionar o pacote onde os arquivos de exportação gerados deveriam ser escritos.</Text>
			<Text Lang="zh">选择生成的导出文件要写入的文件夹。</Text>
			<Text Lang="ko">생성된 내보내기 파일을 저장할 폴더를 선택합니다.</Text>
			<Text Lang="de">Bitte wählen Sie das Verzeichnis in dem die vom Export generierten Daten gespeichert werden sollen.</Text>
		</TextDefinition>

		<TextDefinition Key="ChoosePackageFile.Filter">
			<Context>File filter for the open file dialog. First part until the '|' is the description, the 2nd the wildcard string for file filtering</Context>
			<Text Lang="en">articy:access package file (*.xml)|*.xml</Text>
			<Text Lang="uk">articy:access файл пакету(*.xml)|*.xml</Text>
			<Text Lang="fr">Fichier de pack articy:access (*.xml)|*.xml</Text>
			<Text Lang="pt-BR">pacote de arquivo articy:acess (*.xml) | *.xml</Text>
			<Text Lang="zh">articy:access 包体文件 (*.xml)|*.xml</Text>
			<Text Lang="ko"><![CDATA[articy:access 패키지 파일 (*.xml)|*.xml
]]></Text>
			<Text Lang="de">articy:access Paket-Beschreibung (*.xml)|*.xml</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.WrongVersion">
			<Context>export</Context>
			<Text Lang="en">Articy CAPI version mismatch.</Text>
			<Text Lang="uk">Невідповідність версій Articy CAPI.</Text>
			<Text Lang="fr">Version CAPI d'Articy incompatible.</Text>
			<Text Lang="pt-BR">Incompatibilidade de versão Articy CAPI.</Text>
			<Text Lang="zh">Articy CAPI 版本不匹配。</Text>
			<Text Lang="ko">Articy CAPI 버전이 일치하지 않습니다.</Text>
			<Text Lang="pl">Niezgodność wersji Articy CAPI.</Text>
			<Text Lang="es">Versión no correspondiente de articy CAPI.</Text>
			<Text Lang="it">Errore nell'abbinamento della versione di Articy CAPI.</Text>
			<Text Lang="ru">Несовпадение версии Articy CAPI.</Text>
			<Text Lang="de">Die Articy CAPI hat die falsche Version.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.MissingPackage">
			<Context/>
			<Text Lang="en">Package "{0}" could not be found.</Text>
			<Text Lang="uk">Не вдалося знайти пакет "{0}".</Text>
			<Text Lang="fr">Le pack "{0}" n'a pas pu être trouvé.</Text>
			<Text Lang="pt-BR">Pacote "{0}" não pôde ser achado.</Text>
			<Text Lang="zh">找不到包体 "{0}" 。</Text>
			<Text Lang="ko">"{0}" 패키지를 찾을 수 없습니다.</Text>
			<Text Lang="pl">Paczka '{0}' nie została znaleziona.</Text>
			<Text Lang="es">El paquete '{0}' no se ha podido encontrar.</Text>
			<Text Lang="it">Il pacchetto "{0}" non può essere trovato.</Text>
			<Text Lang="ru">Модуль {0} не был найден.</Text>
			<Text Lang="de">Package "{0}" konnte nicht gefunden werden.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.SkippedPackage">
			<Context/>
			<Text Lang="en">Package "{0}" has been skipped.</Text>
			<Text Lang="uk">Пакет "{0}" пропущено.</Text>
			<Text Lang="fr">Le pack "{0}" a été ignoré.</Text>
			<Text Lang="pt-BR">Pacote "{0}" foi pulado.</Text>
			<Text Lang="zh">已跳过包体 "{0}" 。</Text>
			<Text Lang="ko">"{0}" 패키지를 건너뛰었습니다.</Text>
			<Text Lang="pl">Paczka '{0}' została pominięta.</Text>
			<Text Lang="de">Package "{0}" wurde ausgelassen.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.MissingAttribute">
			<Context/>
			<Text Lang="en">Tag "{0}" requires attribute "{1}".</Text>
			<Text Lang="uk">Тег "{0}" вимагає атрибута "{1}".</Text>
			<Text Lang="fr">La balise "{0}" nécessite l'attribut "{1}".</Text>
			<Text Lang="pt-BR">Etiqueta "{0}" precisa de atributo "{1}".</Text>
			<Text Lang="zh">标记 "{0}" 需要属性 "{1}"。</Text>
			<Text Lang="ko">태그 "{0}"에는 "{1}" 특성이 필요합니다.</Text>
			<Text Lang="pl">Tag '{0}' wymaga atrybutu '{1}'.</Text>
			<Text Lang="es">La etiqueta "{0}" requiere el atributo "{1}".</Text>
			<Text Lang="it">La tag "{0}" richiede l'attributo "{1}".</Text>
			<Text Lang="ru">Тегу "{0}" необходим атрибут "{1}".</Text>
			<Text Lang="de">Tag "{0}" benötigt das Attribut "{1}".</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.TooManyClasses">
			<Context/>
			<Text Lang="en">The maximum number of classes have been registered.</Text>
			<Text Lang="uk">Зареєстровано максимальну кількість класів.</Text>
			<Text Lang="fr">Le nombre maximum de classes a été enregistré.</Text>
			<Text Lang="pt-BR">O número máximo de classes foi registrado.</Text>
			<Text Lang="zh">已注册的最大类数。</Text>
			<Text Lang="ko">최대 클래스 수가 등록되었습니다.</Text>
			<Text Lang="pl">Została zarejestrowana maksymalna liczba klas.</Text>
			<Text Lang="es">Se ha registrado el número máximo de clases.</Text>
			<Text Lang="it">Il numero massimo di classi è stato registrato.</Text>
			<Text Lang="ru">Было зарегистрировано максимальное количество классов.</Text>
			<Text Lang="de">Die maximale Zahl an Klassen wurde registriert.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.TooManyTemplates">
			<Context/>
			<Text Lang="en">The maximum number of templates have been registered.</Text>
			<Text Lang="uk">Зареєстровано максимальну кількість шаблонів.</Text>
			<Text Lang="fr">Le nombre maximum de modèles a été enregistré.</Text>
			<Text Lang="pt-BR">O numero máximo de módulos foram registrados.</Text>
			<Text Lang="zh">已注册的最大模板数。</Text>
			<Text Lang="ko">최대 템플릿 수가 등록되었습니다.</Text>
			<Text Lang="pl">Została zarejestrowana maksymalna liczba szablonów.</Text>
			<Text Lang="es">Se ha registrado el número máximo de plantillas.</Text>
			<Text Lang="it">Il numero massimo di template è stato registrato.</Text>
			<Text Lang="ru">Было зарегистрировано максимальное количество шаблонов.</Text>
			<Text Lang="de">Die maximale Zahl an Templates wurde registriert.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.QueriesTooComplex">
			<Context>Text for a textbox that warn the user that the export can take long due to many queries used</Context>
			<Text Lang="en"><![CDATA[Because of the large number of calculated strip properties exporting the selected objects will take a long time. 

If you don't need those properties within your export, you should consider to cancel this export and to remove (some) calculated reference strips from the export.

Do you want do continue?]]></Text>
			<Text Lang="uk"><![CDATA[Через велику кількість обчислених властивостей смуги експорт вибраних об'єктів займе більше часу.

Якщо вам не потрібні ці властивості в межах вашого експорту, ви повинні скасувати цей експорт і видалити (деякі) обчислені контрольні смуги з експорту.

Ви хочете продовжити? ]]></Text>
			<Text Lang="fr"><![CDATA[En raison du grand nombre de propriétés de bordereaux calculées, l'exportation des objets sélectionnés prendra beaucoup de temps.

Si vous n'avez pas besoin de ces propriétés dans votre exportation, vous devriez envisager d'annuler cette exportation et de supprimer (certains) bordereaux de référence calculés de l'exportation.

Voulez-vous continuer?]]></Text>
			<Text Lang="pt-BR"><![CDATA[Por causo do número alto de exportação de propriedades de tiras calculadas os objetos selecionados irão tomar bastante tempo.

Se você não precisa destas propriedades dentra da exportação, você deveria considerar cancelar esta exportação e remover (algumas) tiras de referências calculadas da exportação.

Deseja continuar?]]></Text>
			<Text Lang="zh"><![CDATA[由于计算 strip 属性的数量众多，导出所选对象需要很长时间。

如果您在导出中不需要这些属性，则应考虑取消此导出并从导出选项中删除（部分）计算出的引用 strips。

是否要继续？]]></Text>
			<Text Lang="ko"><![CDATA[선택한 객체를 내보내는 계산된 스트립 속성이 너무 많기 때문에 시간이 오래 걸립니다. 

내보내기에 이러한 속성이 필요하지 않은 경우에는 이 내보내기를 취소하고 (일부) 계산된 참조 스트립을 내보내기에서 제거하는 것을 고려해야 합니다.

계속하시겠습니까?]]></Text>
			<Text Lang="pl"><![CDATA[articy:draft wykrył, że eksportowanie wybranych obiektów będzie trwać długo.
To wynika z liczby obliczonych właściwości pasków, które muszą być wykonane.

Jeśli ich nie potrzebujesz, powinieneś rozważyć przerwanie procesu i usunięcie (niektórych) obliczonych odwołań pasków z eksportu.

Czy chcesz kontynuować?]]></Text>
			<Text Lang="de"><![CDATA[Aufgrund der hohen Zahl an berechneten Referenz-Strips wird der Export der selektierten Objekte länger dauern. 

Falls Sie diese Eigenschaften nicht in der exportierten Datei benötigen, sollten Sie den Export abbrechen und (einige) berechnete Strips aus dem Export entfernen.

Wollen Sie fortfahren?]]></Text>
		</TextDefinition>

		<TextDefinition Key="Exception.BaseNotFound">
			<Context>Deriving from a base class</Context>
			<Text Lang="en">Base type "{0}" was not found.</Text>
			<Text Lang="uk">Базовий тип "{0}" не знайдено.</Text>
			<Text Lang="fr">Le type de base "{0}" n'a pas pu être trouvé.</Text>
			<Text Lang="pt-BR">Tipo base "{0}" não foi encontrado.</Text>
			<Text Lang="zh">找不到基础类型 "{0}" 。</Text>
			<Text Lang="ko">기본 유형 "{0}"을(를) 찾을 수 없습니다.</Text>
			<Text Lang="pl">Typ podstawy '{0}' nie został znaleziony.</Text>
			<Text Lang="es">El tipo de datos "{0}" no se ha podido encontrar.</Text>
			<Text Lang="it">La base do tipo "{0}" non è stata trovata.</Text>
			<Text Lang="ru">Базовый тип  "{0}" не был найден.</Text>
			<Text Lang="de">Basistyp "{0}" konnte nicht gefunden werden.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.ClassIdAlreadyRegistered">
			<Context/>
			<Text Lang="en">Class id {0:X} is already registered.</Text>
			<Text Lang="uk">ID классу {0: X} вже зареєстрований.</Text>
			<Text Lang="fr">L'identifiant de classe {0: X} est déjà enregistré.</Text>
			<Text Lang="pt-BR">Id de Classe {0:x} já está registrado.</Text>
			<Text Lang="zh">类ID {0:X} 已被注册。</Text>
			<Text Lang="ko">클래스 ID {0:X}이(가) 이미 등록되어 있습니다.</Text>
			<Text Lang="pl">ID klasy {0:X} jest już zarejestrowane.</Text>
			<Text Lang="es">El ID de clase {0:X} ya está registrado.</Text>
			<Text Lang="it">L'id dei classe {0:X} è già registrato.</Text>
			<Text Lang="ru">ID класса {0:X} уже зарегистрирован.</Text>
			<Text Lang="de">Eine Klasse mit id {0:X} ist bereits registriert.</Text>
		</TextDefinition>

		<TextDefinition Key="Exception.TemplateIdAlreadyRegistered">
			<Context/>
			<Text Lang="en">Template id {0:X} is already registered.</Text>
			<Text Lang="uk">ID шаблону {0: X} вже зареєстрований.</Text>
			<Text Lang="fr">L'identifiant de modèle {0: X} est déjà enregistré.</Text>
			<Text Lang="pt-BR">Id de módulo {0:x} já está registrado.</Text>
			<Text Lang="zh">模板ID {0:X} 已被注册。</Text>
			<Text Lang="ko">템플릿 ID {0:X}이(가) 이미 등록되어 있습니다.</Text>
